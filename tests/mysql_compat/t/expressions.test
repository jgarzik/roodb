--echo # Test: Expressions and operators

CREATE TABLE expr_t (id INT NOT NULL, val INT, name VARCHAR(50), PRIMARY KEY (id));
INSERT INTO expr_t VALUES (1, 10, 'apple');
INSERT INTO expr_t VALUES (2, 20, 'banana');
INSERT INTO expr_t VALUES (3, 30, 'cherry');
INSERT INTO expr_t VALUES (4, NULL, NULL);

--echo # Arithmetic
SELECT 2 + 3;
SELECT 10 - 4;
SELECT 3 * 7;
SELECT 15 / 3;

--echo # Comparison
SELECT id, val FROM expr_t WHERE val > 15;
SELECT id, val FROM expr_t WHERE val >= 20;
SELECT id, val FROM expr_t WHERE val < 25;
SELECT id, val FROM expr_t WHERE val <= 10;
SELECT id, val FROM expr_t WHERE val != 20;

--echo # IN list
SELECT id, name FROM expr_t WHERE name IN ('apple', 'cherry');

--echo # BETWEEN
SELECT id, val FROM expr_t WHERE val BETWEEN 15 AND 35;

--echo # LIKE
SELECT id, name FROM expr_t WHERE name LIKE 'a%';

--echo # IS NULL / IS NOT NULL
SELECT id, val FROM expr_t WHERE val IS NULL;
SELECT id, val FROM expr_t WHERE val IS NOT NULL;

--echo # AND / OR
SELECT id FROM expr_t WHERE val > 15 AND val < 35;
SELECT id FROM expr_t WHERE val < 15 OR val > 25;

--echo # Negation
SELECT id FROM expr_t WHERE NOT val > 20;

DROP TABLE expr_t;
