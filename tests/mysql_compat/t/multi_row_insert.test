--echo # Test: Multi-row INSERT

CREATE TABLE mri_t (id INT NOT NULL, name VARCHAR(50), PRIMARY KEY (id));

--echo # Multi-row VALUES
INSERT INTO mri_t (id, name) VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');
SELECT * FROM mri_t;

--echo # Partial column list
INSERT INTO mri_t (id) VALUES (4);
SELECT * FROM mri_t WHERE id = 4;

DROP TABLE mri_t;
