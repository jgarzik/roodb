# Smoke test: data types
CREATE TABLE smoke_types (
t_int INT NOT NULL,
t_bigint BIGINT,
t_varchar VARCHAR(100),
t_bool BOOLEAN,
t_double DOUBLE,
PRIMARY KEY (t_int)
);
INSERT INTO smoke_types VALUES (1, 9999999999, 'hello world', true, 3.14);
INSERT INTO smoke_types VALUES (2, NULL, NULL, false, -1.5);
SELECT * FROM smoke_types;
t_int	t_bigint	t_varchar	t_bool	t_double
1	9999999999	hello world	1	3.14
2	NULL	NULL	0	-1.5
SELECT t_int, t_varchar FROM smoke_types WHERE t_bool = true;
t_int	t_varchar
1	hello world
SELECT t_int, t_double FROM smoke_types WHERE t_double > 0;
t_int	t_double
1	3.14
DROP TABLE smoke_types;
