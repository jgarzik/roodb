# Test: IS TRUE / IS FALSE / IS UNKNOWN predicates
# IS TRUE / IS FALSE / IS UNKNOWN with literals
SELECT 1 IS TRUE;
expr_0
1
SELECT 0 IS TRUE;
expr_0
0
SELECT NULL IS TRUE;
expr_0
0
SELECT 1 IS FALSE;
expr_0
0
SELECT 0 IS FALSE;
expr_0
1
SELECT NULL IS FALSE;
expr_0
0
SELECT NULL IS UNKNOWN;
expr_0
1
SELECT 1 IS UNKNOWN;
expr_0
0
# IS NOT TRUE / IS NOT FALSE / IS NOT UNKNOWN
SELECT 1 IS NOT TRUE;
expr_0
0
SELECT 0 IS NOT TRUE;
expr_0
1
SELECT NULL IS NOT TRUE;
expr_0
1
SELECT 0 IS NOT FALSE;
expr_0
0
SELECT NULL IS NOT UNKNOWN;
expr_0
0
# IS TRUE / IS FALSE with table data
CREATE TABLE bt (id INT NOT NULL, a INT, PRIMARY KEY (id));
INSERT INTO bt VALUES (1, 1);
INSERT INTO bt VALUES (2, 0);
INSERT INTO bt VALUES (3, NULL);
SELECT id, a, a IS TRUE, a IS FALSE, a IS UNKNOWN FROM bt;
id	a	expr_2	expr_3	expr_4
1	1	1	0	0
2	0	0	1	0
3	NULL	0	0	1
DROP TABLE bt;
