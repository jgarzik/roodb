# Test: Built-in functions
# String functions
SELECT UPPER('hello');
upper('hello')
HELLO
SELECT LOWER('HELLO');
lower('HELLO')
hello
SELECT LENGTH('hello');
length('hello')
5
SELECT CONCAT('hello', ' ', 'world');
concat('hello',' ','world')
hello world
# Numeric functions
SELECT ABS(-5);
abs(-5)
5
SELECT ABS(5);
abs(5)
5
# NULL functions
SELECT COALESCE(NULL, 'fallback');
coalesce(NULL,'fallback')
fallback
SELECT COALESCE('first', 'second');
coalesce('first','second')
first
SELECT COALESCE(NULL, NULL, 'third');
coalesce(NULL,NULL,'third')
third
