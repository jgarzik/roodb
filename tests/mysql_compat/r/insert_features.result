# Test: INSERT IGNORE, INSERT...SELECT, numeric overflow
# Setup
CREATE TABLE t1 (id INT NOT NULL, val INT NOT NULL, PRIMARY KEY (id));
INSERT INTO t1 VALUES (1, 100);
INSERT INTO t1 VALUES (2, 200);
# INSERT ... SELECT (all columns)
CREATE TABLE t2 (id INT NOT NULL, val INT NOT NULL, PRIMARY KEY (id));
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY id;
id	val
1	100
2	200
DROP TABLE t2;
# INSERT ... SELECT with explicit columns
CREATE TABLE t3 (a INT NOT NULL, b INT NOT NULL DEFAULT 0, PRIMARY KEY (a));
INSERT INTO t3 (a) SELECT id FROM t1;
SELECT * FROM t3 ORDER BY a;
a	b
1	0
2	0
DROP TABLE t3;
# INSERT ... SELECT from expression (no FROM)
CREATE TABLE t4 (a VARCHAR(100));
INSERT INTO t4 SELECT 'hello';
SELECT * FROM t4;
a
hello
DROP TABLE t4;
# INSERT IGNORE suppresses errors
CREATE TABLE t5 (a INT NOT NULL);
INSERT IGNORE INTO t5 VALUES (1);
SELECT * FROM t5;
a
1
DROP TABLE t5;
# INSERT IGNORE with subquery
CREATE TABLE t6 (a CHAR(1));
INSERT IGNORE INTO t6 (SELECT 'hello world');
SELECT * FROM t6;
a
hello world
DROP TABLE t6;
# ABS on various types
SELECT ABS(-42);
ABS(-42)
42
SELECT ABS(42);
ABS(42)
42
SELECT ABS(0);
ABS(0)
0
SELECT ABS(-3.14);
ABS(-3.14)
3.14
SELECT ABS(NULL);
ABS(NULL)
NULL
# ABS overflow on i64::MIN
SELECT ABS(-9223372036854775808);
ERROR 22003: BIGINT value is out of range
# Double negation promotes to Decimal (literal context)
SELECT -(-9223372036854775808);
--9223372036854775808
9223372036854775808
# UnsignedInt negation boundary: -(2^63) = i64::MIN (fits)
CREATE TABLE t7 (a BIGINT, b BIGINT UNSIGNED);
INSERT INTO t7 VALUES (-9223372036854775808, 9223372036854775809);
SELECT -a FROM t7;
ERROR 22003: BIGINT value is out of range
SELECT -b FROM t7;
ERROR 22003: BIGINT value is out of range
DROP TABLE t7;
# MOD edge case: i64::MIN % -1 = 0
SELECT -9223372036854775808 MOD -1;
-9223372036854775808 % -1
0
# UPDATE with LIMIT
CREATE TABLE t8 (a INT, b INT);
INSERT INTO t8 VALUES (1,10),(2,20),(3,30),(4,40),(5,50);
UPDATE t8 SET b = 99 LIMIT 3;
SELECT * FROM t8 ORDER BY a;
a	b
1	99
2	99
3	99
4	40
5	50
DROP TABLE t8;
# REPLACE INTO
CREATE TABLE t9 (a INT PRIMARY KEY, b VARCHAR(20));
INSERT INTO t9 VALUES (1, 'one');
INSERT INTO t9 VALUES (2, 'two');
REPLACE INTO t9 (a, b) VALUES (2, 'TWO');
REPLACE INTO t9 (a, b) VALUES (3, 'three');
SELECT * FROM t9 ORDER BY a;
a	b
1	one
2	two
3	three
DROP TABLE t9;
# Cleanup
DROP TABLE t1;
