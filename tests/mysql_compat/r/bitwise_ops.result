# Test: Bitwise operators
# Bitwise OR
SELECT 1 | 2;
expr_0
3
SELECT 5 | 3;
expr_0
7
# Bitwise AND
SELECT 5 & 3;
expr_0
1
SELECT 7 & 2;
expr_0
2
# Bitwise XOR
SELECT 5 ^ 3;
expr_0
6
SELECT 7 ^ 2;
expr_0
5
# NULL propagation for bitwise ops
SELECT 1 | NULL;
expr_0
NULL
SELECT 1 & NULL;
expr_0
NULL
SELECT 1 ^ NULL;
expr_0
NULL
SELECT NULL | NULL;
expr_0
NULL
