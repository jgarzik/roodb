# Test: NULL handling
CREATE TABLE null_t (id INT NOT NULL, val INT, name VARCHAR(50), PRIMARY KEY (id));
INSERT INTO null_t VALUES (1, 10, 'hello');
INSERT INTO null_t VALUES (2, NULL, NULL);
INSERT INTO null_t VALUES (3, 0, '');
# NULL comparisons
SELECT id FROM null_t WHERE val IS NULL;
id
2
SELECT id FROM null_t WHERE val IS NOT NULL;
id
1
3
SELECT id FROM null_t WHERE name IS NULL;
id
2
# NULL in expressions
SELECT id, val + 1 FROM null_t;
id	val + 1
1	11
2	NULL
3	1
# COUNT with NULLs
SELECT COUNT(*) FROM null_t;
count(NULL)
3
SELECT COUNT(val) FROM null_t;
count(val)
2
DROP TABLE null_t;
