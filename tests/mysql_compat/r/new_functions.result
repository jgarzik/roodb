# Test: IF(), ISNULL(), IFNULL(), division by zero, DATE type
# Division by zero returns NULL
SELECT 1 / 0;
1 / 0
NULL
SELECT 10 / 0;
10 / 0
NULL
SELECT 5 % 0;
5 % 0
NULL
# IF() function
SELECT IF(1, 'yes', 'no');
IF(1,'yes','no')
yes
SELECT IF(0, 'yes', 'no');
IF(0,'yes','no')
no
SELECT IF(NULL, 'yes', 'no');
IF(NULL,'yes','no')
no
# IF() with expressions
CREATE TABLE if_t (id INT NOT NULL, val INT, PRIMARY KEY (id));
INSERT INTO if_t VALUES (1, 10);
INSERT INTO if_t VALUES (2, NULL);
INSERT INTO if_t VALUES (3, 0);
SELECT id, IF(val, 'truthy', 'falsy') FROM if_t;
id	IF(val,'truthy','falsy')
1	truthy
2	falsy
3	falsy
DROP TABLE if_t;
# ISNULL() function
SELECT ISNULL(1);
ISNULL(1)
0
SELECT ISNULL(NULL);
ISNULL(NULL)
1
SELECT ISNULL('hello');
ISNULL('hello')
0
# IFNULL() function
SELECT IFNULL(1, 2);
IFNULL(1,2)
1
SELECT IFNULL(NULL, 2);
IFNULL(NULL,2)
2
SELECT IFNULL(NULL, 'default');
IFNULL(NULL,'default')
default
# DATE column type
CREATE TABLE date_t (id INT NOT NULL, d DATE, PRIMARY KEY (id));
INSERT INTO date_t VALUES (1, '2024-01-15');
SELECT id, d FROM date_t;
id	d
1	2024-01-15
DROP TABLE date_t;
# Test INET6_ATON / INET6_NTOA round-trip
SELECT HEX(INET6_ATON('::1'));
HEX(INET6_ATON('::1'))
00000000000000000000000000000001
SELECT HEX(INET6_ATON('192.168.1.1'));
HEX(INET6_ATON('192.168.1.1'))
C0A80101
SELECT HEX(INET6_ATON('2001:db8::1'));
HEX(INET6_ATON('2001:db8::1'))
20010DB8000000000000000000000001
SELECT INET6_NTOA(INET6_ATON('::1'));
INET6_NTOA(INET6_ATON('::1'))
::1
SELECT INET6_NTOA(INET6_ATON('192.168.1.1'));
INET6_NTOA(INET6_ATON('192.168.1.1'))
192.168.1.1
SELECT INET6_ATON(NULL);
INET6_ATON(NULL)
NULL
SELECT INET6_ATON('not_an_ip');
INET6_ATON('not_an_ip')
NULL
SELECT INET6_NTOA(NULL);
INET6_NTOA(NULL)
NULL
# Test WEIGHT_STRING
SELECT HEX(WEIGHT_STRING('a'));
HEX(WEIGHT_STRING('a'))
0041
SELECT HEX(WEIGHT_STRING('A'));
HEX(WEIGHT_STRING('A'))
0041
SELECT HEX(WEIGHT_STRING('abc'));
HEX(WEIGHT_STRING('abc'))
004100420043
SELECT WEIGHT_STRING('a') = WEIGHT_STRING('A');
WEIGHT_STRING('a') = WEIGHT_STRING('A')
1
SELECT WEIGHT_STRING(NULL);
WEIGHT_STRING(NULL)
NULL
# Test GET_LOCK / RELEASE_LOCK / IS_FREE_LOCK
SELECT IS_FREE_LOCK('mylock');
IS_FREE_LOCK('mylock')
1
SELECT GET_LOCK('mylock', 0);
GET_LOCK('mylock',0)
1
SELECT IS_FREE_LOCK('mylock');
IS_FREE_LOCK('mylock')
0
SELECT GET_LOCK('mylock', 0);
GET_LOCK('mylock',0)
1
SELECT RELEASE_LOCK('mylock');
RELEASE_LOCK('mylock')
1
SELECT IS_FREE_LOCK('mylock');
IS_FREE_LOCK('mylock')
1
SELECT RELEASE_LOCK('nonexistent');
RELEASE_LOCK('nonexistent')
NULL
# Test STDDEV / VARIANCE aggregates
CREATE TABLE stats_t (val DOUBLE);
INSERT INTO stats_t VALUES (2),(4),(4),(4),(5),(5),(7),(9);
SELECT AVG(val) FROM stats_t;
AVG(val)
5
SELECT VARIANCE(val) FROM stats_t;
VARIANCE(val)
4
SELECT STDDEV(val) FROM stats_t;
STDDEV(val)
2.138089935299395
SELECT VAR_POP(val) FROM stats_t;
VAR_POP(val)
4
SELECT STDDEV_POP(val) FROM stats_t;
STDDEV_POP(val)
2
SELECT VAR_SAMP(val) FROM stats_t;
VAR_SAMP(val)
4.571428571428571
SELECT STDDEV_SAMP(val) FROM stats_t;
STDDEV_SAMP(val)
2.138089935299395
DROP TABLE stats_t;
# STDDEV edge cases
CREATE TABLE stats_edge (v INT);
INSERT INTO stats_edge VALUES (5);
SELECT STDDEV(v) FROM stats_edge;
STDDEV(v)
0
SELECT VARIANCE(v) FROM stats_edge;
VARIANCE(v)
0
SELECT STDDEV_SAMP(v) FROM stats_edge;
STDDEV_SAMP(v)
0
DROP TABLE stats_edge;
