# WEEKOFYEAR and TO_SECONDS tests
# --- WEEKOFYEAR ---
SELECT WEEKOFYEAR('2024-01-01');
WEEKOFYEAR('2024-01-01')
1
SELECT WEEKOFYEAR('2024-01-07');
WEEKOFYEAR('2024-01-07')
1
SELECT WEEKOFYEAR('2024-06-15');
WEEKOFYEAR('2024-06-15')
24
SELECT WEEKOFYEAR('2024-12-31');
WEEKOFYEAR('2024-12-31')
53
# --- WEEKOFYEAR NULL ---
SELECT WEEKOFYEAR(NULL);
WEEKOFYEAR(NULL)
NULL
# --- TO_SECONDS ---
SELECT TO_SECONDS('2024-01-15');
TO_SECONDS('2024-01-15')
212572080000
SELECT TO_SECONDS('2024-01-15 12:00:00');
TO_SECONDS('2024-01-15 12:00:00')
212572123200
# --- TO_SECONDS = TO_DAYS * 86400 for date-only ---
SELECT TO_SECONDS('2024-01-15') = TO_DAYS('2024-01-15') * 86400;
TO_SECONDS('2024-01-15') = TO_DAYS('2024-01-15') * 86400
1
SELECT TO_SECONDS('1999-12-31') = TO_DAYS('1999-12-31') * 86400;
TO_SECONDS('1999-12-31') = TO_DAYS('1999-12-31') * 86400
1
# --- TO_SECONDS with time adds hours/min/sec ---
SELECT TO_SECONDS('2024-01-15 12:00:00') - TO_SECONDS('2024-01-15') = 43200;
TO_SECONDS('2024-01-15 12:00:00') - TO_SECONDS('2024-01-15') = 43200
1
SELECT TO_SECONDS('2024-01-15 01:01:01') - TO_SECONDS('2024-01-15') = 3661;
TO_SECONDS('2024-01-15 01:01:01') - TO_SECONDS('2024-01-15') = 3661
1
# --- TO_SECONDS NULL ---
SELECT TO_SECONDS(NULL);
TO_SECONDS(NULL)
NULL
