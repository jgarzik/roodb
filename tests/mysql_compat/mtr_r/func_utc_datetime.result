# UTC date/time functions
# --- UTC_DATE returns a valid date ---
SELECT LENGTH(UTC_DATE()) = 10;
LENGTH(UTC_DATE()) = 10
1
SELECT UTC_DATE() >= '2024-01-01';
UTC_DATE() >= '2024-01-01'
1
# --- UTC_TIME returns a valid time ---
SELECT LENGTH(UTC_TIME()) = 8;
LENGTH(UTC_TIME()) = 8
1
# --- UTC_TIMESTAMP returns a valid datetime ---
SELECT LENGTH(UTC_TIMESTAMP()) = 19;
LENGTH(UTC_TIMESTAMP()) = 19
1
SELECT UTC_TIMESTAMP() >= '2024-01-01 00:00:00';
UTC_TIMESTAMP() >= '2024-01-01 00:00:00'
1
