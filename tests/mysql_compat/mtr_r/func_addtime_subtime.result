# ADDTIME / SUBTIME tests
# --- ADDTIME with datetime ---
SELECT ADDTIME('2024-01-01 10:00:00', '05:30:00');
ADDTIME('2024-01-01 10:00:00','05:30:00')
2024-01-01 15:30:00
SELECT ADDTIME('2024-01-01 23:00:00', '02:00:00');
ADDTIME('2024-01-01 23:00:00','02:00:00')
2024-01-02 01:00:00
SELECT ADDTIME('2024-12-31 23:30:00', '01:00:00');
ADDTIME('2024-12-31 23:30:00','01:00:00')
2025-01-01 00:30:00
# --- ADDTIME with time ---
SELECT ADDTIME('10:00:00', '05:30:00');
ADDTIME('10:00:00','05:30:00')
15:30:00
SELECT ADDTIME('00:00:00', '12:00:00');
ADDTIME('00:00:00','12:00:00')
12:00:00
SELECT ADDTIME('23:59:59', '00:00:01');
ADDTIME('23:59:59','00:00:01')
24:00:00
# --- SUBTIME with datetime ---
SELECT SUBTIME('2024-01-01 10:00:00', '05:30:00');
SUBTIME('2024-01-01 10:00:00','05:30:00')
2024-01-01 04:30:00
SELECT SUBTIME('2024-01-01 02:00:00', '03:00:00');
SUBTIME('2024-01-01 02:00:00','03:00:00')
2023-12-31 23:00:00
SELECT SUBTIME('2024-01-15 00:00:00', '00:00:01');
SUBTIME('2024-01-15 00:00:00','00:00:01')
2024-01-14 23:59:59
# --- SUBTIME with time ---
SELECT SUBTIME('10:00:00', '03:00:00');
SUBTIME('10:00:00','03:00:00')
07:00:00
SELECT SUBTIME('01:00:00', '00:30:00');
SUBTIME('01:00:00','00:30:00')
00:30:00
