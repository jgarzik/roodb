SELECT DATE_FORMAT(f1, '%l.%i %p') , DATE_FORMAT(f2, '%l.%i %p') FROM t1;
DATE_FORMAT(f1,'%l.%i %p')	DATE_FORMAT(f2,'%l.%i %p')
NULL	NULL
DROP TABLE t1;
CREATE TABLE t1 (f1 DATE);
CREATE TABLE t2 (f2 VARCHAR(8));
CREATE TABLE t3 (f2 CHAR(8));
