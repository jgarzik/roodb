DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
id INT,
name VARCHAR(20),
score DECIMAL(5,2),
grade CHAR(1)
);
INSERT INTO t1 VALUES (1, 'Alice', 95.50, 'A');
INSERT INTO t1 VALUES (2, 'Bob', 87.25, 'B');
INSERT INTO t1 VALUES (3, 'Carol', 87.25, 'B');
INSERT INTO t1 VALUES (4, 'David', 72.00, 'C');
INSERT INTO t1 VALUES (5, 'Eve', NULL, NULL);
INSERT INTO t1 VALUES (6, 'Frank', 92.75, 'A');
INSERT INTO t1 VALUES (7, 'Grace', 68.50, 'D');
INSERT INTO t1 VALUES (8, 'Henry', 72.00, 'C');
SELECT * FROM t1 ORDER BY id LIMIT 3;
id	name	score	grade
1	Alice	95.50	A
2	Bob	87.25	B
3	Carol	87.25	B
SELECT * FROM t1 ORDER BY id LIMIT 0;
id	name	score	grade
SELECT * FROM t1 ORDER BY id LIMIT 100;
id	name	score	grade
1	Alice	95.50	A
2	Bob	87.25	B
3	Carol	87.25	B
4	David	72.00	C
5	Eve	NULL	NULL
