7	Grace	68.50	D
8	Henry	72.00	C
SELECT * FROM t1 ORDER BY id LIMIT 3 OFFSET 2;
id	name	score	grade
3	Carol	87.25	B
4	David	72.00	C
5	Eve	NULL	NULL
SELECT * FROM t1 ORDER BY id LIMIT 3, 3;
id	name	score	grade
4	David	72.00	C
5	Eve	NULL	NULL
6	Frank	92.75	A
SELECT * FROM t1 ORDER BY id LIMIT 2 OFFSET 6;
id	name	score	grade
7	Grace	68.50	D
8	Henry	72.00	C
SELECT * FROM t1 ORDER BY id LIMIT 2 OFFSET 10;
id	name	score	grade
SELECT id, name, score FROM t1 ORDER BY score DESC, id ASC LIMIT 5;
id	name	score
1	Alice	95.50
6	Frank	92.75
2	Bob	87.25
3	Carol	87.25
4	David	72.00
SELECT id, name, score FROM t1 WHERE score IS NOT NULL ORDER BY -score LIMIT 3;
id	name	score
1	Alice	95.50
6	Frank	92.75
2	Bob	87.25
SELECT id, name, score, score * 2 AS doubled FROM t1 WHERE score IS NOT NULL ORDER BY score * 2 DESC LIMIT 3;
id	name	score	doubled
1	Alice	95.50	191.00
6	Frank	92.75	185.50
2	Bob	87.25	174.50
