SELECT id, name, score FROM t1 ORDER BY 3, 1 LIMIT 5;
id	name	score
5	Eve	NULL
7	Grace	68.50
4	David	72.00
8	Henry	72.00
2	Bob	87.25
SELECT * FROM (SELECT * FROM t1 ORDER BY score DESC LIMIT 3) AS top3 ORDER BY id;
id	name	score	grade
1	Alice	95.50	A
2	Bob	87.25	B
6	Frank	92.75	A
SELECT grade, COUNT(*) AS cnt, AVG(score) AS avg_score
FROM t1
WHERE score IS NOT NULL
GROUP BY grade
ORDER BY avg_score DESC;
grade	cnt	avg_score
A	2	94.125
B	2	87.25
C	2	72
D	1	68.5
SELECT grade, MIN(score), MAX(score)
FROM t1
WHERE score IS NOT NULL
GROUP BY grade
ORDER BY grade;
grade	MIN(score)	MAX(score)
A	92.75	95.50
B	87.25	87.25
C	72.00	72.00
D	68.50	68.50
SELECT MAX(score) FROM t1;
MAX(score)
95.50
SELECT * FROM t1 WHERE score IS NOT NULL ORDER BY score DESC LIMIT 1;
id	name	score	grade
1	Alice	95.50	A
SELECT * FROM t1 WHERE score IS NOT NULL ORDER BY score ASC LIMIT 1;
id	name	score	grade
7	Grace	68.50	D
SELECT id, name, score,
CASE WHEN score >= 90 THEN 'excellent'
       WHEN score >= 80 THEN 'good'
       WHEN score >= 70 THEN 'average'
       ELSE 'below' END AS rating
FROM t1
WHERE score IS NOT NULL
ORDER BY CASE WHEN score >= 90 THEN 1
WHEN score >= 80 THEN 2
WHEN score >= 70 THEN 3
ELSE 4 END, name;
id	name	score	rating
1	Alice	95.50	excellent
6	Frank	92.75	excellent
2	Bob	87.25	good
3	Carol	87.25	good
4	David	72.00	average
8	Henry	72.00	average
7	Grace	68.50	below
DROP TABLE t1;
