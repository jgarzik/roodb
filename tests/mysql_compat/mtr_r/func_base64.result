# TO_BASE64 / FROM_BASE64
# --- TO_BASE64 ---
SELECT TO_BASE64('abc');
TO_BASE64('abc')
YWJj
SELECT TO_BASE64('');
TO_BASE64('')

SELECT TO_BASE64('A');
TO_BASE64('A')
QQ==
SELECT TO_BASE64(NULL);
TO_BASE64(NULL)
NULL
# --- FROM_BASE64 ---
SELECT FROM_BASE64('YWJj');
FROM_BASE64('YWJj')
abc
SELECT FROM_BASE64('');
FROM_BASE64('')

SELECT FROM_BASE64('QQ==');
FROM_BASE64('QQ==')
A
SELECT FROM_BASE64(NULL);
FROM_BASE64(NULL)
NULL
# --- Round-trip ---
SELECT FROM_BASE64(TO_BASE64('test string'));
FROM_BASE64(TO_BASE64('test string'))
test string
SELECT FROM_BASE64(TO_BASE64('0123456789'));
FROM_BASE64(TO_BASE64('0123456789'))
0123456789
