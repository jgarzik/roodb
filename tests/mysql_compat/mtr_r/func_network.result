# IS_IPV4 / IS_IPV6
# --- IS_IPV4 ---
SELECT IS_IPV4('192.168.1.1');
IS_IPV4('192.168.1.1')
1
SELECT IS_IPV4('10.0.0.1');
IS_IPV4('10.0.0.1')
1
SELECT IS_IPV4('255.255.255.255');
IS_IPV4('255.255.255.255')
1
SELECT IS_IPV4('0.0.0.0');
IS_IPV4('0.0.0.0')
1
SELECT IS_IPV4('::1');
IS_IPV4('::1')
0
SELECT IS_IPV4('hello');
IS_IPV4('hello')
0
SELECT IS_IPV4('');
IS_IPV4('')
0
SELECT IS_IPV4(NULL);
IS_IPV4(NULL)
0
# --- IS_IPV6 ---
SELECT IS_IPV6('::1');
IS_IPV6('::1')
1
SELECT IS_IPV6('2001:db8::1');
IS_IPV6('2001:db8::1')
1
SELECT IS_IPV6('fe80::1');
IS_IPV6('fe80::1')
1
SELECT IS_IPV6('::ffff:192.168.1.1');
IS_IPV6('::ffff:192.168.1.1')
1
SELECT IS_IPV6('192.168.1.1');
IS_IPV6('192.168.1.1')
0
SELECT IS_IPV6('hello');
IS_IPV6('hello')
0
SELECT IS_IPV6('');
IS_IPV6('')
0
SELECT IS_IPV6(NULL);
IS_IPV6(NULL)
0
