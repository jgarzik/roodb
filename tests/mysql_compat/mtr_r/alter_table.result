DROP TABLE IF EXISTS t1, t2;
CREATE TABLE t1 (a int);
ALTER TABLE t1 ADD COLUMN b int;
INSERT INTO t1 VALUES (1, 10);
SELECT * FROM t1;
a	b
1	10
DROP TABLE t1;
CREATE TABLE t1 (a int, b int);
ALTER TABLE t1 ADD COLUMN c varchar(20) NOT NULL DEFAULT 'x';
DESC t1;
Field	Type	Null	Key	Default	Extra
a	INT	YES		NULL	
b	INT	YES		NULL	
c	VARCHAR(20)	NO		'x'	
DROP TABLE t1;
CREATE TABLE t1 (a int, b varchar(10));
INSERT INTO t1 VALUES (1, 'abc');
ALTER TABLE t1 MODIFY COLUMN b varchar(50);
DESC t1;
Field	Type	Null	Key	Default	Extra
a	INT	YES		NULL	
b	VARCHAR(50)	YES		NULL	
SELECT * FROM t1;
a	b
1	abc
DROP TABLE t1;
CREATE TABLE t1 (a int, b int);
INSERT INTO t1 VALUES (1, 100);
ALTER TABLE t1 CHANGE COLUMN b new_b bigint;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	INT	YES		NULL	
new_b	BIGINT	YES		NULL	
SELECT * FROM t1;
a	new_b
1	100
DROP TABLE t1;
