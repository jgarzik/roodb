CREATE TABLE t1 (
id int NOT NULL default 0,
name varchar(10) default NULL,
PRIMARY KEY (id)
);
INSERT INTO t1 VALUES (1,'aaa'),(2,'aaa'),(3,'aaa');
CREATE TABLE t2 (
id int NOT NULL default 0,
name varchar(10) default NULL,
PRIMARY KEY (id)
);
INSERT INTO t2 VALUES (2,'bbb'),(3,'bbb'),(4,'bbb');
SELECT t1.id, t1.name, t2.name FROM t1 INNER JOIN t2 ON t1.id=t2.id ORDER BY t1.id;
id	name	name
2	aaa	bbb
3	aaa	bbb
UPDATE t1 SET name='updated' WHERE id = 2;
UPDATE t1 SET name='updated' WHERE id = 3;
SELECT * FROM t1 ORDER BY id;
id	name
1	aaa
2	updated
3	updated
SELECT * FROM t2 ORDER BY id;
id	name
2	bbb
3	bbb
4	bbb
DROP TABLE t1,t2;
CREATE TABLE t1 (
id int NOT NULL,
tst text,
tst1 text,
PRIMARY KEY (id)
);
CREATE TABLE t2 (
ID int NOT NULL,
ParId int default NULL,
tst text,
tst1 text,
PRIMARY KEY (ID)
);
INSERT INTO t1 VALUES(1, 'MySQL','MySQL AB'), (2, 'MSSQL','Microsoft'), (3, 'ORACLE','ORACLE');
INSERT INTO t2 VALUES(1, 1, NULL, NULL), (2, 2, NULL, NULL), (3, 3, NULL, NULL);
SELECT * FROM t2 ORDER BY ID;
ID	ParId	tst	tst1
1	1	NULL	NULL
2	2	NULL	NULL
3	3	NULL	NULL
UPDATE t2 SET tst = 'MySQL', tst1 = 'MySQL AB' WHERE ParId = 1;
UPDATE t2 SET tst = 'MSSQL', tst1 = 'Microsoft' WHERE ParId = 2;
UPDATE t2 SET tst = 'ORACLE', tst1 = 'ORACLE' WHERE ParId = 3;
SELECT * FROM t2 ORDER BY ID;
ID	ParId	tst	tst1
1	1	MySQL	MySQL AB
2	2	MSSQL	Microsoft
3	3	ORACLE	ORACLE
SELECT t2.ID, t2.ParId, t2.tst, t2.tst1, t1.tst AS t1_tst, t1.tst1 AS t1_tst1
FROM t2 INNER JOIN t1 ON t2.ParId = t1.id ORDER BY t2.ID;
ID	ParId	tst	tst1	t1_tst	t1_tst1
1	1	MySQL	MySQL AB	MySQL	MySQL AB
2	2	MSSQL	Microsoft	MSSQL	Microsoft
3	3	ORACLE	ORACLE	ORACLE	ORACLE
DROP TABLE t2, t1;
