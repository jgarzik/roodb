SELECT t1.c1, t1.c2, t2.c1 AS t2c1, t2.c2 AS t2c2, t3.c1 AS t3c1, t3.c2 AS t3c2
FROM t1
INNER JOIN t2 ON t1.c1 = t2.c2
INNER JOIN t3 ON t2.c1 = t3.c2
ORDER BY t1.c1, t2.c1, t3.c1;
