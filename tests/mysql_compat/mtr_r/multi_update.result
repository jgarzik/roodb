CREATE TABLE t1 (p_id int NOT NULL, p_code varchar(20) NOT NULL default '', p_active tinyint NOT NULL default 1, PRIMARY KEY (p_id));
CREATE TABLE t2 (c2_id int NOT NULL, c2_p_id int NOT NULL default 0, c2_note text NOT NULL, c2_active tinyint NOT NULL default 1, PRIMARY KEY (c2_id));
