DROP TABLE IF EXISTS t1, t2;
CREATE TABLE t1 (id int NOT NULL, str char(10));
INSERT INTO t1 VALUES (1, NULL),(2, NULL),(3, 'foo'),(4, 'bar');
EXPLAIN SELECT * FROM t1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	NULL
DROP TABLE t1;
EXPLAIN SELECT 1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	No tables used
CREATE TABLE t1 (a int NOT NULL);
EXPLAIN SELECT count(*) FROM t1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using temporary
INSERT INTO t1 VALUES (1);
EXPLAIN SELECT count(*) FROM t1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using temporary
DROP TABLE t1;
CREATE TABLE t1 (f1 int, f2 int);
INSERT INTO t1 VALUES (1,1);
EXPLAIN SELECT * FROM t1 WHERE f1 = 1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	10.00	Using where
DROP TABLE t1;
CREATE TABLE t1 (a int);
CREATE TABLE t2 (a int);
INSERT INTO t1 VALUES (1),(2);
INSERT INTO t2 VALUES (1),(2);
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.a;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	NULL
1	SIMPLE	t2	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	NULL
DROP TABLE t1, t2;
CREATE TABLE t1 (f1 int);
CREATE TABLE t2 (f2 int);
INSERT INTO t1 VALUES (1);
INSERT INTO t2 VALUES (1),(2);
EXPLAIN SELECT * FROM t1 WHERE f1 = 1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	10.00	Using where
EXPLAIN SELECT * FROM t1 JOIN t2 ON f1 = f2 WHERE f1 = 1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using where
1	SIMPLE	t2	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using where
DROP TABLE t1, t2;
CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (1),(2),(3);
EXPLAIN SELECT a FROM t1 UNION SELECT a+10 FROM t1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	NULL
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	NULL
DROP TABLE t1;
CREATE TABLE t1 (a int, b varchar(20));
INSERT INTO t1 VALUES (3,'c'),(1,'a'),(2,'b');
EXPLAIN SELECT * FROM t1 ORDER BY a LIMIT 2;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using filesort
DROP TABLE t1;
CREATE TABLE t1 (a int, b int);
INSERT INTO t1 VALUES (1,10),(1,20),(2,30),(2,40);
EXPLAIN SELECT a, SUM(b) FROM t1 GROUP BY a;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
1	SIMPLE	t1	NULL	ALL	NULL	NULL	NULL	NULL	1000	100.00	Using temporary
DROP TABLE t1;
CREATE TABLE t1 (a int, b int);
INSERT INTO t1 VALUES (1,1),(1,2),(2,3);
EXPLAIN SELECT DISTINCT a FROM t1;
id	select_type	table	partitions	type	possible_keys	key	key_len	ref	rows	filtered	Extra
