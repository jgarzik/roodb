# --- Multiple scalar subqueries in SELECT + WHERE ---
SELECT e.name,
(SELECT MAX(salary) FROM employees) AS max_sal,
(SELECT MIN(salary) FROM employees) AS min_sal,
e.salary
FROM employees e
WHERE e.salary > (SELECT AVG(salary) FROM employees)
ORDER BY e.id;
name	max_sal	min_sal	salary
Alice	120000.00	55000.00	120000.00
Bob	120000.00	55000.00	95000.00
Charlie	120000.00	55000.00	105000.00
Frank	120000.00	55000.00	90000.00
Grace	120000.00	55000.00	85000.00
# --- Cleanup ---
DROP TABLE tasks, salaries, employees, departments;
