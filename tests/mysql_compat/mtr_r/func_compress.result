# COMPRESS / UNCOMPRESS / UNCOMPRESSED_LENGTH
# --- Round-trip ---
SELECT UNCOMPRESS(COMPRESS('Hello'));
UNCOMPRESS(COMPRESS('Hello'))
Hello
SELECT UNCOMPRESS(COMPRESS(''));
UNCOMPRESS(COMPRESS(''))
NULL
SELECT UNCOMPRESS(COMPRESS('The quick brown fox jumps over the lazy dog'));
UNCOMPRESS(COMPRESS('The quick brown fox jumps over the lazy dog'))
The quick brown fox jumps over the lazy dog
# --- UNCOMPRESSED_LENGTH ---
SELECT UNCOMPRESSED_LENGTH(COMPRESS('Hello')) = 5;
UNCOMPRESSED_LENGTH(COMPRESS('Hello')) = 5
1
SELECT UNCOMPRESSED_LENGTH(COMPRESS('test')) = 4;
UNCOMPRESSED_LENGTH(COMPRESS('test')) = 4
1
# --- COMPRESS produces shorter output for repeated data ---
SELECT LENGTH(COMPRESS(REPEAT('a', 100))) < 100;
LENGTH(COMPRESS(REPEAT('a',100))) < 100
1
# --- NULL handling ---
SELECT COMPRESS(NULL) IS NULL;
COMPRESS(NULL) IS NULL
1
SELECT UNCOMPRESS(NULL) IS NULL;
UNCOMPRESS(NULL) IS NULL
1
SELECT UNCOMPRESSED_LENGTH(NULL) IS NULL;
UNCOMPRESSED_LENGTH(NULL) IS NULL
1
