drop table if exists t1, t2;
CREATE TABLE t1 (id int NOT NULL PRIMARY KEY, name varchar(20), INDEX (name));
CREATE TABLE t2 (id int NOT NULL PRIMARY KEY, fkey int);
INSERT INTO t1 VALUES (1,'A1'),(2,'A2'),(3,'B');
INSERT INTO t2 VALUES (1,1),(2,2),(3,2),(4,3),(5,3);
SELECT COUNT(*) FROM t2 LEFT JOIN t1 ON t2.fkey = t1.id
WHERE t1.name LIKE 'A%';
COUNT(NULL)
3
SELECT COUNT(*) FROM t2 LEFT JOIN t1 ON t2.fkey = t1.id
WHERE t1.name LIKE 'A%' OR FALSE;
COUNT(NULL)
3
DROP TABLE t1,t2;
CREATE TABLE t1 (
col_int INT,
col_int_key INT,
pk INT NOT NULL,
PRIMARY KEY (pk),
KEY col_int_key (col_int_key)
);
INSERT INTO t1 VALUES (NULL,1,1), (6,2,2), (5,3,3), (NULL,4,4);
INSERT INTO t1 VALUES (1,NULL,6), (8,5,7), (NULL,8,8), (8,NULL,5);
CREATE TABLE t2 (pk INT PRIMARY KEY);
SELECT t1.pk
FROM t2 LEFT JOIN t1 ON t2.pk = t1.col_int
ORDER BY t1.pk;
pk
DROP TABLE t1,t2;
CREATE TABLE t1 (c1 INT, c2 INT, c3 INT, PRIMARY KEY (c1,c2));
CREATE TABLE t2 (c1 INT, c2 INT, c3 INT, PRIMARY KEY (c1), KEY (c2));
INSERT INTO t1 VALUES (1,2,3),(2,3,4),(3,4,5);
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t1 LEFT JOIN t2 ON t1.c2=t2.c2 AND t2.c1=1 ORDER BY t1.c1;
c1	c2	c3	c1	c2	c3
1	2	3	1	2	3
2	3	4	NULL	NULL	NULL
3	4	5	NULL	NULL	NULL
SELECT * FROM t1 LEFT JOIN t2 ON t1.c1 = t2.c2 AND t2.c1 = 3 ORDER BY t1.c1;
c1	c2	c3	c1	c2	c3
1	2	3	NULL	NULL	NULL
2	3	4	NULL	NULL	NULL
3	4	5	NULL	NULL	NULL
DROP TABLE t1,t2;
CREATE TABLE t1 (id INT PRIMARY KEY, grp INT, val INT);
INSERT INTO t1 VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);
CREATE TABLE t2 (id INT PRIMARY KEY, label VARCHAR(10));
INSERT INTO t2 VALUES (1, 'group1'), (2, 'group2'), (3, 'group3');
SELECT t2.label, SUM(t1.val) as total
FROM t2 LEFT JOIN t1 ON t2.id = t1.grp
GROUP BY t2.label
ORDER BY t2.label;
label	total
group1	30
group2	30
group3	NULL
DROP TABLE t1, t2;
