# RANDOM_BYTES and AES_ENCRYPT/AES_DECRYPT
# --- RANDOM_BYTES ---
SELECT LENGTH(HEX(RANDOM_BYTES(16))) = 32;
LENGTH(HEX(RANDOM_BYTES(16))) = 32
1
SELECT LENGTH(HEX(RANDOM_BYTES(1))) = 2;
LENGTH(HEX(RANDOM_BYTES(1))) = 2
1
SELECT LENGTH(HEX(RANDOM_BYTES(32))) = 64;
LENGTH(HEX(RANDOM_BYTES(32))) = 64
1
SELECT RANDOM_BYTES(NULL) IS NULL;
RANDOM_BYTES(NULL) IS NULL
1
# --- AES_ENCRYPT / AES_DECRYPT round-trip ---
SELECT AES_DECRYPT(AES_ENCRYPT('hello', 'secret'), 'secret');
AES_DECRYPT(AES_ENCRYPT('hello','secret'),'secret')
hello
SELECT AES_DECRYPT(AES_ENCRYPT('', 'key'), 'key');
AES_DECRYPT(AES_ENCRYPT('','key'),'key')

SELECT AES_DECRYPT(AES_ENCRYPT('test data 12345', 'mykey'), 'mykey');
AES_DECRYPT(AES_ENCRYPT('test data 12345','mykey'),'mykey')
test data 12345
# --- AES with NULL ---
SELECT AES_ENCRYPT(NULL, 'key') IS NULL;
AES_ENCRYPT(NULL,'key') IS NULL
1
SELECT AES_DECRYPT(NULL, 'key') IS NULL;
AES_DECRYPT(NULL,'key') IS NULL
1
SELECT AES_ENCRYPT('hello', NULL) IS NULL;
AES_ENCRYPT('hello',NULL) IS NULL
1
# --- AES wrong key returns NULL ---
SELECT AES_DECRYPT(AES_ENCRYPT('hello', 'key1'), 'key2') IS NULL;
AES_DECRYPT(AES_ENCRYPT('hello','key1'),'key2') IS NULL
1
