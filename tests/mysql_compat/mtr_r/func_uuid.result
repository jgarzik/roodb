# UUID, UUID_SHORT, BENCHMARK
# --- UUID format ---
SELECT LENGTH(UUID()) = 36;
LENGTH(UUID()) = 36
1
SELECT UUID() <> UUID();
UUID() <> UUID()
1
# --- UUID_SHORT ---
SELECT UUID_SHORT() IS NOT NULL;
UUID_SHORT() IS NOT NULL
1
# --- BENCHMARK ---
SELECT BENCHMARK(1, 1+1);
BENCHMARK(1,1 + 1)
0
SELECT BENCHMARK(100, 1+1);
BENCHMARK(100,1 + 1)
0
