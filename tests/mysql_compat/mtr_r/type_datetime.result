CREATE TABLE t1 (id int NOT NULL, cur_date datetime NOT NULL);
CREATE TABLE t2 (id int NOT NULL, cur_date date NOT NULL);
INSERT INTO t1 (id, cur_date) VALUES (1, '2007-04-25 18:30:22');
INSERT INTO t2 (id, cur_date) VALUES (1, '2007-04-25');
SELECT * FROM t1 WHERE cur_date IS NULL;
id	cur_date
SELECT * FROM t2 WHERE cur_date IS NULL;
id	cur_date
INSERT INTO t1 (id, cur_date) VALUES (2, '2007-04-26 18:30:22');
INSERT INTO t2 (id, cur_date) VALUES (2, '2007-04-26');
SELECT * FROM t1 WHERE cur_date IS NULL;
id	cur_date
SELECT * FROM t2 WHERE cur_date IS NULL;
id	cur_date
SELECT * FROM t1 ORDER BY id;
id	cur_date
1	2007-04-25 18:30:22
2	2007-04-26 18:30:22
SELECT * FROM t2 ORDER BY id;
id	cur_date
1	2007-04-25
2	2007-04-26
DROP TABLE t1,t2;
SELECT
CAST('NULL' AS DATE) <=> CAST('2008-01-01' AS DATE) AS n1,
CAST('2008-01-01' AS DATE) <=> CAST('NULL' AS DATE) AS n2,
CAST('NULL' AS DATE) <=> CAST('NULL' AS DATE) AS n3,
CAST('NULL' AS DATE) <> CAST('2008-01-01' AS DATE) AS n4,
CAST('2008-01-01' AS DATE) <> CAST('NULL' AS DATE) AS n5,
CAST('NULL' AS DATE) <> CAST('NULL' AS DATE) AS n6,
CAST('NULL' AS DATE) < CAST('2008-01-01' AS DATE) AS n7,
CAST('2008-01-01' AS DATE) < CAST('NULL' AS DATE) AS n8,
CAST('NULL' AS DATE) < CAST('NULL' AS DATE) AS n9;
n1	n2	n3	n4	n5	n6	n7	n8	n9
0	0	1	1	1	0	0	1	0
