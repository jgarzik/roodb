SELECT LEAST(CAST('2001-01-01' AS DATE), '2001-01-02');
LEAST(CAST('2001-01-01' AS DATETIME),'2001-01-02')
2001-01-01
SELECT GREATEST(CAST('2001-01-01' AS DATE), '2001-01-02');
GREATEST(CAST('2001-01-01' AS DATETIME),'2001-01-02')
2001-01-02
SELECT LEAST(CAST('2001-01-01' AS DATE), '2001-01-02') + 0;
LEAST(CAST('2001-01-01' AS DATETIME),'2001-01-02') + 0
2001
SELECT GREATEST(CAST('2001-01-01' AS DATE), '2001-01-02') + 0;
GREATEST(CAST('2001-01-01' AS DATETIME),'2001-01-02') + 0
2001
SELECT LEAST(CAST('2001-01-01' AS DATETIME), '2001-01-02') + 0;
LEAST(CAST('2001-01-01' AS DATETIME),'2001-01-02') + 0
2001
