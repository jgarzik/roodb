COALESCE(f1,f1)
2001-01-01
SELECT COALESCE(f1,f2) FROM t1;
COALESCE(f1,f2)
2001-01-01
SELECT COALESCE(f2,f2) FROM t1;
COALESCE(f2,f2)
2001-01-01 12:00:00
SELECT COALESCE(f1,f3) FROM t1;
COALESCE(f1,f3)
2001-01-01
SELECT COALESCE(f2,f3) FROM t1;
COALESCE(f2,f3)
2001-01-01 12:00:00
