'hello' LIKE 'hello'
1
SELECT 'hello' LIKE 'HELLO';
'hello' LIKE 'HELLO'
0
SELECT 'hello' LIKE 'h%';
'hello' LIKE 'h%'
1
SELECT 'hello' LIKE '%lo';
'hello' LIKE '%lo'
1
SELECT 'hello' LIKE '%ell%';
'hello' LIKE '%ell%'
1
SELECT 'hello' LIKE 'h_llo';
'hello' LIKE 'h_llo'
1
SELECT 'hello' LIKE '____o';
'hello' LIKE '____o'
1
SELECT LEFT('hello', 3);
LEFT('hello',3)
hel
SELECT RIGHT('hello', 3);
RIGHT('hello',3)
llo
SELECT SUBSTRING('hello', 2, 3);
SUBSTRING('hello',2,3)
ell
SELECT SUBSTRING('hello', 2);
SUBSTRING('hello',2)
ello
