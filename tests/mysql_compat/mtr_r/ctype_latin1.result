HEX('ABC')
414243
SELECT HEX(65);
HEX(65)
41
SELECT HEX(255);
HEX(255)
FF
SELECT HEX(256);
HEX(256)
100
SELECT CONCAT('hello', ' ', 'world');
CONCAT('hello',' ','world')
hello world
SELECT CONCAT('A', 'B', 'C', 'D');
CONCAT('A','B','C','D')
ABCD
SELECT LENGTH('hello');
LENGTH('hello')
5
SELECT LENGTH('');
LENGTH('')
0
SELECT LENGTH(NULL);
LENGTH(NULL)
NULL
SELECT 'a' = 'A';
'a' = 'A'
0
SELECT 'a' < 'b';
'a' < 'b'
1
SELECT 'z' > 'a';
'z' > 'a'
1
SELECT 'abc' = 'ABC';
'abc' = 'ABC'
0
