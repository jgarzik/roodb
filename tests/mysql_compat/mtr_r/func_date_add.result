SELECT DATE_ADD('2000-01-01', INTERVAL 10 DAY);
DATE_ADD('2000-01-01',__INTERVAL(10,'DAY'))
2000-01-11
SELECT DATE_ADD('2000-01-15', INTERVAL 3 MONTH);
DATE_ADD('2000-01-15',__INTERVAL(3,'MONTH'))
2000-04-15
SELECT DATE_SUB('2000-06-15', INTERVAL 100 DAY);
DATE_SUB('2000-06-15',__INTERVAL(100,'DAY'))
2000-03-07
SELECT DATE_ADD(NULL, INTERVAL 1 DAY);
DATE_ADD(NULL,__INTERVAL(1,'DAY'))
NULL
SELECT DATE_ADD('2000-01-04', INTERVAL NULL DAY);
DATE_ADD('2000-01-04',__INTERVAL(NULL,'DAY'))
NULL
create table t1 (a int, b varchar(10));
insert into t1 values (1, '2001-01-01'),(2, '2002-02-02');
select DATE_ADD('2007-01-01', INTERVAL a DAY) from t1;
DATE_ADD('2007-01-01',__INTERVAL(a,'DAY'))
2007-01-02
2007-01-03
select DATE_ADD(b, INTERVAL a DAY) from t1;
DATE_ADD(b,__INTERVAL(a,'DAY'))
2001-01-02
2002-02-04
drop table t1;
