SELECT ADDDATE(DATE'2021-01-01', INTERVAL 1 DAY);
ADDDATE('2021-01-01',__INTERVAL(1,'DAY'))
2021-01-02
SELECT ADDDATE(DATE'2021-01-01', INTERVAL 1 HOUR);
ADDDATE('2021-01-01',__INTERVAL(1,'HOUR'))
2021-01-01 01:00:00
SELECT ADDDATE(TIMESTAMP'2021-01-01 00:00:00', INTERVAL 1 DAY);
ADDDATE('2021-01-01 00:00:00',__INTERVAL(1,'DAY'))
2021-01-02 00:00:00
SELECT ADDDATE(TIMESTAMP'2021-01-01 00:00:00', INTERVAL 1 HOUR);
ADDDATE('2021-01-01 00:00:00',__INTERVAL(1,'HOUR'))
2021-01-01 01:00:00
