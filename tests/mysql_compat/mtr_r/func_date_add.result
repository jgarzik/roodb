2021-01-01 01:00:00
SELECT DATE_ADD('2000-01-01', INTERVAL 1 DAY);
DATE_ADD('2000-01-01',__INTERVAL(1,'DAY'))
2000-01-02
SELECT DATE_ADD('2000-01-01', INTERVAL 1 MONTH);
DATE_ADD('2000-01-01',__INTERVAL(1,'MONTH'))
2000-02-01
SELECT DATE_ADD('2000-01-01', INTERVAL 1 YEAR);
DATE_ADD('2000-01-01',__INTERVAL(1,'YEAR'))
2001-01-01
SELECT DATE_SUB('2000-01-01', INTERVAL 1 DAY);
DATE_SUB('2000-01-01',__INTERVAL(1,'DAY'))
1999-12-31
SELECT DATE_SUB('2000-01-01', INTERVAL 1 MONTH);
DATE_SUB('2000-01-01',__INTERVAL(1,'MONTH'))
1999-12-01
SELECT DATE_SUB('2000-01-01', INTERVAL 1 YEAR);
DATE_SUB('2000-01-01',__INTERVAL(1,'YEAR'))
1999-01-01
SELECT DATE_ADD('2006-09-26', INTERVAL 1 WEEK);
DATE_ADD('2006-09-26',__INTERVAL(1,'WEEK'))
