SELECT 2 + 3 * 4;
2 + 3 * 4
14
SELECT (2 + 3) * 4;
2 + 3 * 4
20
SELECT 10 - 2 - 3;
10 - 2 - 3
5
SELECT 10 - (2 - 3);
10 - 2 - 3
11
SELECT 2 * 3 + 4 * 5;
2 * 3 + 4 * 5
26
SELECT 100 / 10 / 2;
100 / 10 / 2
5
SELECT 100 / (10 / 2);
100 / 10 / 2
