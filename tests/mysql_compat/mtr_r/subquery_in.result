DROP TABLE IF EXISTS t1, t2, t3, t4;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val INT NOT NULL);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);
CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, ref_val INT NOT NULL);
INSERT INTO t2 VALUES (1, 10), (2, 30), (3, 50);
CREATE TABLE t3 (id INT NOT NULL PRIMARY KEY, ref_val INT);
INSERT INTO t3 VALUES (1, 10), (2, NULL), (3, 30), (4, NULL);
# --- Basic IN subquery ---
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t2) ORDER BY id;
id	val
1	10
3	30
5	50
SELECT id, val FROM t1 WHERE id IN (SELECT id FROM t2) ORDER BY id;
id	val
1	10
2	20
3	30
# --- Basic NOT IN subquery ---
SELECT id, val FROM t1 WHERE val NOT IN (SELECT ref_val FROM t2) ORDER BY id;
id	val
2	20
4	40
SELECT id, val FROM t1 WHERE id NOT IN (SELECT id FROM t2) ORDER BY id;
id	val
4	40
5	50
# --- IN subquery with empty result ---
CREATE TABLE t_empty (a INT NOT NULL PRIMARY KEY);
SELECT id, val FROM t1 WHERE val IN (SELECT a FROM t_empty) ORDER BY id;
id	val
SELECT id, val FROM t1 WHERE val NOT IN (SELECT a FROM t_empty) ORDER BY id;
id	val
1	10
2	20
3	30
4	40
5	50
DROP TABLE t_empty;
# --- IN subquery with single value ---
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t2 WHERE id = 1) ORDER BY id;
id	val
1	10
SELECT id, val FROM t1 WHERE val NOT IN (SELECT ref_val FROM t2 WHERE id = 1) ORDER BY id;
id	val
2	20
3	30
4	40
5	50
# --- IN with NULLs in subquery result ---
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t3) ORDER BY id;
id	val
1	10
3	30
SELECT id, val FROM t1 WHERE val NOT IN (SELECT ref_val FROM t3) ORDER BY id;
id	val
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t3 WHERE ref_val IS NOT NULL) ORDER BY id;
id	val
1	10
3	30
SELECT id, val FROM t1 WHERE val NOT IN (SELECT ref_val FROM t3 WHERE ref_val IS NOT NULL) ORDER BY id;
id	val
2	20
4	40
5	50
# --- IN subquery with duplicates ---
CREATE TABLE t4 (id INT NOT NULL PRIMARY KEY, ref_val INT NOT NULL);
INSERT INTO t4 VALUES (1, 10), (2, 10), (3, 30), (4, 30), (5, 50);
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t4) ORDER BY id;
id	val
1	10
3	30
5	50
DROP TABLE t4;
# --- IN subquery with expressions ---
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val * 2 FROM t2) ORDER BY id;
id	val
2	20
SELECT id, val FROM t1 WHERE val + 10 IN (SELECT ref_val FROM t2) ORDER BY id;
id	val
2	20
4	40
SELECT id, val FROM t1 WHERE val IN (SELECT MAX(ref_val) FROM t2) ORDER BY id;
id	val
5	50
# --- IN subquery with multiple columns in outer WHERE ---
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t2) AND id > 1 ORDER BY id;
id	val
3	30
5	50
SELECT id, val FROM t1 WHERE val IN (SELECT ref_val FROM t2) OR id = 4 ORDER BY id;
id	val
1	10
3	30
4	40
5	50
# --- IN subquery in SELECT list ---
SELECT id, val, val IN (SELECT ref_val FROM t2) AS is_matched FROM t1 ORDER BY id;
id	val	is_matched
1	10	1
2	20	0
3	30	1
4	40	0
5	50	1
SELECT id, val, val NOT IN (SELECT ref_val FROM t2) AS not_matched FROM t1 ORDER BY id;
id	val	not_matched
1	10	0
2	20	1
3	30	0
4	40	1
5	50	0
# --- IN subquery with different types ---
CREATE TABLE t_str (id INT NOT NULL PRIMARY KEY, sval VARCHAR(10));
INSERT INTO t_str VALUES (1, '10'), (2, '20'), (3, '30');
SELECT id, sval FROM t_str WHERE sval IN (SELECT ref_val FROM t2) ORDER BY id;
id	sval
DROP TABLE t_str;
CREATE TABLE t_dec (id INT NOT NULL PRIMARY KEY, dval DECIMAL(10,2));
INSERT INTO t_dec VALUES (1, 10.00), (2, 20.00), (3, 30.00);
SELECT id, dval FROM t_dec WHERE dval IN (SELECT ref_val FROM t2) ORDER BY id;
id	dval
1	10.00
3	30.00
DROP TABLE t_dec;
# --- Multiple IN subqueries ---
SELECT id, val FROM t1
WHERE val IN (SELECT ref_val FROM t2)
AND id IN (SELECT id FROM t3)
ORDER BY id;
id	val
1	10
3	30
# --- IN subquery with DISTINCT ---
SELECT id, val FROM t1 WHERE val IN (SELECT DISTINCT ref_val FROM t3 WHERE ref_val IS NOT NULL) ORDER BY id;
id	val
1	10
3	30
# --- Cleanup ---
DROP TABLE t1, t2, t3;
