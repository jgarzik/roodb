#
# Checking Item_func_if with TIME arguments
#
SELECT CAST(IF(1, TIME'00:00:00', TIME'00:00:00') AS CHAR);
CAST(IF(1,'00:00:00','00:00:00') AS CHAR(1))
00:00:00
#
# Checking CASE with TIME arguments
#
SELECT CAST(CASE WHEN 1 THEN TIME'00:00:00' ELSE TIME'00:00:00' END AS CHAR);
CAST(CASE AS CHAR(1))
00:00:00
