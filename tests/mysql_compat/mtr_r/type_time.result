INSERT INTO t1 VALUES('2007-07-01', 2);
INSERT INTO t1 VALUES('2007-07-02', 1);
INSERT INTO t1 VALUES('2007-07-02', 2);
SELECT SUM(f3) FROM t1 WHERE f2='2007-07-01 00:00:00' GROUP BY f2;
SUM(f3)
