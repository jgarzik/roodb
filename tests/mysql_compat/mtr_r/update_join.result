# UPDATE with JOIN tests
# --- Basic UPDATE JOIN ---
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
CREATE TABLE t2 (a INT, c INT);
INSERT INTO t2 VALUES (1, 100), (2, 200);
UPDATE t1 JOIN t2 ON t1.a = t2.a SET t1.b = 99;
SELECT * FROM t1 ORDER BY a;
a	b
1	99
2	99
3	30
DROP TABLE t1, t2;
# --- UPDATE JOIN: no matches leaves rows unchanged ---
CREATE TABLE t1 (id INT PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, 10), (2, 20);
CREATE TABLE t2 (id INT);
INSERT INTO t2 VALUES (10);
UPDATE t1 JOIN t2 ON t1.id = t2.id SET t1.val = 99;
SELECT * FROM t1 ORDER BY id;
id	val
1	10
2	20
DROP TABLE t1, t2;
# --- UPDATE JOIN: all match ---
CREATE TABLE t1 (x INT PRIMARY KEY, y INT);
INSERT INTO t1 VALUES (1, 10), (2, 20);
CREATE TABLE t2 (x INT);
INSERT INTO t2 VALUES (1), (2);
UPDATE t1 JOIN t2 ON t1.x = t2.x SET t1.y = t1.y + 100;
SELECT * FROM t1 ORDER BY x;
x	y
1	110
2	120
DROP TABLE t1, t2;
