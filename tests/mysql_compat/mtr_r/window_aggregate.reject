# Window functions over aggregate expressions
CREATE TABLE t1 (dept INT, emp VARCHAR(10), sal INT);
INSERT INTO t1 VALUES (1, 'a', 100), (1, 'b', 200), (2, 'c', 300), (2, 'd', 150);
# --- ROW_NUMBER ordered by SUM(sal) DESC ---
SELECT dept, SUM(sal) as total, ROW_NUMBER() OVER (ORDER BY SUM(sal) DESC) as rnk FROM t1 GROUP BY dept;
dept	total	rnk
2	450	1
1	300	2
# --- RANK ordered by COUNT(*) ---
SELECT dept, COUNT(*) as cnt, RANK() OVER (ORDER BY COUNT(*) DESC) as rnk FROM t1 GROUP BY dept;
dept	cnt	rnk
2	2	1
1	2	1
# --- Window ORDER BY group-by column ---
SELECT dept, SUM(sal) as total, ROW_NUMBER() OVER (ORDER BY dept) as rnk FROM t1 GROUP BY dept;
dept	total	rnk
1	300	1
2	450	2
DROP TABLE t1;
