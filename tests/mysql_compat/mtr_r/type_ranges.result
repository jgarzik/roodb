30	test	1	3	3	3	3	3	3	3	3	3	2024-03-03	10:10:10	2024-03-03 10:10:10	blob3
update t1 set string='updated' where id=10;
select id,string from t1 where id=10;
id	string
10	updated
delete from t1 where id=40;
select count(*) from t1;
COUNT(NULL)
3
drop table t1;
CREATE TABLE t1 (
a tinyint,
b smallint,
c int,
d bigint,
e tinyint unsigned,
f smallint unsigned,
g int unsigned,
h bigint unsigned
);
INSERT INTO t1 VALUES (-128, -32768, -2147483648, -9223372036854775808, 0, 0, 0, 0);
INSERT INTO t1 VALUES (127, 32767, 2147483647, 9223372036854775807, 255, 65535, 4294967295, 18446744073709551615);
