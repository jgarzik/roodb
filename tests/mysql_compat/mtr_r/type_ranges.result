127	32767	2147483647	9223372036854775807	255	65535	4294967295	18446744073709551615
DROP TABLE t1;
create table t1 (id int, val varchar(10));
create table t2 (id int, val varchar(10));
insert into t1 values (1, 'a'), (2, 'b'), (3, 'c');
insert into t2 values (1, 'x'), (3, 'z');
select t1.id, t1.val, t2.val from t1 left join t2 on t1.id = t2.id order by t1.id;
id	val	val
1	a	x
2	b	NULL
3	c	z
drop table t1, t2;
