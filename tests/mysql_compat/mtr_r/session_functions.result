# Session state functions
# --- CONNECTION_ID ---
SELECT CONNECTION_ID() > 0;
CONNECTION_ID() > 0
1
# --- USER / CURRENT_USER ---
SELECT USER() IS NOT NULL;
USER() IS NOT NULL
1
SELECT CURRENT_USER() IS NOT NULL;
CURRENT_USER() IS NOT NULL
1
SELECT SESSION_USER() IS NOT NULL;
SESSION_USER() IS NOT NULL
1
SELECT SYSTEM_USER() IS NOT NULL;
SYSTEM_USER() IS NOT NULL
1
# --- DATABASE / SCHEMA ---
SELECT DATABASE() IS NOT NULL;
DATABASE()
test
SELECT SCHEMA() IS NOT NULL;
SCHEMA() IS NOT NULL
1
# --- LAST_INSERT_ID ---
CREATE TABLE t1 (id INT AUTO_INCREMENT PRIMARY KEY, val INT);
INSERT INTO t1 (val) VALUES (10);
SELECT LAST_INSERT_ID() > 0;
LAST_INSERT_ID() > 0
1
INSERT INTO t1 (val) VALUES (20);
SELECT LAST_INSERT_ID() > 0;
LAST_INSERT_ID() > 0
1
DROP TABLE t1;
# --- ROW_COUNT after INSERT ---
CREATE TABLE t2 (a INT);
INSERT INTO t2 VALUES (1), (2), (3);
SELECT ROW_COUNT();
ROW_COUNT()
3
DROP TABLE t2;
# --- FOUND_ROWS after SELECT ---
CREATE TABLE t3 (a INT);
INSERT INTO t3 VALUES (1), (2), (3), (4), (5);
SELECT * FROM t3;
a
1
2
3
4
5
SELECT FOUND_ROWS();
FOUND_ROWS()
5
DROP TABLE t3;
# --- LAST_INSERT_ID(expr) sets the value ---
SELECT LAST_INSERT_ID(42);
LAST_INSERT_ID(42)
42
SELECT LAST_INSERT_ID();
LAST_INSERT_ID()
42
