#
# SHOW CREATE PROCEDURE on dropped procedure — should error
#
SHOW CREATE PROCEDURE p2;
ERROR HY000: PROCEDURE p2 does not exist
#
# Cleanup
#
DROP PROCEDURE p1;
DROP PROCEDURE p3;
SHOW PROCEDURE STATUS;
