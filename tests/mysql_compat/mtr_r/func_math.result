select (round(-9223372036854775808, -4));
ERROR 22003: BIGINT value is out of range
# Bug#31128028 ROUND and TRUNCATE sometimes produce wrong result types
CREATE TABLE t1(a INTEGER, b INTEGER);
INSERT INTO t1 VALUES(11, -1);
CREATE TABLE t2 AS SELECT a, ROUND(a, b) AS c FROM t1;
DESCRIBE t2;
Field	Type	Null	Key	Default	Extra
a	INT	YES		NULL	
c	INT	YES		NULL	
DROP TABLE t1, t2;
SET sql_mode = DEFAULT;
#
# Bug #30156563 TYPE RESOLUTION OF DIV OPERATOR
#               PRODUCES ONE LESS PRECISION.
#
SELECT 5.0 + 96 DIV 1;
5 + 96 DIV 1
101
CREATE TABLE t1 SELECT
5.0 + 96 DIV 1,                     # Dividend is integer
5.0 + 96.1234 DIV 1,                # Dividend is decimal
5.0 + '96' DIV 1,                   # Dividend is string
5.0 + CAST('96' AS SIGNED) DIV 1,   # Dividend is function
5.0 + CAST('96' AS UNSIGNED) DIV 1;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `5 + 96 DIV 1` DOUBLE NOT NULL,
  `5 + 96.1234 DIV 1` DOUBLE NOT NULL,
  `5 + '96' DIV 1` DOUBLE NOT NULL,
  `5 + CAST('96' AS BIGINT) DIV 1` DOUBLE NOT NULL,
  `5 + CAST('96' AS unsigned) DIV 1` DOUBLE NOT NULL
) ENGINE=RooDB DEFAULT CHARSET=utf8mb4
DROP TABLE t1;
#
# Bug #32693863 MINUS BETWEEN CONST VALUE 0 AND FIELD WITH
#               MIN BIGINT VALUE GETS WRONG RESULT
#
CREATE TABLE t1(a BIGINT);
INSERT INTO t1 VALUES (-9223372036854775808);
SELECT a, 0-a FROM t1;
ERROR 22003: BIGINT value is out of range
DELETE FROM t1;
INSERT INTO t1 VALUES (-9223372036854775807);
SELECT a, 1-a FROM t1;
ERROR 22003: BIGINT value is out of range
DROP TABLE t1;
