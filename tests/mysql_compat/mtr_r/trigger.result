DROP TABLE IF EXISTS t1, t2, t3;
CREATE TABLE t1 (a int);
CREATE TABLE t2 (b int);
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (NEW.a * 100);
INSERT INTO t1 VALUES (3);
SELECT * FROM t1;
a
3
SELECT * FROM t2;
b
300
INSERT INTO t1 VALUES (5);
SELECT * FROM t2;
b
300
500
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (a int);
CREATE TABLE t2 (msg varchar(50));
CREATE TRIGGER trg BEFORE INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (CONCAT('inserted: ', NEW.a));
INSERT INTO t1 VALUES (42);
SELECT * FROM t1;
a
42
SELECT * FROM t2;
msg
inserted: 42
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (a int);
CREATE TABLE t2 (counter int);
INSERT INTO t2 VALUES (0);
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW UPDATE t2 SET counter = counter + 1;
INSERT INTO t1 VALUES (1);
INSERT INTO t1 VALUES (2);
INSERT INTO t1 VALUES (3);
SELECT * FROM t1;
a
1
2
3
SELECT * FROM t2;
counter
3
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (a int);
CREATE TABLE t2 (msg varchar(50));
CREATE TABLE t3 (msg varchar(50));
CREATE TRIGGER trg1 BEFORE INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (CONCAT('before: ', NEW.a));
CREATE TRIGGER trg2 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t3 VALUES (CONCAT('after: ', NEW.a));
INSERT INTO t1 VALUES (99);
SELECT * FROM t1;
a
99
SELECT * FROM t2;
msg
before: 99
SELECT * FROM t3;
msg
after: 99
DROP TRIGGER trg1;
DROP TRIGGER trg2;
DROP TABLE t1, t2, t3;
DROP TRIGGER IF EXISTS no_such_trigger;
CREATE TABLE t1 (x int);
CREATE TABLE t2 (y int);
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (NEW.x * 10);
INSERT INTO t1 VALUES (1),(2),(3);
SELECT * FROM t1;
x
1
2
3
SELECT * FROM t2;
y
10
20
30
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (id int, name varchar(20));
CREATE TABLE t2 (last_inserted_name varchar(20));
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (NEW.name);
INSERT INTO t1 VALUES (1, 'alice');
INSERT INTO t1 VALUES (2, 'bob');
SELECT * FROM t1;
id	name
1	alice
2	bob
SELECT * FROM t2;
last_inserted_name
alice
bob
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (a int, b int);
CREATE TABLE t2 (sum_val int);
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES (NEW.a + NEW.b);
INSERT INTO t1 VALUES (10, 20);
INSERT INTO t1 VALUES (100, 200);
SELECT * FROM t2;
sum_val
30
300
DROP TRIGGER trg;
DROP TABLE t1, t2;
CREATE TABLE t1 (a int);
SET @trig_val = 0;
CREATE TRIGGER trg BEFORE INSERT ON t1 FOR EACH ROW SET @trig_val = NEW.a;
INSERT INTO t1 VALUES (42);
SELECT @trig_val;
@trig_val
42
INSERT INTO t1 VALUES (99);
SELECT @trig_val;
@trig_val
99
DROP TRIGGER trg;
DROP TABLE t1;
CREATE TABLE t1 (a int);
SET @count = 0;
CREATE TRIGGER trg AFTER INSERT ON t1 FOR EACH ROW SET @count = @count + 1;
INSERT INTO t1 VALUES (1);
INSERT INTO t1 VALUES (2);
INSERT INTO t1 VALUES (3);
SELECT @count;
@count
3
DROP TRIGGER trg;
DROP TABLE t1;
