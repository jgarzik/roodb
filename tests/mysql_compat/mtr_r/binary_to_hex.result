DROP TABLE IF EXISTS t1, t2;
SELECT HEX('abc');
HEX('abc')
616263
SELECT HEX(255);
HEX(255)
FF
SELECT HEX(0);
HEX(0)
0
SELECT HEX(256);
HEX(256)
100
SELECT UNHEX('616263');
UNHEX('616263')
abc
SELECT UNHEX('FF');
UNHEX('FF')
�
SELECT UNHEX(HEX('test string'));
UNHEX(HEX('test string'))
test string
SELECT HEX(UNHEX('48454C4C4F'));
HEX(UNHEX('48454C4C4F'))
48454C4C4F
SELECT HEX(1), HEX(10), HEX(100), HEX(1000);
HEX(1)	HEX(10)	HEX(100)	HEX(1000)
1	A	64	3E8
SELECT HEX(-1);
HEX(-1)
FFFFFFFFFFFFFFFF
SELECT UNHEX('');
UNHEX('')

SELECT UNHEX(NULL);
UNHEX(NULL)
NULL
SELECT HEX(NULL);
HEX(NULL)
NULL
SELECT HEX(UNHEX('DEADBEEF'));
HEX(UNHEX('DEADBEEF'))
DEADEFBFBDEFBFBD
SELECT UNHEX(HEX(12345));
UNHEX(HEX(12345))
09
CREATE TABLE t1 (id INT, val VARCHAR(20));
INSERT INTO t1 VALUES (1, 'hello'), (2, 'world'), (3, 'test');
SELECT id, HEX(val) FROM t1 ORDER BY id;
id	HEX(val)
1	68656C6C6F
2	776F726C64
3	74657374
SELECT id, UNHEX(HEX(val)) FROM t1 ORDER BY id;
id	UNHEX(HEX(val))
1	hello
2	world
3	test
DROP TABLE t1;
CREATE TABLE t2 (id INT, col1 VARCHAR(20));
INSERT INTO t2 VALUES (1, X'AB1234'), (2, X'DE1234');
SELECT id, HEX(col1) FROM t2 ORDER BY id;
id	HEX(col1)
1	3078414231323334
2	3078444531323334
DROP TABLE t2;
SELECT HEX(1 + 1);
HEX(1 + 1)
2
SELECT HEX(ASCII('A'));
HEX(ASCII('A'))
41
