DROP TABLE IF EXISTS products, orders, categories;
CREATE TABLE categories (id INT NOT NULL PRIMARY KEY, name VARCHAR(30));
INSERT INTO categories VALUES (1, 'Electronics'), (2, 'Books'), (3, 'Clothing');
CREATE TABLE products (
id INT NOT NULL PRIMARY KEY,
name VARCHAR(50) NOT NULL,
cat_id INT NOT NULL,
price DECIMAL(10,2) NOT NULL,
stock INT NOT NULL
);
INSERT INTO products VALUES
(1, 'Laptop', 1, 999.99, 10),
(2, 'Phone', 1, 699.50, 25),
(3, 'Novel', 2, 14.99, 100),
(4, 'Textbook', 2, 89.95, 30),
(5, 'Jacket', 3, 149.00, 15),
(6, 'T-Shirt', 3, 29.99, 50),
(7, 'Tablet', 1, 499.00, 20),
(8, 'Biography', 2, 24.99, 45);
CREATE TABLE orders (
id INT NOT NULL PRIMARY KEY,
product_id INT NOT NULL,
qty INT NOT NULL,
order_date DATE NOT NULL
);
INSERT INTO orders VALUES
(1, 1, 2, '2025-01-15'),
(2, 2, 5, '2025-01-20'),
(3, 3, 10, '2025-02-01'),
(4, 5, 3, '2025-02-10'),
(5, 1, 1, '2025-03-01'),
(6, 7, 4, '2025-03-05'),
(7, 6, 8, '2025-03-10'),
(8, 4, 2, '2025-03-15');
# --- CASE with subquery ---
SELECT id, name, price,
CASE
WHEN price > (SELECT AVG(price) FROM products) THEN 'above avg'
        WHEN price = (SELECT AVG(price) FROM products) THEN 'at avg'
        ELSE 'below avg'
    END AS price_tier
FROM products ORDER BY id;
id	name	price	price_tier
1	Laptop	999.99	above avg
2	Phone	699.50	above avg
3	Novel	14.99	below avg
4	Textbook	89.95	below avg
5	Jacket	149.00	below avg
6	T-Shirt	29.99	below avg
7	Tablet	499.00	above avg
8	Biography	24.99	below avg
# --- COALESCE with subquery ---
SELECT COALESCE((SELECT MAX(price) FROM products WHERE cat_id = 99), 0.00) AS missing_cat;
missing_cat
0.00
SELECT COALESCE((SELECT MAX(price) FROM products WHERE cat_id = 1), 0.00) AS electronics_max;
electronics_max
999.99
# --- Arithmetic with subqueries ---
SELECT id, name, price,
price - (SELECT AVG(price) FROM products) AS diff_from_avg,
ROUND(price / (SELECT MAX(price) FROM products) * 100, 1) AS pct_of_max
FROM products ORDER BY id;
id	name	price	diff_from_avg	pct_of_max
1	Laptop	999.99	686.563750000000027	100
2	Phone	699.50	386.073750000000018	70
3	Novel	14.99	-298.436249999999973	1.5
4	Textbook	89.95	-223.476249999999993	9
5	Jacket	149.00	-164.426249999999982	14.9
6	T-Shirt	29.99	-283.436249999999973	3
7	Tablet	499.00	185.573750000000018	49.899999999999999
8	Biography	24.99	-288.436249999999973	2.5
# --- String functions with subquery results ---
SELECT id, name,
CONCAT(name, ' ($', price, ')') AS display,
LENGTH(name) AS name_len
FROM products
WHERE price > (SELECT AVG(price) FROM products)
ORDER BY id;
id	name	display	name_len
1	Laptop	Laptop ($999.99)	6
2	Phone	Phone ($699.50)	5
7	Tablet	Tablet ($499.00)	6
# --- Aggregate over subquery-filtered set ---
SELECT cat_id,
COUNT(*) AS product_count,
SUM(price) AS total_price,
ROUND(AVG(price), 2) AS avg_price
FROM products
WHERE price > (SELECT MIN(price) FROM products)
GROUP BY cat_id
ORDER BY cat_id;
cat_id	product_count	total_price	avg_price
1	3	2198.489999999999782	732.830000000000041
2	2	114.939999999999998	57.469999999999999
3	2	178.990000000000009	89.5
# --- IN subquery with JOIN ---
SELECT p.id, p.name, p.price
FROM products p
WHERE p.id IN (SELECT o.product_id FROM orders o)
ORDER BY p.id;
id	name	price
1	Laptop	999.99
2	Phone	699.50
3	Novel	14.99
4	Textbook	89.95
5	Jacket	149.00
6	T-Shirt	29.99
7	Tablet	499.00
SELECT p.id, p.name, p.price
FROM products p
WHERE p.id NOT IN (SELECT o.product_id FROM orders o)
ORDER BY p.id;
id	name	price
8	Biography	24.99
# --- Subquery in derived table ---
SELECT d.cat_id, c.name AS category, d.cnt, d.avg_price
FROM (
SELECT cat_id, COUNT(*) AS cnt, ROUND(AVG(price), 2) AS avg_price
FROM products
GROUP BY cat_id
) d
JOIN categories c ON d.cat_id = c.id
WHERE d.avg_price > (SELECT AVG(price) FROM products)
ORDER BY d.cat_id;
cat_id	category	cnt	avg_price
1	Electronics	3	732.830000000000041
# --- Complex WHERE combining subqueries ---
SELECT p.id, p.name, p.price, p.stock
FROM products p
WHERE p.price > (SELECT AVG(price) FROM products)
AND p.stock > (SELECT AVG(stock) FROM products)
ORDER BY p.id;
id	name	price	stock
SELECT p.id, p.name, p.price
FROM products p
WHERE p.cat_id IN (SELECT cat_id FROM products GROUP BY cat_id HAVING COUNT(*) >= 3)
AND p.price < (SELECT AVG(price) FROM products)
ORDER BY p.id;
id	name	price
3	Novel	14.99
4	Textbook	89.95
8	Biography	24.99
# --- Nested CASE with multiple subqueries ---
SELECT id, name,
CASE
WHEN price > (SELECT AVG(price) FROM products WHERE cat_id = 1) THEN 'expensive'
        WHEN price > (SELECT AVG(price) FROM products WHERE cat_id = 2) THEN 'moderate'
        ELSE 'affordable'
    END AS tier
FROM products ORDER BY id;
id	name	tier
1	Laptop	expensive
2	Phone	moderate
3	Novel	affordable
4	Textbook	moderate
5	Jacket	moderate
6	T-Shirt	affordable
7	Tablet	moderate
8	Biography	affordable
# --- Subquery with LIMIT in outer query ---
SELECT id, name, price FROM products
WHERE price >= (SELECT AVG(price) FROM products)
ORDER BY price DESC
LIMIT 3;
id	name	price
1	Laptop	999.99
2	Phone	699.50
7	Tablet	499.00
# --- NULL-safe comparisons with subqueries ---
SELECT COALESCE((SELECT SUM(qty) FROM orders WHERE product_id = 999), 0) AS no_orders;
no_orders
0
SELECT (SELECT SUM(qty) FROM orders WHERE qty > 9999) AS none_found;
none_found
NULL
SELECT COALESCE((SELECT SUM(qty) FROM orders WHERE qty > 9999), 0) AS safe_none;
safe_none
0
SELECT p.id, p.name, p.price
FROM products p
WHERE p.id IN (SELECT product_id FROM orders)
ORDER BY p.id;
id	name	price
1	Laptop	999.99
2	Phone	699.50
3	Novel	14.99
4	Textbook	89.95
5	Jacket	149.00
6	T-Shirt	29.99
7	Tablet	499.00
SELECT p.id, p.name, p.price
FROM products p
WHERE p.id NOT IN (SELECT product_id FROM orders)
ORDER BY p.id;
id	name	price
8	Biography	24.99
# --- Cleanup ---
DROP TABLE products, orders, categories;
