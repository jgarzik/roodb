# JSON modification functions
# --- JSON_SET ---
SELECT JSON_SET('{"a": 1}', '$.b', 2);
JSON_SET('{"a": 1}','$.b',2)
{"a":1,"b":2}
SELECT JSON_SET('{"a": 1}', '$.a', 99);
JSON_SET('{"a": 1}','$.a',99)
{"a":99}
SELECT JSON_SET('{"a": 1}', '$.b', JSON_ARRAY(1, 2));
JSON_SET('{"a": 1}','$.b',JSON_ARRAY(1,2))
{"a":1,"b":[1,2]}
# --- JSON_INSERT (only adds, never replaces) ---
SELECT JSON_INSERT('{"a": 1}', '$.b', 2);
JSON_INSERT('{"a": 1}','$.b',2)
{"a":1,"b":2}
SELECT JSON_INSERT('{"a": 1}', '$.a', 99);
JSON_INSERT('{"a": 1}','$.a',99)
{"a":1}
# --- JSON_REPLACE (only replaces, never adds) ---
SELECT JSON_REPLACE('{"a": 1}', '$.a', 99);
JSON_REPLACE('{"a": 1}','$.a',99)
{"a":99}
SELECT JSON_REPLACE('{"a": 1}', '$.b', 2);
JSON_REPLACE('{"a": 1}','$.b',2)
{"a":1}
# --- JSON_REMOVE ---
SELECT JSON_REMOVE('{"a": 1, "b": 2, "c": 3}', '$.b');
JSON_REMOVE('{"a": 1, "b": 2, "c": 3}','$.b')
{"a":1,"c":3}
SELECT JSON_REMOVE('[1, 2, 3]', '$[1]');
JSON_REMOVE('[1, 2, 3]','$[1]')
[1,3]
# --- JSON_ARRAY_APPEND ---
SELECT JSON_ARRAY_APPEND('[1, 2]', '$', 3);
JSON_ARRAY_APPEND('[1, 2]','$',3)
[1,2,3]
SELECT JSON_ARRAY_APPEND('{"a": [1]}', '$.a', 2);
JSON_ARRAY_APPEND('{"a": [1]}','$.a',2)
{"a":[1,2]}
# --- JSON_MERGE_PRESERVE ---
SELECT JSON_MERGE_PRESERVE('{"a": 1}', '{"a": 2, "b": 3}');
JSON_MERGE_PRESERVE('{"a": 1}','{"a": 2, "b": 3}')
{"a":[1,2],"b":3}
SELECT JSON_MERGE_PRESERVE('[1, 2]', '[3, 4]');
JSON_MERGE_PRESERVE('[1, 2]','[3, 4]')
[1,2,3,4]
# --- JSON_MERGE_PATCH ---
SELECT JSON_MERGE_PATCH('{"a": 1, "b": 2}', '{"a": 3, "b": null, "c": 4}');
JSON_MERGE_PATCH('{"a": 1, "b": 2}','{"a": 3, "b": null, "c": 4}')
{"a":3,"c":4}
# --- JSON_CONTAINS ---
SELECT JSON_CONTAINS('{"a": 1, "b": 2}', '{"a": 1}');
JSON_CONTAINS('{"a": 1, "b": 2}','{"a": 1}')
1
SELECT JSON_CONTAINS('{"a": 1}', '{"a": 2}');
JSON_CONTAINS('{"a": 1}','{"a": 2}')
0
SELECT JSON_CONTAINS('[1, 2, 3]', '2');
JSON_CONTAINS('[1, 2, 3]','2')
1
# --- JSON_CONTAINS_PATH ---
SELECT JSON_CONTAINS_PATH('{"a": 1, "b": 2}', 'one', '$.a');
JSON_CONTAINS_PATH('{"a": 1, "b": 2}','one','$.a')
1
SELECT JSON_CONTAINS_PATH('{"a": 1}', 'all', '$.a', '$.b');
JSON_CONTAINS_PATH('{"a": 1}','all','$.a','$.b')
0
# --- JSON_SEARCH ---
SELECT JSON_SEARCH('{"a": "hello", "b": "world"}', 'one', 'hello');
JSON_SEARCH('{"a": "hello", "b": "world"}','one','hello')
"$.a"
SELECT JSON_SEARCH('["abc", "def", "abc"]', 'all', 'abc');
JSON_SEARCH('["abc", "def", "abc"]','all','abc')
["\"$[0]\"","\"$[2]\""]
# --- JSON_OVERLAPS ---
SELECT JSON_OVERLAPS('[1, 2, 3]', '[3, 4, 5]');
JSON_OVERLAPS('[1, 2, 3]','[3, 4, 5]')
1
SELECT JSON_OVERLAPS('[1, 2]', '[3, 4]');
JSON_OVERLAPS('[1, 2]','[3, 4]')
0
# --- JSON_SCHEMA_VALID ---
SELECT JSON_SCHEMA_VALID('{"type": "object"}', '{"a": 1}');
JSON_SCHEMA_VALID('{"type": "object"}','{"a": 1}')
1
SELECT JSON_SCHEMA_VALID('{"type": "array"}', '{"a": 1}');
JSON_SCHEMA_VALID('{"type": "array"}','{"a": 1}')
0
SELECT JSON_SCHEMA_VALID('{"type": "string"}', '"hello"');
JSON_SCHEMA_VALID('{"type": "string"}','"hello"')
1
