# Multi-way UNION tests (3+ operands)
# --- 3-way UNION ALL ---
SELECT 1 AS a UNION ALL SELECT 2 UNION ALL SELECT 3;
a
1
2
3
# --- 3-way UNION DISTINCT ---
SELECT 1 AS a UNION SELECT 1 UNION SELECT 2;
a
1
2
# --- 4-way UNION ALL ---
SELECT 'a' AS v UNION ALL SELECT 'b' UNION ALL SELECT 'c' UNION ALL SELECT 'd';
v
a
b
c
d
# --- 5-way UNION ALL ---
SELECT 10 AS n UNION ALL SELECT 20 UNION ALL SELECT 30 UNION ALL SELECT 40 UNION ALL SELECT 50;
n
10
20
30
40
50
# --- UNION ALL with table ---
CREATE TABLE t1 (x INT);
INSERT INTO t1 VALUES (100), (200);
SELECT x FROM t1 UNION ALL SELECT 300 UNION ALL SELECT 400;
x
100
200
300
400
DROP TABLE t1;
# --- Mixed UNION ALL and UNION DISTINCT in chain ---
SELECT 1 AS a UNION ALL SELECT 2 UNION SELECT 2;
a
1
2
2
