CREATE TABLE t1 (id INT, flags INT);
INSERT INTO t1 VALUES (1, 0x01), (2, 0x02), (3, 0x03), (4, 0x04), (5, 0x07), (6, 0x00);
SELECT id, flags FROM t1 WHERE flags & 0x01;
id	flags
1	1
3	3
5	7
SELECT id, flags FROM t1 WHERE flags & 0x02;
id	flags
2	2
3	3
5	7
SELECT id, flags FROM t1 WHERE flags & 0x04;
id	flags
4	4
5	7
SELECT id, flags FROM t1 WHERE (flags & 0x03) = 0x03;
id	flags
3	3
5	7
SELECT id, flags FROM t1 WHERE flags | 0x01 = 0x01;
id	flags
1	1
6	0
DROP TABLE t1;
CREATE TABLE t1 (a BIT(8), b BIT(8));
INSERT INTO t1 VALUES (0xFF, 0x0F), (0xF0, 0x0F), (0xAA, 0x55);
SELECT HEX(a), HEX(b), a+0 & b+0, a+0 | b+0, a+0 ^ b+0 FROM t1;
HEX(a)	HEX(b)	a + 0 & b + 0	a + 0 | b + 0	a + 0 ^ b + 0
FF	F	15	255	240
F0	F	0	255	255
AA	55	0	255	255
SELECT HEX(a), BIT_COUNT(a+0) FROM t1;
HEX(a)	BIT_COUNT(a + 0)
FF	8
F0	4
AA	4
DROP TABLE t1;
