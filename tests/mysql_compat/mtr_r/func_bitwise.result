CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (0xFF, 0x0F), (0xF0, 0x0F), (123, 456), (0, 0), (0xFFFF, 0xFF00);
SELECT a, b, a & b, a | b, a ^ b FROM t1;
a	b	a & b	a | b	a ^ b
255	15	15	255	240
240	15	0	255	255
123	456	72	507	435
0	0	0	0	0
65535	65280	65280	65535	255
SELECT a, ~a FROM t1;
a	~a
255	-256
240	-241
123	-124
0	-1
65535	-65536
SELECT a, a << 4, a >> 4 FROM t1;
a	a << 4	a >> 4
255	4080	15
240	3840	15
123	1968	7
0	0	0
65535	1048560	4095
SELECT a, BIT_COUNT(a) FROM t1;
a	BIT_COUNT(a)
255	8
240	4
123	6
0	0
65535	16
DROP TABLE t1;
