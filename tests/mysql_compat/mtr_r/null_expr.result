SELECT a FROM t1 WHERE a IN (1, 3, NULL) ORDER BY a;
a
1
3
SELECT a FROM t1 WHERE a NOT IN (1, 3) ORDER BY COALESCE(a, 999);
a
5
SELECT a FROM t1 WHERE a BETWEEN 1 AND 5 ORDER BY a;
a
1
3
5
SELECT a FROM t1 WHERE a NOT BETWEEN 1 AND 3 ORDER BY a;
a
5
SELECT b FROM t1 WHERE b LIKE 'h%' ORDER BY b;
b
hello
SELECT b FROM t1 WHERE b IS NULL;
b
NULL
NULL
SELECT COALESCE(NULLIF(1, 1), IFNULL(NULL, 42));
COALESCE(NULLIF(1,1),IFNULL(NULL,42))
42
SELECT IFNULL(NULLIF(1, 2), 99);
IFNULL(NULLIF(1,2),99)
