# Correlated subquery tests
CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
CREATE TABLE t2 (a INT);
INSERT INTO t2 VALUES (1), (3);
# --- Correlated EXISTS ---
SELECT * FROM t1 WHERE EXISTS (SELECT 1 FROM t2 WHERE t2.a = t1.a) ORDER BY a;
a	b
1	10
3	30
# --- Correlated NOT EXISTS ---
SELECT * FROM t1 WHERE NOT EXISTS (SELECT 1 FROM t2 WHERE t2.a = t1.a) ORDER BY a;
a	b
2	20
DROP TABLE t1, t2;
# --- Correlated scalar subquery in SELECT ---
CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20);
CREATE TABLE t2 (a INT, c INT);
INSERT INTO t2 VALUES (1, 100), (2, 200);
SELECT a, (SELECT c FROM t2 WHERE t2.a = t1.a) AS c FROM t1 ORDER BY a;
a	c
1	100
2	200
# --- Correlated scalar subquery returning NULL ---
SELECT a, (SELECT c FROM t2 WHERE t2.a = 999) AS c FROM t1 ORDER BY a;
a	c
1	NULL
2	NULL
DROP TABLE t1, t2;
