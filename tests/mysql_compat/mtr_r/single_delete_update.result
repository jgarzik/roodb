CREATE TABLE t1 (
pk INT NOT NULL PRIMARY KEY,
c1_idx CHAR(1),
c2 INT
);
INSERT INTO t1 VALUES (1, 'y', NULL), (2, 'y', NULL), (3, 'y', NULL), (4, 'y', NULL);
SELECT * FROM t1 WHERE c1_idx = 'y' ORDER BY pk DESC LIMIT 2;
pk	c1_idx	c2
4	y	NULL
3	y	NULL
UPDATE t1 SET c2 = 0 WHERE c1_idx = 'y' AND pk >= 3;
SELECT * FROM t1 WHERE c1_idx = 'y' ORDER BY pk DESC LIMIT 2;
pk	c1_idx	c2
4	y	0
3	y	0
SELECT * FROM t1 WHERE c1_idx = 'y' ORDER BY pk DESC;
