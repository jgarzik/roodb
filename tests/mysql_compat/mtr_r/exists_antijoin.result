DROP TABLE IF EXISTS customers, orders, products, reviews;
CREATE TABLE customers (
id INT NOT NULL PRIMARY KEY,
name VARCHAR(50) NOT NULL,
city VARCHAR(30) NOT NULL,
tier VARCHAR(10) NOT NULL
);
INSERT INTO customers VALUES
(1, 'Alice', 'NYC', 'gold'),
(2, 'Bob', 'LA', 'silver'),
(3, 'Charlie', 'NYC', 'gold'),
(4, 'Diana', 'Chicago', 'bronze'),
(5, 'Eve', 'LA', 'silver'),
(6, 'Frank', 'Boston', 'gold');
CREATE TABLE orders (
id INT NOT NULL PRIMARY KEY,
customer_id INT NOT NULL,
amount DECIMAL(10,2) NOT NULL,
status VARCHAR(20) NOT NULL
);
INSERT INTO orders VALUES
(1, 1, 150.00, 'shipped'),
(2, 1, 200.00, 'delivered'),
(3, 2, 75.00, 'shipped'),
(4, 3, 300.00, 'pending'),
(5, 3, 50.00, 'delivered'),
(6, 5, 120.00, 'shipped');
CREATE TABLE products (
id INT NOT NULL PRIMARY KEY,
name VARCHAR(50) NOT NULL,
price DECIMAL(10,2) NOT NULL,
category VARCHAR(20) NOT NULL
);
INSERT INTO products VALUES
(1, 'Widget', 25.00, 'hardware'),
(2, 'Gadget', 50.00, 'hardware'),
(3, 'Service A', 100.00, 'service'),
(4, 'Service B', 200.00, 'service');
CREATE TABLE reviews (
id INT NOT NULL PRIMARY KEY,
product_id INT NOT NULL,
customer_id INT NOT NULL,
rating INT NOT NULL
);
INSERT INTO reviews VALUES
(1, 1, 1, 5),
(2, 1, 2, 4),
(3, 2, 1, 3),
(4, 3, 3, 5);
# --- Semi-join via IN: customers who have orders ---
SELECT c.id, c.name
FROM customers c
WHERE c.id IN (SELECT customer_id FROM orders)
ORDER BY c.id;
id	name
1	Alice
2	Bob
3	Charlie
5	Eve
# --- Anti-join via NOT IN: customers with no orders ---
SELECT c.id, c.name
FROM customers c
WHERE c.id NOT IN (SELECT customer_id FROM orders)
ORDER BY c.id;
id	name
4	Diana
6	Frank
# --- Anti-join via LEFT JOIN IS NULL ---
SELECT c.id, c.name
FROM customers c
LEFT JOIN orders o ON c.id = o.customer_id
WHERE o.id IS NULL
ORDER BY c.id;
id	name
4	Diana
6	Frank
# --- Semi-join with filter: customers with shipped orders ---
SELECT c.id, c.name
FROM customers c
WHERE c.id IN (SELECT customer_id FROM orders WHERE status = 'shipped')
ORDER BY c.id;
id	name
1	Alice
2	Bob
5	Eve
# --- Anti-join: customers who have no shipped orders ---
SELECT c.id, c.name
FROM customers c
WHERE c.id NOT IN (SELECT customer_id FROM orders WHERE status = 'shipped')
ORDER BY c.id;
id	name
3	Charlie
4	Diana
6	Frank
# --- Semi-join combined with AND ---
SELECT c.id, c.name, c.tier
FROM customers c
WHERE c.tier = 'gold'
  AND c.id IN (SELECT customer_id FROM orders)
ORDER BY c.id;
id	name	tier
1	Alice	gold
3	Charlie	gold
# --- Semi-join combined with OR ---
SELECT c.id, c.name
FROM customers c
WHERE c.city = 'Boston'
   OR c.id IN (SELECT customer_id FROM orders WHERE amount > 200)
ORDER BY c.id;
id	name
3	Charlie
6	Frank
# --- Anti-join via NOT IN and LEFT JOIN should match ---
SELECT c.id, c.name FROM customers c
WHERE c.id NOT IN (SELECT customer_id FROM reviews)
ORDER BY c.id;
id	name
4	Diana
5	Eve
6	Frank
SELECT c.id, c.name FROM customers c
LEFT JOIN reviews r ON r.customer_id = c.id
WHERE r.id IS NULL
ORDER BY c.id;
id	name
4	Diana
5	Eve
6	Frank
# --- Uncorrelated EXISTS with aggregate subquery (always returns row) ---
SELECT c.id, c.name
FROM customers c
WHERE EXISTS (SELECT COUNT(*) FROM orders WHERE customer_id = 99999)
ORDER BY c.id;
id	name
1	Alice
2	Bob
3	Charlie
4	Diana
5	Eve
6	Frank
# --- NOT EXISTS with empty table ---
DROP TABLE IF EXISTS empty_tbl;
CREATE TABLE empty_tbl (id INT PRIMARY KEY);
SELECT c.id, c.name
FROM customers c
WHERE NOT EXISTS (SELECT 1 FROM empty_tbl)
ORDER BY c.id;
id	name
1	Alice
2	Bob
3	Charlie
4	Diana
5	Eve
6	Frank
SELECT c.id, c.name
FROM customers c
WHERE EXISTS (SELECT 1 FROM empty_tbl)
ORDER BY c.id;
id	name
# --- Double condition: IN orders AND IN reviews ---
SELECT c.id, c.name
FROM customers c
WHERE c.id IN (SELECT customer_id FROM orders)
AND c.id IN (SELECT customer_id FROM reviews)
ORDER BY c.id;
id	name
1	Alice
2	Bob
3	Charlie
# --- IN orders AND NOT IN reviews ---
SELECT c.id, c.name
FROM customers c
WHERE c.id IN (SELECT customer_id FROM orders)
AND c.id NOT IN (SELECT customer_id FROM reviews)
ORDER BY c.id;
id	name
5	Eve
# --- Uncorrelated EXISTS in HAVING ---
SELECT c.city, COUNT(*) AS cnt
FROM customers c
GROUP BY c.city
HAVING COUNT(*) > 1
AND EXISTS (SELECT 1 FROM orders)
ORDER BY c.city;
city	cnt
LA	2
NYC	2
# --- NOT EXISTS in HAVING with empty table ---
SELECT c.tier, COUNT(*) AS cnt
FROM customers c
GROUP BY c.tier
HAVING NOT EXISTS (SELECT 1 FROM empty_tbl)
ORDER BY c.tier;
tier	cnt
bronze	1
gold	3
silver	2
# --- LEFT JOIN anti-join with 3 tables ---
SELECT c.id, c.name
FROM customers c
JOIN orders o ON c.id = o.customer_id
LEFT JOIN reviews r ON c.id = r.customer_id
WHERE r.id IS NULL
ORDER BY c.id;
id	name
5	Eve
# --- Cleanup ---
DROP TABLE customers, orders, products, reviews, empty_tbl;
