# INTERVAL arithmetic, hex comparison, SET defaults
# --- INTERVAL + operator ---
SELECT DATE '2024-01-15' + INTERVAL 10 DAY;
DATE_ADD('2024-01-15',__INTERVAL(10,'DAY'))
2024-01-25
SELECT DATE '2024-01-15' + INTERVAL 1 MONTH;
DATE_ADD('2024-01-15',__INTERVAL(1,'MONTH'))
2024-02-15
SELECT DATE '2024-03-01' - INTERVAL 1 MONTH;
DATE_SUB('2024-03-01',__INTERVAL(1,'MONTH'))
2024-02-01
# --- Column + INTERVAL ---
CREATE TABLE t1 (d DATE);
INSERT INTO t1 VALUES ('2024-06-15');
SELECT d + INTERVAL 7 DAY FROM t1;
DATE_ADD(d,__INTERVAL(7,'DAY'))
2024-06-22
SELECT d - INTERVAL 1 YEAR FROM t1;
DATE_SUB(d,__INTERVAL(1,'YEAR'))
2023-06-15
DROP TABLE t1;
# --- Hex = integer comparison ---
SELECT 0x41 = 65;
blob = 65
1
SELECT 0xFF = 255;
blob = 255
1
SELECT 0x00 = 0;
blob = 0
1
# --- SET column with default ---
CREATE TABLE t1 (s SET('a','b','c') DEFAULT 'a');
INSERT INTO t1 () VALUES ();
SELECT s FROM t1;
s
a
DROP TABLE t1;
