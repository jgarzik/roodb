CREATE TABLE t1 (a INT NOT NULL, b INT NOT NULL, PRIMARY KEY (a));
INSERT INTO t1 VALUES (1,1), (2,2);
SELECT d.a, d.b FROM (SELECT a, b FROM t1) AS d ORDER BY d.a;
a	b
1	1
2	2
DROP TABLE t1;
CREATE TABLE t1 (n INT NOT NULL, m INT NOT NULL);
INSERT INTO t1 VALUES (1,0),(1,0),(1,0),(2,0),(2,0),(3,0);
SELECT * FROM (SELECT n, COUNT(*) AS cnt FROM t1 GROUP BY n HAVING cnt > 1) AS derived ORDER BY n;
n	cnt
1	3
2	2
DROP TABLE t1;
CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1,10),(2,20),(3,30);
CREATE TABLE t2 (a INT, b INT);
INSERT INTO t2 VALUES (1,100),(4,400);
SELECT t1.a, t1.b, d.b AS d_b
FROM t1 LEFT JOIN (SELECT a, b FROM t2) AS d ON t1.a = d.a
ORDER BY t1.a;
a	b	d_b
1	10	NULL
2	20	NULL
3	30	NULL
DROP TABLE t1, t2;
SELECT a.v, b.v FROM (SELECT 1 AS v) AS a, (SELECT 2 AS v) AS b;
v	v
1	2
CREATE TABLE t1 (id INT PRIMARY KEY, val VARCHAR(20));
INSERT INTO t1 VALUES (1,'alpha'),(2,'beta'),(3,'gamma');
SELECT d.id, d.val FROM (SELECT * FROM t1 WHERE id > 1) AS d ORDER BY d.id;
id	val
2	beta
3	gamma
DROP TABLE t1;
CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1,2),(3,4);
CREATE TABLE t2 (a INT, b INT);
INSERT INTO t2 VALUES (1,2),(4,5);
SELECT * FROM (SELECT COUNT(DISTINCT t1.a) AS cnt, t1.b FROM t1 RIGHT JOIN t2 ON t1.a = t2.a GROUP BY t1.b) AS tt ORDER BY tt.b;
cnt	b
0	NULL
1	2
DROP TABLE t1, t2;
CREATE TABLE t1 (x INT, y INT, z VARCHAR(20));
INSERT INTO t1 VALUES (1, 10, 'alpha'), (2, 20, 'beta'), (3, 30, 'gamma');
SELECT d.x, d.total FROM (SELECT x, y + x AS total, z FROM t1) AS d ORDER BY d.total;
x	total
1	11
2	22
3	33
DROP TABLE t1;
CREATE TABLE t1 (id INT, name VARCHAR(20));
INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Carol');
CREATE TABLE t2 (id INT, score INT);
INSERT INTO t2 VALUES (1, 90), (2, 85), (3, 95);
SELECT d.name, t2.score
FROM (SELECT id, name FROM t1) AS d
INNER JOIN t2 ON d.id = t2.id
ORDER BY t2.score;
name	score
Bob	85
Alice	90
Carol	95
DROP TABLE t1, t2;
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (5),(3),(1),(4),(2);
SELECT * FROM (SELECT a FROM t1 ORDER BY a LIMIT 3) AS d ORDER BY d.a;
a
1
2
3
4
5
DROP TABLE t1;
CREATE TABLE t1 (grp INT, val INT);
INSERT INTO t1 VALUES (1,10),(1,20),(2,30),(2,40),(3,50);
SELECT d.grp, d.s, d.c, d.mn, d.mx
FROM (SELECT grp, SUM(val) AS s, COUNT(*) AS c, MIN(val) AS mn, MAX(val) AS mx FROM t1 GROUP BY grp) AS d
ORDER BY d.grp;
grp	s	c	mn	mx
1	30	2	10	20
2	70	2	30	40
3	50	1	50	50
DROP TABLE t1;
