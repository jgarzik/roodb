# Multi-column IN tuples and UNION in subqueries
# --- Multi-column IN ---
CREATE TABLE t1 (a INT, b INT, c INT);
INSERT INTO t1 VALUES (1, 2, 10), (3, 4, 20), (5, 6, 30), (7, 8, 40);
SELECT * FROM t1 WHERE (a, b) IN ((1, 2), (5, 6)) ORDER BY a;
a	b	c
1	2	10
5	6	30
SELECT * FROM t1 WHERE (a, b) NOT IN ((1, 2), (5, 6)) ORDER BY a;
a	b	c
3	4	20
7	8	40
# --- UNION in IN subquery ---
DROP TABLE t1;
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1), (2), (3), (4), (5);
SELECT * FROM t1 WHERE a IN (SELECT 1 UNION SELECT 3 UNION SELECT 5) ORDER BY a;
a
1
# --- JSON arrow in WHERE ---
DROP TABLE t1;
CREATE TABLE t1 (id INT, doc JSON);
INSERT INTO t1 VALUES (1, '{"status": "active"}');
INSERT INTO t1 VALUES (2, '{"status": "inactive"}');
INSERT INTO t1 VALUES (3, '{"status": "active"}');
SELECT id FROM t1 WHERE JSON_UNQUOTE(doc->'$.status') = 'active' ORDER BY id;
id
1
3
DROP TABLE t1;
