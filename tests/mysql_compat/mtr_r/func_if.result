#
# Bug#24492965 ERROR RESULTS FROM CALCULATION
#
CREATE TABLE test_grids_1 (
unq_id int(11) NOT NULL DEFAULT '0',
var_fld int(11) DEFAULT '0'
);
INSERT INTO test_grids_1 VALUES
(1,4500),
(2,6000);
CREATE TABLE test_grid_dtl_1 (
dtl_id int(11) NOT NULL DEFAULT '0',
unq_id int(11) DEFAULT '0'
);
INSERT INTO test_grid_dtl_1 VALUES
(1,1),
(2,1),
(3,2);
SELECT g.calc_var, g.if_var, g.case_var
FROM
(
SELECT unq_id,
IF ( var_fld  > 5000, (     1 / var_fld ) , 5000 ) calc_var,
IF ( var_fld  > 5000, ( 00001 / var_fld ) , 5000 ) if_var,
CASE  var_fld  > 5000 WHEN TRUE THEN ( 1 / var_fld ) ELSE 5000 END case_var
FROM
test_grids_1
) g
JOIN
test_grid_dtl_1 d USING (unq_id)
ORDER BY 1
;
calc_var	if_var	case_var
0.000166666666667	0.000166666666667	0.000166666666667
0.000166666666667	0.000166666666667	0.000166666666667
0.000166666666667	0.000166666666667	0.000166666666667
5000	5000	5000
5000	5000	5000
5000	5000	5000
DROP TABLE test_grids_1, test_grid_dtl_1;
#
# Additional basic IF/NULLIF/IFNULL tests
#
SELECT IF(1 > 0, 'yes', 'no');
IF(1 > 0,'yes','no')
yes
SELECT IF(1 < 0, 'yes', 'no');
IF(1 < 0,'yes','no')
no
SELECT IF(NULL, 'yes', 'no');
IF(NULL,'yes','no')
no
SELECT IFNULL(NULL, 'replacement');
IFNULL(NULL,'replacement')
replacement
SELECT IFNULL('value', 'replacement');
IFNULL('value','replacement')
value
SELECT IFNULL(NULL, NULL);
IFNULL(NULL,NULL)
NULL
SELECT NULLIF(1, 1);
NULLIF(1,1)
NULL
SELECT NULLIF(1, 2);
NULLIF(1,2)
1
SELECT NULLIF('abc', 'abc');
NULLIF('abc','abc')
NULL
SELECT NULLIF('abc', 'def');
NULLIF('abc','def')
abc
