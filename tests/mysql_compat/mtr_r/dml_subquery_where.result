DROP TABLE IF EXISTS inventory, warehouses, shipments;
CREATE TABLE warehouses (
id INT NOT NULL PRIMARY KEY,
name VARCHAR(30) NOT NULL,
region VARCHAR(20) NOT NULL
);
INSERT INTO warehouses VALUES
(1, 'East Hub', 'east'),
(2, 'West Hub', 'west'),
(3, 'Central', 'central');
CREATE TABLE inventory (
id INT NOT NULL PRIMARY KEY,
warehouse_id INT NOT NULL,
product VARCHAR(30) NOT NULL,
qty INT NOT NULL,
min_qty INT NOT NULL DEFAULT 10
);
INSERT INTO inventory VALUES
(1, 1, 'Widget', 100, 10),
(2, 1, 'Gadget', 5, 10),
(3, 2, 'Widget', 200, 10),
(4, 2, 'Bolt', 50, 20),
(5, 3, 'Gadget', 8, 10),
(6, 3, 'Nut', 500, 50),
(7, 1, 'Bolt', 3, 10),
(8, 2, 'Nut', 15, 20);
CREATE TABLE shipments (
id INT NOT NULL PRIMARY KEY,
inventory_id INT NOT NULL,
qty_shipped INT NOT NULL
);
INSERT INTO shipments VALUES
(1, 1, 20), (2, 1, 30), (3, 3, 50), (4, 6, 100);
# --- UPDATE with IN subquery in WHERE ---
UPDATE inventory SET min_qty = min_qty + 5
WHERE warehouse_id IN (SELECT id FROM warehouses WHERE region = 'east');
SELECT id, warehouse_id, product, min_qty FROM inventory ORDER BY id;
id	warehouse_id	product	min_qty
1	1	Widget	15
2	1	Gadget	15
3	2	Widget	10
4	2	Bolt	20
5	3	Gadget	10
6	3	Nut	50
7	1	Bolt	15
8	2	Nut	20
# --- UPDATE with NOT IN subquery ---
UPDATE inventory SET min_qty = 10
WHERE warehouse_id NOT IN (SELECT id FROM warehouses WHERE region = 'central');
SELECT id, warehouse_id, product, min_qty FROM inventory ORDER BY id;
id	warehouse_id	product	min_qty
1	1	Widget	10
2	1	Gadget	10
3	2	Widget	10
4	2	Bolt	10
5	3	Gadget	10
6	3	Nut	50
7	1	Bolt	10
8	2	Nut	10
# --- UPDATE with scalar subquery comparison ---
UPDATE inventory SET qty = qty + 10
WHERE qty < (SELECT AVG(i2.qty) FROM (SELECT qty FROM inventory) i2);
SELECT id, product, qty FROM inventory ORDER BY id;
id	product	qty
1	Widget	110
2	Gadget	15
3	Widget	200
4	Bolt	60
5	Gadget	18
6	Nut	500
7	Bolt	13
8	Nut	25
# --- UPDATE with IN subquery matching shipped items ---
UPDATE inventory SET qty = qty + 1
WHERE id IN (SELECT inventory_id FROM shipments);
SELECT id, product, qty FROM inventory ORDER BY id;
id	product	qty
1	Widget	111
2	Gadget	15
3	Widget	201
4	Bolt	60
5	Gadget	18
6	Nut	501
7	Bolt	13
8	Nut	25
# --- DELETE with IN subquery ---
DELETE FROM shipments
WHERE inventory_id IN (SELECT id FROM inventory WHERE warehouse_id = 2);
SELECT * FROM shipments ORDER BY id;
id	inventory_id	qty_shipped
1	1	20
2	1	30
4	6	100
# --- DELETE with NOT IN subquery ---
DELETE FROM shipments
WHERE inventory_id NOT IN (SELECT id FROM inventory WHERE warehouse_id = 1);
SELECT * FROM shipments ORDER BY id;
id	inventory_id	qty_shipped
1	1	20
2	1	30
# --- DELETE with scalar subquery ---
DELETE FROM inventory
WHERE qty < (SELECT MIN(m.min_qty) FROM (SELECT min_qty FROM inventory) m);
SELECT id, product, qty FROM inventory ORDER BY id;
id	product	qty
1	Widget	111
2	Gadget	15
3	Widget	201
4	Bolt	60
5	Gadget	18
6	Nut	501
7	Bolt	13
8	Nut	25
# --- DELETE with NOT IN: warehouses with no inventory ---
DELETE FROM warehouses
WHERE id NOT IN (SELECT DISTINCT warehouse_id FROM inventory);
SELECT * FROM warehouses ORDER BY id;
id	name	region
1	East Hub	east
2	West Hub	west
3	Central	central
# --- UPDATE with subquery in SET value ---
UPDATE inventory SET qty = (SELECT MAX(qty_shipped) FROM shipments) WHERE id = 1;
SELECT id, product, qty FROM inventory WHERE id = 1;
id	product	qty
1	Widget	30
# --- UPDATE with multiple IN subqueries ---
UPDATE inventory SET min_qty = 25
WHERE warehouse_id IN (SELECT id FROM warehouses WHERE region = 'east')
AND id IN (SELECT inventory_id FROM shipments);
SELECT id, product, min_qty FROM inventory ORDER BY id;
id	product	min_qty
1	Widget	25
2	Gadget	10
3	Widget	10
4	Bolt	10
5	Gadget	10
6	Nut	50
7	Bolt	10
8	Nut	10
# --- DELETE with scalar subquery in WHERE ---
DELETE FROM inventory
WHERE qty > (SELECT AVG(q) * 2 FROM (SELECT qty AS q FROM inventory) sub);
SELECT id, product, qty FROM inventory ORDER BY id;
id	product	qty
1	Widget	30
2	Gadget	15
3	Widget	201
4	Bolt	60
5	Gadget	18
7	Bolt	13
8	Nut	25
# --- Verify final state ---
SELECT COUNT(*) AS inv_count FROM inventory;
inv_count
7
SELECT COUNT(*) AS wh_count FROM warehouses;
wh_count
3
SELECT COUNT(*) AS ship_count FROM shipments;
ship_count
2
# --- Cleanup ---
DROP TABLE shipments, inventory, warehouses;
