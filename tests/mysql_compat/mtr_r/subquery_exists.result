DROP TABLE IF EXISTS t1, t2, t3, t4;
CREATE TABLE t1 (id INT PRIMARY KEY, val VARCHAR(20));
INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three'), (4, 'four'), (5, 'five');
CREATE TABLE t2 (id INT PRIMARY KEY, ref_id INT, amount DECIMAL(10,2));
INSERT INTO t2 VALUES (1, 1, 10.50), (2, 1, 20.75), (3, 2, 30.00),
(4, 3, 40.25), (5, 5, 50.00);
CREATE TABLE t3 (id INT PRIMARY KEY, category VARCHAR(10));
INSERT INTO t3 VALUES (1, 'A'), (2, 'B'), (3, 'A'), (4, 'B'), (5, 'A');
SELECT t1.id, t1.val, t2.amount
FROM t1 JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id, t2.id;
id	val	amount
1	one	10.50
1	one	20.75
2	two	30.00
3	three	40.25
5	five	50.00
SELECT t1.id, t1.val, t2.amount
FROM t1 LEFT JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id, t2.id;
id	val	amount
1	one	10.50
1	one	20.75
2	two	30.00
3	three	40.25
4	four	NULL
5	five	50.00
SELECT t1.id, t1.val
FROM t1 LEFT JOIN t2 ON t1.id = t2.ref_id
WHERE t2.id IS NULL
ORDER BY t1.id;
id	val
4	four
SELECT t1.id, t1.val, t2.id AS t2_id, t2.ref_id
FROM t1 RIGHT JOIN t2 ON t1.id = t2.ref_id
ORDER BY t2.id;
id	val	t2_id	ref_id
1	one	1	1
1	one	2	1
2	two	3	2
3	three	4	3
5	five	5	5
SELECT t1.id, t1.val, t3.category, SUM(t2.amount) AS total
FROM t1
JOIN t3 ON t1.id = t3.id
LEFT JOIN t2 ON t1.id = t2.ref_id
GROUP BY t1.id, t1.val, t3.category
ORDER BY t1.id;
id	val	category	total
1	one	A	31.25
2	two	B	30
3	three	A	40.25
4	four	B	NULL
5	five	A	50
SELECT a.id AS id1, b.id AS id2, a.val AS val1, b.val AS val2
FROM t1 a JOIN t1 b ON a.id < b.id
WHERE a.id <= 3 AND b.id <= 3
ORDER BY a.id, b.id;
id1	id2	val1	val2
1	2	one	two
1	3	one	three
2	3	two	three
SELECT d.ref_id, d.total
FROM (SELECT ref_id, SUM(amount) AS total FROM t2 GROUP BY ref_id) d
WHERE d.total > 25
ORDER BY d.ref_id;
ref_id	total
1	31.25
2	30
3	40.25
5	50
SELECT t1.id, t1.val, COUNT(t2.id) AS order_count, SUM(t2.amount) AS total
FROM t1
LEFT JOIN t2 ON t1.id = t2.ref_id
GROUP BY t1.id, t1.val
HAVING COUNT(t2.id) > 0
ORDER BY t1.id;
id	val	order_count	total
1	one	2	31.25
2	two	1	30
3	three	1	40.25
5	five	1	50
CREATE TABLE t4 (id INT PRIMARY KEY, total_amount DECIMAL(10,2));
INSERT INTO t4 SELECT t2.ref_id, SUM(t2.amount)
FROM t2 GROUP BY t2.ref_id;
SELECT * FROM t4 ORDER BY id;
id	total_amount
1	31.25
2	30.00
3	40.25
5	50.00
UPDATE t1 SET val = 'has_orders' WHERE id = 1;
UPDATE t1 SET val = 'has_orders' WHERE id = 2;
UPDATE t1 SET val = 'has_orders' WHERE id = 3;
UPDATE t1 SET val = 'has_orders' WHERE id = 5;
SELECT * FROM t1 ORDER BY id;
id	val
1	has_orders
2	has_orders
3	has_orders
4	four
5	has_orders
DELETE FROM t3 WHERE category = 'B';
SELECT * FROM t3 ORDER BY id;
id	category
1	A
3	A
5	A
SELECT t1.val, t3.category, t2.amount
FROM t1
JOIN t3 ON t1.id = t3.id
LEFT JOIN t2 ON t1.id = t2.ref_id
ORDER BY t3.category, t1.val, t2.amount;
val	category	amount
has_orders	A	10.50
has_orders	A	20.75
has_orders	A	40.25
has_orders	A	50.00
SELECT a.id AS a_id, b.id AS b_id
FROM t3 a, t3 b
WHERE a.id < b.id
ORDER BY a.id, b.id;
a_id	b_id
1	3
1	5
3	5
SELECT t1.id, t2.amount
FROM t1 JOIN t2 ON t1.id = t2.ref_id
WHERE t2.amount BETWEEN 15 AND 45
ORDER BY t2.amount;
id	amount
1	20.75
2	30.00
3	40.25
SELECT t1.id, t1.val
FROM t1
WHERE EXISTS (SELECT 1 FROM t2)
ORDER BY t1.id;
id	val
1	has_orders
2	has_orders
3	has_orders
4	four
5	has_orders
SELECT t1.id, t1.val
FROM t1
WHERE NOT EXISTS (SELECT 1 FROM t2)
ORDER BY t1.id;
id	val
SELECT t1.id, t1.val
FROM t1
WHERE EXISTS (SELECT 1 FROM t2 WHERE ref_id = 1)
ORDER BY t1.id;
id	val
1	has_orders
2	has_orders
3	has_orders
4	four
5	has_orders
SELECT t1.id, t1.val
FROM t1
WHERE EXISTS (SELECT 1 FROM t2 WHERE ref_id = 999)
ORDER BY t1.id;
id	val
SELECT t1.id, t1.val
FROM t1
WHERE NOT EXISTS (SELECT 1 FROM t2 WHERE ref_id = 999)
ORDER BY t1.id;
id	val
1	has_orders
2	has_orders
3	has_orders
4	four
5	has_orders
SELECT t1.id, t1.val
FROM t1
WHERE EXISTS (SELECT COUNT(*) FROM t2 WHERE ref_id = 999)
ORDER BY t1.id;
id	val
1	has_orders
2	has_orders
3	has_orders
4	four
5	has_orders
DROP TABLE t1, t2, t3, t4;
