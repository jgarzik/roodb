SELECT * FROM t1;
a	b
1	12
2	3
DROP TABLE t1;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, text1 TEXT, text2 TEXT);
INSERT INTO t1 VALUES (0, 'x', 'x'), (1, 'y', 'y');
SELECT * FROM t1;
id	text1	text2
0	x	x
1	y	y
UPDATE t1 SET text1 = 'z', text2 = 'w' WHERE id = 0;
SELECT * FROM t1;
id	text1	text2
0	z	w
1	y	y
DROP TABLE t1;
CREATE TABLE t1 (
id INT AUTO_INCREMENT PRIMARY KEY,
c1 CHAR(1),
cnt INT DEFAULT 1
);
INSERT INTO t1 (c1) VALUES ('A'), ('B'), ('C');
SELECT c1, cnt FROM t1 ORDER BY c1;
c1	cnt
A	1
B	1
C	1
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT, c VARCHAR(20));
INSERT INTO t1 SET a=1, b=10, c='first';
INSERT INTO t1 SET a=2, b=20, c='second';
INSERT INTO t1 SET a=3;
SELECT * FROM t1;
a	b	c
1	10	first
2	20	second
3	NULL	NULL
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT DEFAULT 0);
INSERT INTO t1 (a) VALUES (1);
INSERT INTO t1 (a, b) VALUES (2, 10);
INSERT INTO t1 VALUES (3, 20);
SELECT * FROM t1;
a	b
1	0
2	10
3	20
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 10 + 5);
INSERT INTO t1 VALUES (2, 100 * 2);
INSERT INTO t1 VALUES (3, 7 - 3);
SELECT * FROM t1;
a	b
1	15
2	200
3	4
DROP TABLE t1;
