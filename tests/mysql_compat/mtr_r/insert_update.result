1	2	10
3	4	20
INSERT INTO t1 VALUES (5,6,30);
SELECT * FROM t1;
a	b	c
1	2	10
3	4	20
5	6	30
TRUNCATE TABLE t1;
INSERT INTO t1 VALUES (1,2,10), (3,4,20);
SELECT * FROM t1;
