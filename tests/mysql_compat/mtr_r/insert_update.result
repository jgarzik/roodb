CREATE TABLE t1 (a INT, b INT, c INT);
INSERT INTO t1 VALUES (1,2,10), (3,4,20);
CREATE TABLE t2 (a INT, b INT, c INT, d INT);
INSERT INTO t2 VALUES (5,6,30,1), (7,8,40,1), (9,10,60,1);
INSERT INTO t1 SELECT a,b,c FROM t2 WHERE d=1;
SELECT * FROM t1;
a	b	c
1	2	10
3	4	20
5	6	30
7	8	40
9	10	60
DROP TABLE t1;
DROP TABLE t2;
