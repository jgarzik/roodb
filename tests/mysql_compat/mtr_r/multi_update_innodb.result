DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
#
# Multi-table JOIN with aggregate on empty result
#
CREATE TABLE t1 (
pk INT,
a INT,
b INT,
PRIMARY KEY (pk)
);
INSERT INTO t1 VALUES (0,0,0);
CREATE TABLE t2 (
pk INT,
a INT,
b INT,
PRIMARY KEY (pk)
);
INSERT INTO t2 VALUES (1,1,1);
SELECT COUNT(*) FROM t1, t2;
COUNT(NULL)
1
SELECT t1.pk, t2.pk FROM t1 JOIN t2 ON t1.pk = t2.pk;
pk	pk
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.pk = t2.pk;
COUNT(NULL)
0
SELECT MIN(t1.a), MAX(t2.b) FROM t1 JOIN t2 ON t1.pk = t2.pk;
MIN(a)	MAX(b)
NULL	NULL
SELECT SUM(t1.a + t2.b) FROM t1 JOIN t2 ON t1.pk = t2.pk;
SUM(a + b)
NULL
DROP TABLE t1, t2;
#
# Multi-table JOIN with composite primary key
#
CREATE TABLE t1 (
col_int_key int,
pk int,
col_int int,
PRIMARY KEY (pk)
);
INSERT INTO t1 VALUES (1,2,3);
CREATE TABLE t2 (
col_int_key int,
pk_1 int,
pk_2 int,
col_int int,
PRIMARY KEY (pk_1,pk_2)
);
INSERT INTO t2 VALUES (1,2,3,4);
SELECT t1.pk, t1.col_int, t2.pk_1, t2.col_int
FROM t1 JOIN t2 ON t1.pk = t2.pk_1;
pk	col_int	pk_1	col_int
2	3	2	4
SELECT COUNT(*), SUM(t1.col_int + t2.col_int)
FROM t1 JOIN t2 ON t1.pk = t2.pk_1;
COUNT(NULL)	SUM(col_int + col_int)
1	7
DROP TABLE t1, t2;
#
# Three-table cross join with COUNT
#
CREATE TABLE t1(c1 INT);
INSERT INTO t1 VALUES (0),(0),(1);
CREATE TABLE t2(b INT);
INSERT INTO t2 VALUES(0),(0);
CREATE TABLE t3(x INT);
INSERT INTO t3 VALUES(10),(20),(30);
SELECT COUNT(*) FROM t1, t2;
COUNT(NULL)
6
SELECT COUNT(*) FROM t1, t2, t3;
COUNT(NULL)
18
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.c1 = t2.b;
COUNT(NULL)
4
SELECT t1.c1, COUNT(*) FROM t1, t2 GROUP BY t1.c1 ORDER BY t1.c1;
c1	COUNT(NULL)
0	4
1	2
DROP TABLE t1, t2, t3;
#
# JOIN with large composite primary key
#
CREATE TABLE t1 (c1 CHAR(255) NOT NULL);
CREATE TABLE t2 (c1 CHAR(255) NOT NULL, c2 CHAR(255) NOT NULL,
c3 CHAR(255) NOT NULL, PRIMARY KEY (c1, c2, c3));
INSERT INTO t1 VALUES ('x'), ('x');
INSERT INTO t2 VALUES ('x', '', '');
SELECT t1.c1, t2.c2, t2.c3 FROM t1 JOIN t2 ON t1.c1 = t2.c1;
c1	c2	c3
x		
x		
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.c1 = t2.c1;
COUNT(NULL)
2
UPDATE t2 SET c2 = 'y', c3 = 'y' WHERE c1 = 'x';
SELECT * FROM t2;
c1	c2	c3
x	y	y
SELECT t1.c1, t2.c2, t2.c3 FROM t1 JOIN t2 ON t1.c1 = t2.c1;
c1	c2	c3
x	y	y
x	y	y
DROP TABLE t1, t2;
#
# Aggregate edge cases with JOINs
#
CREATE TABLE t1 (id INT PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
CREATE TABLE t2 (id INT PRIMARY KEY, ref_id INT, status INT);
INSERT INTO t2 VALUES (1, 1, 0), (2, 2, 0), (3, 99, 0);
SELECT t1.id, t1.val, t2.status
FROM t1 JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id;
id	val	status
1	10	0
2	20	0
SELECT t1.id, t1.val, t2.ref_id, t2.status
FROM t1 LEFT JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id;
id	val	ref_id	status
1	10	1	0
2	20	2	0
3	30	NULL	NULL
SELECT COUNT(*), SUM(t1.val), AVG(t1.val)
FROM t1 JOIN t2 ON t1.id = t2.ref_id;
COUNT(NULL)	SUM(val)	AVG(val)
2	30	15
SELECT t2.status, COUNT(*), SUM(t1.val)
FROM t1 JOIN t2 ON t1.id = t2.ref_id
GROUP BY t2.status;
status	COUNT(NULL)	SUM(val)
0	2	30
DROP TABLE t1, t2;
