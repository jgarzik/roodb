CREATE TABLE t1 (id int primary key, name varchar(50), description varchar(100));
INSERT INTO t1 VALUES (1, 'Alice', 'First user');
INSERT INTO t1 VALUES (2, 'Bob', 'Second user');
INSERT INTO t1 VALUES (3, 'Charlie', 'Third user');
INSERT INTO t1 VALUES (4, '', 'Empty name');
INSERT INTO t1 VALUES (5, NULL, 'NULL name');
SELECT id, LENGTH(name), CHAR_LENGTH(name) FROM t1 ORDER BY id;
id	LENGTH(name)	CHAR_LENGTH(name)
1	5	5
2	3	3
3	7	7
4	0	0
5	NULL	NULL
SELECT id, UPPER(name), LOWER(name) FROM t1 ORDER BY id;
id	UPPER(name)	LOWER(name)
1	ALICE	alice
2	BOB	bob
3	CHARLIE	charlie
4		
5	NULL	NULL
SELECT id, CONCAT(name, ' - ', description) FROM t1 WHERE name IS NOT NULL AND name != '' ORDER BY id;
id	CONCAT(name,' - ',description)
1	Alice - First user
2	Bob - Second user
3	Charlie - Third user
SELECT id, SUBSTRING(description, 1, 5) FROM t1 ORDER BY id;
id	SUBSTRING(description,1,5)
1	First
2	Secon
3	Third
4	Empty
5	NULL 
SELECT id, REPLACE(description, 'user', 'person') FROM t1 ORDER BY id;
id	REPLACE(description,'user','person')
1	First person
2	Second person
3	Third person
4	Empty name
5	NULL name
SELECT id, REVERSE(name) FROM t1 WHERE name IS NOT NULL ORDER BY id;
id	REVERSE(name)
1	ecilA
2	boB
3	eilrahC
4	
SELECT id, LPAD(name, 10, '*'), RPAD(name, 10, '*') FROM t1 WHERE name IS NOT NULL ORDER BY id;
id	LPAD(name,10,'*')	RPAD(name,10,'*')
1	*****Alice	Alice*****
2	*******Bob	Bob*******
3	***Charlie	Charlie***
4	**********	**********
DROP TABLE t1;
