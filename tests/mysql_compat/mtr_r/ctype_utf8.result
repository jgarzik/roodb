CONCAT_WS(',','a','b','c')
a,b,c
SELECT CONCAT_WS('-', 'hello', NULL, 'world');
CONCAT_WS('-','hello',NULL,'world')
hello-world
SELECT CONCAT_WS('', 'a', 'b');
CONCAT_WS('','a','b')
ab
