DROP TABLE IF EXISTS t1, t2;
CREATE TABLE t1 (f1 INT);
INSERT INTO t1 VALUES (1);
CREATE TABLE t2 (f1 INT, f2 INT);
SELECT t1.f1, COUNT(DISTINCT t2.f2), COUNT(DISTINCT 1, NULL) FROM t1 LEFT JOIN t2 ON t1.f1=t2.f1 GROUP BY t1.f1 ORDER BY t1.f1;
f1	COUNT(f2)	COUNT(1,NULL)
1	0	1
DROP TABLE t1, t2;
CREATE TABLE t1 (f INT);
SELECT COUNT(DISTINCT f) FROM t1;
COUNT(f)
0
DROP TABLE t1;
CREATE TABLE t1 (a CHAR(3), b CHAR(20), PRIMARY KEY (a, b));
INSERT INTO t1 VALUES ('ABW', 'Dutch'), ('ABW', 'English');
SELECT COUNT(DISTINCT a) FROM t1;
COUNT(a)
1
DROP TABLE t1;
CREATE TABLE t1 (f1 INT, f2 INT);
INSERT INTO t1 VALUES (0,1),(1,2);
SELECT COUNT(DISTINCT IF(f1,3,f2)) FROM t1;
COUNT(IF(f1,3,f2))
2
DROP TABLE t1;
CREATE TABLE t1 (i INT);
INSERT INTO t1 VALUES (0), (1);
SELECT COUNT(DISTINCT i) FROM t1;
COUNT(i)
2
DROP TABLE t1;
#
# Bug#11760197: INCORRECT RESULTS WITH COUNT DISTINCT
#
CREATE TABLE t1 (a INT PRIMARY KEY);
INSERT INTO t1 VALUES (1),(2);
SELECT COUNT(DISTINCT t1.a) FROM t1, t1 t2 WHERE t1.a = 1;
COUNT(a)
1
DROP TABLE t1;
CREATE TABLE t1 (a CHAR PRIMARY KEY);
INSERT INTO t1 VALUES (1),(2);
SELECT COUNT(DISTINCT t1.a) FROM t1, t1 t2 WHERE t1.a = 1;
COUNT(a)
0
SELECT COUNT(DISTINCT t1.a) FROM t1, t1 t2 WHERE t1.a = '1';
COUNT(a)
1
DROP TABLE t1;
CREATE TABLE t1 (pk INT NOT NULL, col_varchar_key VARCHAR(1), PRIMARY KEY (pk));
INSERT INTO t1 VALUES (10,'x'),(11,'d'),(12,'r'),(13,'f'),(14,'y');
CREATE TABLE t2 (pk INT NOT NULL, col_int_nokey INT, col_varchar_key VARCHAR(1), PRIMARY KEY (pk));
INSERT INTO t2 VALUES (1,7,'x');
SELECT COUNT(DISTINCT table1.col_varchar_key)
FROM t2 AS table1
JOIN t1 AS table2 ON (table2.pk = table1.col_int_nokey)
WHERE table1.pk = 1;
COUNT(col_varchar_key)
0
SELECT COUNT(table1.col_varchar_key)
FROM t2 AS table1
JOIN t1 AS table2 ON (table2.pk = table1.col_int_nokey)
WHERE table1.pk = 1;
COUNT(col_varchar_key)
0
DROP TABLE t1, t2;
