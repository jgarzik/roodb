(9, 5, 130), (10, 5, 80);
# --- Basic derived table in JOIN ---
SELECT e.name, d.dept_name, d.avg_sal
FROM employees e
JOIN (
SELECT dept_id, AVG(salary) AS avg_sal, MAX(salary) AS max_sal,
MIN(name) AS dept_name
FROM employees
GROUP BY dept_id
) d ON e.dept_id = d.dept_id
WHERE e.salary > d.avg_sal
ORDER BY e.id;
name	dept_name	avg_sal
# --- Multiple derived tables in JOIN ---
SELECT ds.dept_name, ds.emp_count, dp.proj_count
FROM (
SELECT dept_id, COUNT(*) AS emp_count,
MIN(name) AS dept_name
FROM employees
GROUP BY dept_id
) ds
JOIN (
SELECT dept_id, COUNT(*) AS proj_count
FROM projects
GROUP BY dept_id
) dp ON ds.dept_id = dp.dept_id
ORDER BY ds.dept_id;
dept_name	emp_count	proj_count
# --- Derived table with regular table in JOIN ---
SELECT d.name AS dept, sub.total_hours
FROM departments d
JOIN (
SELECT p.dept_id, SUM(a.hours) AS total_hours
FROM assignments a
JOIN projects p ON a.project_id = p.id
GROUP BY p.dept_id
) sub ON d.id = sub.dept_id
ORDER BY d.id;
dept	total_hours
# --- LEFT JOIN with derived table ---
SELECT d.name AS dept, COALESCE(sub.total_hours, 0) AS total_hours
FROM departments d
LEFT JOIN (
SELECT p.dept_id, SUM(a.hours) AS total_hours
FROM assignments a
JOIN projects p ON a.project_id = p.id
GROUP BY p.dept_id
) sub ON d.id = sub.dept_id
ORDER BY d.id;
dept	total_hours
Engineering	0
Marketing	0
Sales	0
Support	0
# --- Derived table with WHERE filter ---
SELECT e.name, e.salary, top_d.max_sal
FROM employees e
JOIN (
SELECT dept_id, MAX(salary) AS max_sal
FROM employees
WHERE hire_year >= 2020
GROUP BY dept_id
) top_d ON e.dept_id = top_d.dept_id AND e.salary = top_d.max_sal
ORDER BY e.id;
name	salary	max_sal
# --- Nested derived tables ---
SELECT outer_d.dept_id, outer_d.senior_count
FROM (
SELECT dept_id, COUNT(*) AS senior_count
FROM (
SELECT id, dept_id, salary, hire_year
FROM employees
WHERE hire_year <= 2020
) seniors
GROUP BY dept_id
) outer_d
ORDER BY outer_d.dept_id;
dept_id	senior_count
1	3
3	2
# --- Derived table joining with another derived table and real table ---
SELECT d.name AS department,
emp_stats.avg_salary,
proj_stats.total_hours
FROM departments d
JOIN (
SELECT dept_id, ROUND(AVG(salary), 2) AS avg_salary
FROM employees
GROUP BY dept_id
) emp_stats ON d.id = emp_stats.dept_id
LEFT JOIN (
SELECT p.dept_id, SUM(a.hours) AS total_hours
FROM projects p
JOIN assignments a ON p.id = a.project_id
GROUP BY p.dept_id
) proj_stats ON d.id = proj_stats.dept_id
ORDER BY d.id;
department	avg_salary	total_hours
# --- Derived table with HAVING ---
SELECT d.name, sub.high_earners
FROM departments d
JOIN (
SELECT dept_id, COUNT(*) AS high_earners
FROM employees
WHERE salary >= 80000.00
GROUP BY dept_id
HAVING COUNT(*) >= 2
) sub ON d.id = sub.dept_id
ORDER BY d.id;
name	high_earners
# --- Derived table with WHERE filter (top 2 budgets) ---
SELECT e.name, e.salary
FROM employees e
JOIN (
SELECT id AS dept_id FROM departments WHERE budget >= 300000.00
) big_depts ON e.dept_id = big_depts.dept_id
ORDER BY e.salary DESC;
name	salary
# --- Scalar subquery alongside derived table JOIN ---
SELECT e.name, e.salary,
e.salary - (SELECT AVG(salary) FROM employees) AS diff_from_avg,
ds.dept_avg
FROM employees e
JOIN (
SELECT dept_id, ROUND(AVG(salary), 2) AS dept_avg
FROM employees
GROUP BY dept_id
) ds ON e.dept_id = ds.dept_id
WHERE e.salary > ds.dept_avg
ORDER BY e.id;
name	salary	diff_from_avg	dept_avg
# --- Derived table with DISTINCT ---
SELECT DISTINCT sub.dept_id, sub.project_name
FROM (
SELECT p.dept_id, p.name AS project_name, a.emp_id
FROM projects p
JOIN assignments a ON p.id = a.project_id
) sub
ORDER BY sub.dept_id, sub.project_name;
dept_id	project_name
1	Backend Rewrite
1	Mobile App
2	Ad Campaign
3	Q4 Push
4	Help Desk v2
# --- Cleanup ---
DROP TABLE assignments, projects, employees, departments;
