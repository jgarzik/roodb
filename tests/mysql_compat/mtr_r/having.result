DROP TABLE IF EXISTS t1, t2, t3;
CREATE TABLE t1 (a int);
SELECT count(a) AS b FROM t1 WHERE a=0 HAVING b > 0;
b
INSERT INTO t1 VALUES (null);
SELECT count(a) AS b FROM t1 WHERE a=0 HAVING b > 0;
b
SELECT count(a) AS b FROM t1 WHERE a=0 HAVING b >=0;
b
