# CONVERT_TZ tests
# --- UTC to positive offset ---
SELECT CONVERT_TZ('2024-01-15 12:00:00', '+00:00', '+05:30');
CONVERT_TZ('2024-01-15 12:00:00','+00:00','+05:30')
2024-01-15 17:30:00
SELECT CONVERT_TZ('2024-01-15 12:00:00', '+00:00', '+09:00');
CONVERT_TZ('2024-01-15 12:00:00','+00:00','+09:00')
2024-01-15 21:00:00
# --- UTC to negative offset ---
SELECT CONVERT_TZ('2024-01-15 12:00:00', '+00:00', '-05:00');
CONVERT_TZ('2024-01-15 12:00:00','+00:00','-05:00')
2024-01-15 07:00:00
SELECT CONVERT_TZ('2024-01-15 12:00:00', '+00:00', '-08:00');
CONVERT_TZ('2024-01-15 12:00:00','+00:00','-08:00')
2024-01-15 04:00:00
# --- Named timezone UTC ---
SELECT CONVERT_TZ('2024-01-15 12:00:00', 'UTC', '+03:00');
CONVERT_TZ('2024-01-15 12:00:00','UTC','+03:00')
2024-01-15 15:00:00
# --- Cross-midnight conversion ---
SELECT CONVERT_TZ('2024-01-15 23:00:00', '+00:00', '+05:00');
CONVERT_TZ('2024-01-15 23:00:00','+00:00','+05:00')
2024-01-16 04:00:00
SELECT CONVERT_TZ('2024-01-15 02:00:00', '+00:00', '-05:00');
CONVERT_TZ('2024-01-15 02:00:00','+00:00','-05:00')
2024-01-14 21:00:00
# --- Between two offsets ---
SELECT CONVERT_TZ('2024-06-15 12:00:00', '+05:30', '-05:00');
CONVERT_TZ('2024-06-15 12:00:00','+05:30','-05:00')
2024-06-15 01:30:00
# --- NULL handling ---
SELECT CONVERT_TZ(NULL, '+00:00', '+05:00');
CONVERT_TZ(NULL,'+00:00','+05:00')
NULL
SELECT CONVERT_TZ('2024-01-15 12:00:00', NULL, '+05:00');
CONVERT_TZ('2024-01-15 12:00:00',NULL,'+05:00')
NULL
