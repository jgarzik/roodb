DROP TABLE IF EXISTS t1, t2, t3;
CREATE TABLE t1 (
a INT,
b VARCHAR(20) DEFAULT NULL,
c INT NOT NULL,
PRIMARY KEY (c)
);
INSERT INTO t1 VALUES (NULL, 'alpha', 1), (NULL, 'beta', 2),
(3, NULL, 3), (4, 'delta', 4), (NULL, NULL, 5);
SELECT * FROM t1 ORDER BY c;
a	b	c
NULL	alpha	1
NULL	beta	2
3	NULL	3
4	delta	4
NULL	NULL	5
DELETE FROM t1 WHERE a IS NULL;
SELECT * FROM t1 ORDER BY c;
a	b	c
3	NULL	3
4	delta	4
DROP TABLE t1;
CREATE TABLE t1 (a INT, b INT, c VARCHAR(10));
INSERT INTO t1 VALUES (1, 10, 'x'), (2, 20, 'y'), (3, 30, 'x'),
(4, 40, 'y'), (5, 50, 'x');
DELETE FROM t1 WHERE (a > 2 AND c = 'x') OR b = 20;
SELECT * FROM t1 ORDER BY a;
a	b	c
1	10	x
4	40	y
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 100), (2, 200), (3, 300), (4, 400), (5, 500);
DELETE FROM t1 WHERE a * b > 1000;
SELECT * FROM t1 ORDER BY a;
a	b
1	100
2	200
3	300
DROP TABLE t1;
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1), (2), (3);
DELETE FROM t1 WHERE 1 = 0;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
3
DELETE FROM t1 WHERE a > 100;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
3
DROP TABLE t1;
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1), (2), (3);
DELETE FROM t1 WHERE 1 = 1;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
0
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b VARCHAR(20));
INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three'),
(4, 'four'), (5, 'five');
DELETE FROM t1 WHERE a IN (2, 4);
SELECT * FROM t1 ORDER BY a;
a	b
1	one
3	three
5	five
DELETE FROM t1 WHERE b IN ('one', 'five');
SELECT * FROM t1 ORDER BY a;
a	b
3	three
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);
DELETE FROM t1 WHERE a BETWEEN 2 AND 4;
SELECT * FROM t1 ORDER BY a;
a	b
1	10
5	50
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, name VARCHAR(50));
INSERT INTO t1 VALUES (1, 'alice'), (2, 'bob'), (3, 'alice_jr'),
(4, 'charlie'), (5, 'albert');
DELETE FROM t1 WHERE name LIKE 'al%';
SELECT * FROM t1 ORDER BY a;
a	name
2	bob
4	charlie
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT, c VARCHAR(10));
INSERT INTO t1 VALUES (1, 10, 'foo'), (2, 20, 'bar'), (3, 30, 'foo'),
(4, 40, 'baz'), (5, 50, 'bar');
DELETE FROM t1 WHERE b > 15 AND c = 'bar';
SELECT * FROM t1 ORDER BY a;
a	b	c
1	10	foo
3	30	foo
4	40	baz
DELETE FROM t1 WHERE a >= 3 AND b <= 40;
SELECT * FROM t1 ORDER BY a;
a	b	c
1	10	foo
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY);
INSERT INTO t1 VALUES (1), (2), (3), (4), (5);
DELETE FROM t1 WHERE a NOT IN (1, 3, 5);
SELECT * FROM t1 ORDER BY a;
a
1
3
5
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b VARCHAR(20));
INSERT INTO t1 VALUES (1, '100'), (2, '200'), (3, '50');
DELETE FROM t1 WHERE b > '150';
SELECT * FROM t1 ORDER BY a;
a	b
1	100
DROP TABLE t1;
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (5, 50), (3, 30), (1, 10), (4, 40), (2, 20);
DELETE FROM t1 ORDER BY a LIMIT 2;
SELECT * FROM t1 ORDER BY a;
a	b
3	30
4	40
5	50
DELETE FROM t1 ORDER BY a DESC LIMIT 1;
SELECT * FROM t1 ORDER BY a;
a	b
3	30
4	40
DROP TABLE t1;
CREATE TABLE t1 (a INT);
DELETE FROM t1;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
0
DELETE FROM t1 WHERE a = 1;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
0
DROP TABLE t1;
CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1, NULL), (2, NULL), (3, 30), (NULL, 40), (NULL, NULL);
DELETE FROM t1 WHERE a = NULL;
SELECT COUNT(*) FROM t1;
COUNT(NULL)
5
DELETE FROM t1 WHERE a IS NULL;
SELECT * FROM t1 ORDER BY a;
a	b
1	NULL
2	NULL
3	30
DELETE FROM t1 WHERE b IS NOT NULL;
SELECT * FROM t1 ORDER BY a;
a	b
1	NULL
2	NULL
DROP TABLE t1;
