--echo # ADDTIME / SUBTIME tests

--echo # --- ADDTIME with datetime ---
SELECT ADDTIME('2024-01-01 10:00:00', '05:30:00');
SELECT ADDTIME('2024-01-01 23:00:00', '02:00:00');
SELECT ADDTIME('2024-12-31 23:30:00', '01:00:00');

--echo # --- ADDTIME with time ---
SELECT ADDTIME('10:00:00', '05:30:00');
SELECT ADDTIME('00:00:00', '12:00:00');
SELECT ADDTIME('23:59:59', '00:00:01');

--echo # --- SUBTIME with datetime ---
SELECT SUBTIME('2024-01-01 10:00:00', '05:30:00');
SELECT SUBTIME('2024-01-01 02:00:00', '03:00:00');
SELECT SUBTIME('2024-01-15 00:00:00', '00:00:01');

--echo # --- SUBTIME with time ---
SELECT SUBTIME('10:00:00', '03:00:00');
SELECT SUBTIME('01:00:00', '00:30:00');
