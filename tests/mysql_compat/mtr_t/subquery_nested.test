#
# Multi-level subquery composition tests for RooDB.
# Tests multiple subqueries working together: independent subqueries at the same
# level, subqueries inside derived tables, various combination patterns, and
# truly nested subqueries (subquery inside subquery).
#
# [RooDB-skip] Correlated subqueries — not yet supported
#

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings

CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val INT NOT NULL, grp VARCHAR(10));
INSERT INTO t1 VALUES (1, 10, 'A'), (2, 20, 'A'), (3, 30, 'B'),
                      (4, 40, 'B'), (5, 50, 'C');

CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, ref_id INT NOT NULL, amount DECIMAL(10,2));
INSERT INTO t2 VALUES (1, 1, 100.00), (2, 2, 200.00), (3, 3, 150.00),
                      (4, 4, 250.00), (5, 5, 300.00);

CREATE TABLE t3 (id INT NOT NULL PRIMARY KEY, category VARCHAR(10), active INT NOT NULL);
INSERT INTO t3 VALUES (1, 'A', 1), (2, 'B', 1), (3, 'C', 0);

--echo # --- Multiple independent scalar subqueries in SELECT ---

SELECT (SELECT MIN(val) FROM t1) AS min_v,
       (SELECT MAX(val) FROM t1) AS max_v,
       (SELECT COUNT(*) FROM t1) AS cnt,
       (SELECT SUM(val) FROM t1) AS total;

--echo # --- Multiple independent scalar subqueries in WHERE ---

# Two scalar subqueries combined with AND
SELECT id, val FROM t1
WHERE val > (SELECT MIN(val) FROM t1)
  AND val < (SELECT MAX(val) FROM t1)
ORDER BY id;

# Two scalar subqueries combined with OR
SELECT id, val FROM t1
WHERE val = (SELECT MIN(val) FROM t1)
   OR val = (SELECT MAX(val) FROM t1)
ORDER BY id;

# Three independent conditions
SELECT id, val FROM t1
WHERE val > (SELECT MIN(val) FROM t1)
  AND val < (SELECT MAX(val) FROM t1)
  AND val <> (SELECT AVG(val) FROM t1)
ORDER BY id;

--echo # --- Scalar subquery in SELECT + different scalar subquery in WHERE ---

SELECT id, val, (SELECT MAX(val) FROM t1) AS max_v
FROM t1 WHERE val > (SELECT MIN(val) FROM t1) ORDER BY id;

SELECT id, val, (SELECT SUM(amount) FROM t2) AS total_amount
FROM t1 WHERE val >= (SELECT AVG(val) FROM t1) ORDER BY id;

--echo # --- IN subquery combined with scalar subquery ---

SELECT id, val FROM t1
WHERE grp IN (SELECT category FROM t3 WHERE active = 1)
  AND val > (SELECT AVG(val) FROM t1)
ORDER BY id;

SELECT id, val FROM t1
WHERE val NOT IN (SELECT ref_id FROM t2)
  AND val >= (SELECT MIN(val) FROM t1)
ORDER BY id;

--echo # --- Subquery inside derived table ---

# Derived table that uses a scalar subquery in WHERE
SELECT * FROM (
    SELECT id, val FROM t1 WHERE val > (SELECT AVG(val) FROM t1)
) d ORDER BY d.id;

# Derived table that uses an IN subquery
SELECT * FROM (
    SELECT id, val FROM t1 WHERE grp IN (SELECT category FROM t3 WHERE active = 1)
) d ORDER BY d.id;

# Derived table with aggregation + outer scalar subquery
SELECT d.grp, d.total FROM (
    SELECT grp, SUM(val) AS total FROM t1 GROUP BY grp
) d
WHERE d.total > (SELECT AVG(val) FROM t1)
ORDER BY d.grp;

--echo # --- Derived table with IN subquery in outer WHERE ---

SELECT d.grp, d.total FROM (
    SELECT grp, SUM(val) AS total FROM t1
    WHERE grp IN (SELECT category FROM t3 WHERE active = 1)
    GROUP BY grp
) d ORDER BY d.grp;

--echo # --- Comparison with subqueries on both sides ---

SELECT (SELECT MIN(val) FROM t1) < (SELECT MAX(val) FROM t1);
SELECT (SELECT MIN(val) FROM t1) = (SELECT MAX(val) FROM t1);
SELECT (SELECT COUNT(*) FROM t1) >= (SELECT COUNT(*) FROM t2);
SELECT (SELECT SUM(val) FROM t1) > (SELECT SUM(amount) FROM t2);

--echo # --- Subquery in HAVING with separate subquery in WHERE ---

SELECT grp, COUNT(*) AS cnt, SUM(val) AS total FROM t1
WHERE val > (SELECT MIN(val) FROM t1)
GROUP BY grp
HAVING COUNT(*) >= (SELECT 2)
ORDER BY grp;

--echo # --- IN subquery in SELECT list + IN subquery in WHERE ---

SELECT id, val,
       val IN (SELECT ref_id FROM t2) AS is_ref
FROM t1
WHERE grp IN (SELECT category FROM t3 WHERE active = 1)
ORDER BY id;

--echo # --- Subquery result used in expression ---

SELECT id, val,
       val - (SELECT AVG(val) FROM t1) AS diff_avg,
       val * 100 / (SELECT SUM(val) FROM t1) AS pct
FROM t1 ORDER BY id;

--echo # --- Multi-table join with independent subquery filter ---

SELECT t1.id, t1.val, t2.amount
FROM t1 JOIN t2 ON t1.id = t2.ref_id
WHERE t1.val > (SELECT AVG(val) FROM t1)
ORDER BY t1.id;

SELECT t1.id, t1.val, t2.amount
FROM t1 JOIN t2 ON t1.id = t2.ref_id
WHERE t2.amount IN (SELECT amount FROM t2 WHERE amount > 200)
ORDER BY t1.id;

--echo # --- INSERT ... SELECT with subquery ---

CREATE TABLE t4 (id INT NOT NULL PRIMARY KEY, val INT NOT NULL);
INSERT INTO t4 SELECT id, val FROM t1
WHERE val > (SELECT AVG(val) FROM t1);
SELECT * FROM t4 ORDER BY id;
DROP TABLE t4;

--echo # --- UPDATE with scalar subquery ---

UPDATE t1 SET val = 99 WHERE id = (SELECT MAX(id) FROM t1);
SELECT * FROM t1 ORDER BY id;

--echo # --- DELETE with IN subquery ---

DELETE FROM t1 WHERE grp IN (SELECT category FROM t3 WHERE active = 0);
SELECT * FROM t1 ORDER BY id;

--echo # --- Truly nested subqueries (subquery inside subquery) ---

# Scalar subquery whose WHERE contains another scalar subquery
SELECT (SELECT MAX(val) FROM t1 WHERE val > (SELECT MIN(val) FROM t1));

# Nested subquery in outer WHERE
SELECT id, val FROM t1
WHERE val > (SELECT AVG(val) FROM t1 WHERE val > (SELECT MIN(val) FROM t1))
ORDER BY id;

# Three levels of nesting
SELECT (SELECT MAX(val) FROM t1 WHERE val > (SELECT AVG(val) FROM t1 WHERE val > (SELECT MIN(val) FROM t1)));

# IN subquery containing a scalar subquery in its WHERE
SELECT id, val FROM t1
WHERE val IN (SELECT val FROM t1 WHERE val > (SELECT AVG(val) FROM t1))
ORDER BY id;

--echo # --- Cleanup ---
DROP TABLE t1, t2, t3;
