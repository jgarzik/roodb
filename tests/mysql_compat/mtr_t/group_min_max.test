#
# Adapted from MySQL group_min_max.test for RooDB.
# Tests GROUP BY queries with MIN/MAX aggregate functions.
#
# [RooDB-skip] --source include directives
# [RooDB-skip] ENGINE= clauses
# [RooDB-skip] ANALYZE TABLE
# [RooDB-skip] EXPLAIN / explain format=tree
# [RooDB-skip] --replace_column
# [RooDB-skip] --skip_if_hypergraph
# [RooDB-skip] charset latin1 (RooDB uses utf8)
# [RooDB-skip] Table t2 with NULLs in MIN/MAX column (complex setup)
# [RooDB-skip] Table t3 (smaller columns variant)
# [RooDB-skip] HAVING with subqueries
# [RooDB-skip] Force index hints
# [RooDB-skip] Bug-specific regression tests that need specific optimizer behavior

#
# Setup: table t1 with char columns for GROUP BY / MIN / MAX
#

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
  a1 char(64), a2 char(64), b char(16), c char(16) not null, d char(16), dummy char(248) default ' '
);

insert into t1 (a1, a2, b, c, d) values
('a','a','a','a111','xy1'),('a','a','a','b111','xy2'),('a','a','a','c111','xy3'),('a','a','a','d111','xy4'),
('a','a','b','e112','xy1'),('a','a','b','f112','xy2'),('a','a','b','g112','xy3'),('a','a','b','h112','xy4'),
('a','b','a','i121','xy1'),('a','b','a','j121','xy2'),('a','b','a','k121','xy3'),('a','b','a','l121','xy4'),
('a','b','b','m122','xy1'),('a','b','b','n122','xy2'),('a','b','b','o122','xy3'),('a','b','b','p122','xy4'),
('b','a','a','a211','xy1'),('b','a','a','b211','xy2'),('b','a','a','c211','xy3'),('b','a','a','d211','xy4'),
('b','a','b','e212','xy1'),('b','a','b','f212','xy2'),('b','a','b','g212','xy3'),('b','a','b','h212','xy4'),
('b','b','a','i221','xy1'),('b','b','a','j221','xy2'),('b','b','a','k221','xy3'),('b','b','a','l221','xy4'),
('b','b','b','m222','xy1'),('b','b','b','n222','xy2'),('b','b','b','o222','xy3'),('b','b','b','p222','xy4'),
('c','a','a','a311','xy1'),('c','a','a','b311','xy2'),('c','a','a','c311','xy3'),('c','a','a','d311','xy4'),
('c','a','b','e312','xy1'),('c','a','b','f312','xy2'),('c','a','b','g312','xy3'),('c','a','b','h312','xy4'),
('c','b','a','i321','xy1'),('c','b','a','j321','xy2'),('c','b','a','k321','xy3'),('c','b','a','l321','xy4'),
('c','b','b','m322','xy1'),('c','b','b','n322','xy2'),('c','b','b','o322','xy3'),('c','b','b','p322','xy4'),
('d','a','a','a411','xy1'),('d','a','a','b411','xy2'),('d','a','a','c411','xy3'),('d','a','a','d411','xy4'),
('d','a','b','e412','xy1'),('d','a','b','f412','xy2'),('d','a','b','g412','xy3'),('d','a','b','h412','xy4'),
('d','b','a','i421','xy1'),('d','b','a','j421','xy2'),('d','b','a','k421','xy3'),('d','b','a','l421','xy4'),
('d','b','b','m422','xy1'),('d','b','b','n422','xy2'),('d','b','b','o422','xy3'),('d','b','b','p422','xy4');

# Add duplicate rows
insert into t1 (a1, a2, b, c, d) values
('a','a','a','a111','xy1'),('a','a','a','b111','xy2'),('a','a','a','c111','xy3'),('a','a','a','d111','xy4'),
('a','a','b','e112','xy1'),('a','a','b','f112','xy2'),('a','a','b','g112','xy3'),('a','a','b','h112','xy4'),
('a','b','a','i121','xy1'),('a','b','a','j121','xy2'),('a','b','a','k121','xy3'),('a','b','a','l121','xy4'),
('a','b','b','m122','xy1'),('a','b','b','n122','xy2'),('a','b','b','o122','xy3'),('a','b','b','p122','xy4'),
('b','a','a','a211','xy1'),('b','a','a','b211','xy2'),('b','a','a','c211','xy3'),('b','a','a','d211','xy4'),
('b','a','b','e212','xy1'),('b','a','b','f212','xy2'),('b','a','b','g212','xy3'),('b','a','b','h212','xy4'),
('b','b','a','i221','xy1'),('b','b','a','j221','xy2'),('b','b','a','k221','xy3'),('b','b','a','l221','xy4'),
('b','b','b','m222','xy1'),('b','b','b','n222','xy2'),('b','b','b','o222','xy3'),('b','b','b','p222','xy4'),
('c','a','a','a311','xy1'),('c','a','a','b311','xy2'),('c','a','a','c311','xy3'),('c','a','a','d311','xy4'),
('c','a','b','e312','xy1'),('c','a','b','f312','xy2'),('c','a','b','g312','xy3'),('c','a','b','h312','xy4'),
('c','b','a','i321','xy1'),('c','b','a','j321','xy2'),('c','b','a','k321','xy3'),('c','b','a','l321','xy4'),
('c','b','b','m322','xy1'),('c','b','b','n322','xy2'),('c','b','b','o322','xy3'),('c','b','b','p322','xy4'),
('d','a','a','a411','xy1'),('d','a','a','b411','xy2'),('d','a','a','c411','xy3'),('d','a','a','d411','xy4'),
('d','a','b','e412','xy1'),('d','a','b','f412','xy2'),('d','a','b','g412','xy3'),('d','a','b','h412','xy4'),
('d','b','a','i421','xy1'),('d','b','a','j421','xy2'),('d','b','a','k421','xy3'),('d','b','a','l421','xy4'),
('d','b','b','m422','xy1'),('d','b','b','n422','xy2'),('d','b','b','o422','xy3'),('d','b','b','p422','xy4');

#
# Queries without a WHERE clause
#

--sorted_result
select a1, min(a2) from t1 group by a1;
--sorted_result
select a1, max(a2) from t1 group by a1;
--sorted_result
select a1, min(a2), max(a2) from t1 group by a1;
--sorted_result
select a1, a2, b, min(c), max(c) from t1 group by a1,a2,b;
--sorted_result
select a1,a2,b,max(c),min(c) from t1 group by a1,a2,b;
# Select fields in different order
--sorted_result
select min(a2), a1, max(a2), min(a2), a1 from t1 group by a1;
--sorted_result
select a1, b, min(c), a1, max(c), b, a2, max(c), max(c) from t1 group by a1, a2, b;
--sorted_result
select min(a2) from t1 group by a1;
--sorted_result
select a2, min(c), max(c) from t1 group by a1,a2,b;

#
# Queries with WHERE over group attributes
#

--sorted_result
select a1,a2,b,min(c),max(c) from t1 where a1 < 'd' group by a1,a2,b;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where a1 >= 'b' group by a1,a2,b;
--sorted_result
select a1,a2,b,       max(c) from t1 where a1 >= 'c' or a1 < 'b' group by a1,a2,b;
--sorted_result
select a1, max(c)            from t1 where a1 >= 'c' or a1 < 'b' group by a1,a2,b;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where a1 >= 'c' or a2 < 'b' group by a1,a2,b;
--sorted_result
select a1,a2,b,       max(c) from t1 where a1 = 'z' or a1 = 'b' or a1 = 'd' group by a1,a2,b;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where a1 = 'z' or a1 = 'b' or a1 = 'd' group by a1,a2,b;
--sorted_result
select a1,a2,b,       max(c) from t1 where (a1 = 'b' or a1 = 'd' or a1 = 'a' or a1 = 'c') and (a2 > 'a') group by a1,a2,b;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where (a1 = 'b' or a1 = 'd' or a1 = 'a' or a1 = 'c') and (a2 > 'a') group by a1,a2,b;
--sorted_result
select a1,min(c),max(c)      from t1 where a1 >= 'b' group by a1,a2,b;
--sorted_result
select a1,  max(c)           from t1 where a1 in ('a','b','d') group by a1,a2,b;

#
# Queries with WHERE over non-group attributes (equalities)
#

--sorted_result
select a1,a2,b,max(c),min(c) from t1 where (a2 = 'a') and (b = 'b') group by a1;
--sorted_result
select a1,max(c),min(c)      from t1 where (a2 = 'a') and (b = 'b') group by a1;
--sorted_result
select a1,a2,b,       max(c) from t1 where (b = 'b') group by a1,a2;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where (b = 'b') group by a1,a2;
--sorted_result
select a1,a2, max(c)         from t1 where (b = 'b') group by a1,a2;

#
# Queries with WHERE over group and non-group attributes
#

--sorted_result
select a1,a2,b,min(c),max(c) from t1 where a1 = 'a' and (a2 = 'a') and (b = 'b') group by a1;
--sorted_result
select a1,a2,b,min(c),max(c) from t1 where (a1 = 'b' or a1 = 'd' or a1 = 'a' or a1 = 'c') and (a2 > 'a') and (b = 'b') group by a1;
--sorted_result
select a1,min(c),max(c) from t1 where a1 = 'a' group by a1,a2,b;

#
# Queries with COUNT
#

--sorted_result
select a1, count(a1) from t1 group by a1;
--sorted_result
select a1, a2, count(a1) from t1 group by a1, a2;
--sorted_result
select a1, a2, b, count(a1) from t1 group by a1, a2, b;

#
# Queries with MIN/MAX and COUNT combined
#

--sorted_result
select a1, min(c), max(c), count(c) from t1 group by a1;
--sorted_result
select a1, a2, min(c), max(c), count(c) from t1 group by a1, a2;

#
# Queries with HAVING
#

--sorted_result
select a1, max(c) from t1 group by a1 having a1 > 'b';
--sorted_result
select a1, min(c) from t1 group by a1 having min(c) < 'e112';
--sorted_result
select a1, a2, max(c) from t1 group by a1, a2 having max(c) > 'p122';

#
# Queries with ORDER BY
#

select a1, min(c) from t1 group by a1 order by a1;
select a1, min(c) from t1 group by a1 order by a1 desc;
select a1, min(c) from t1 group by a1 order by min(c);

#
# Queries with DISTINCT and GROUP BY
#

--sorted_result
select distinct a1 from t1;
--sorted_result
select distinct a1, a2 from t1;

drop table t1;

#
# Test with integer columns
#

create table t1 (a int, b int, c int);
insert into t1 values
(1, 10, 100), (1, 10, 200), (1, 20, 300),
(2, 10, 400), (2, 20, 500), (2, 20, 600),
(3, 30, 700), (3, 30, 800), (3, 30, 900);

--sorted_result
select a, min(b), max(b) from t1 group by a;
--sorted_result
select a, min(c), max(c) from t1 group by a;
--sorted_result
select a, b, min(c), max(c) from t1 group by a, b;
--sorted_result
select a, min(b), max(b), min(c), max(c) from t1 group by a;
--sorted_result
select a, min(b), max(c) from t1 where a > 1 group by a;
--sorted_result
select a, min(b), max(c) from t1 where b > 10 group by a;
--sorted_result
select a, count(*), min(b), max(c) from t1 group by a;

drop table t1;

--echo # End of group_min_max tests
