# Adapted from MySQL func_time.test for RooDB compatibility testing.
# Tests time functions that are implemented in RooDB.

# [RooDB-skip] TIMESTAMPADD / TIMESTAMPDIFF — not implemented in eval
# [RooDB-skip] ADDTIME / SUBTIME — not implemented in eval
# [RooDB-skip] EXTRACT — not implemented in eval
# [RooDB-skip] FROM_DAYS — not implemented in eval
# [RooDB-skip] INTERVAL arithmetic (expr + INTERVAL x UNIT) — not implemented
# [RooDB-skip] SET time_zone / SET TIMESTAMP / SET GLOBAL / SET SESSION
# [RooDB-skip] SET default_week_format / SET NAMES / SET lc_time_names
# [RooDB-skip] stored procedures / functions / triggers
# [RooDB-skip] prepared statements
# [RooDB-skip] CREATE VIEW / DROP VIEW
# [RooDB-skip] ANALYZE TABLE / EXPLAIN
# [RooDB-skip] ENGINE= hints
# [RooDB-skip] INSERT IGNORE with invalid dates
# [RooDB-skip] NOW() / CURDATE() / CURTIME() / SYSDATE() (time-dependent)
# [RooDB-skip] UTC_DATE / UTC_TIME / UTC_TIMESTAMP (time-dependent)
# [RooDB-skip] CREATE TABLE ... SELECT / SHOW CREATE TABLE / DESC
# [RooDB-skip] DO / SLEEP / user variables with :=
# [RooDB-skip] 0000-00-00 dates

#
# WEEKDAY
#
SELECT WEEKDAY('1997-11-29');

#
# PERIOD_ADD / PERIOD_DIFF
#
SELECT PERIOD_ADD('9602',-12), PERIOD_DIFF(199505,'9404');

#
# FROM_UNIXTIME / UNIX_TIMESTAMP
#
SELECT FROM_UNIXTIME(UNIX_TIMESTAMP('1994-03-02 10:11:12'));
SELECT FROM_UNIXTIME(UNIX_TIMESTAMP('1994-03-02 10:11:12'),'%Y-%m-%d %h:%i:%s');

#
# SEC_TO_TIME / TIME_TO_SEC
#
SELECT SEC_TO_TIME(9001), SEC_TO_TIME(9001)+0, TIME_TO_SEC('15:12:22');
SELECT SEC_TO_TIME(TIME_TO_SEC('-838:59:59'));

#
# DATE_FORMAT
#
SELECT DATE_FORMAT('1997-01-02 03:04:05', '%M %W %D %Y %y %m %d %h %i %s %w');
SELECT DATE_FORMAT('1997-01-02', CONCAT('%M %W %D ','%Y %y %m %d %h %i %s %w'));

#
# DAYOFMONTH
#
SELECT DAYOFMONTH('1997-01-02'), DAYOFMONTH(19970323);

#
# MONTH, YEAR, DAYOFYEAR
#
SELECT MONTH('1997-01-02'), YEAR('98-02-03'), DAYOFYEAR('1997-12-31');
SELECT DAYOFYEAR('1997-03-03'), WEEK('1998-03-03'), QUARTER(980303);
SELECT HOUR('1997-03-03 23:03:22'), MINUTE('23:03:22'), SECOND(230322);

#
# WEEK and YEARWEEK
#
SELECT WEEK(19980101), WEEK(19970101), WEEK(19980101,1), WEEK(19970101,1);
SELECT WEEK(19981231), WEEK(19971231), WEEK(19981231,1), WEEK(19971231,1);
SELECT WEEK(19950101), WEEK(19950101,1);
SELECT YEARWEEK('1981-12-31',1), YEARWEEK('1982-01-01',1), YEARWEEK('1982-12-31',1), YEARWEEK('1983-01-01',1);
SELECT YEARWEEK('1987-01-01',1), YEARWEEK('1987-01-01');

#
# DAYNAME, MONTHNAME
#
SELECT DAYNAME('1962-03-03');
SELECT MONTHNAME('1972-03-04');

#
# Table-based time function tests
#
CREATE TABLE t1 (ctime varchar(20));
INSERT INTO t1 VALUES ('2001-01-12 12:23:40');
SELECT ctime, HOUR(ctime) FROM t1;
DROP TABLE t1;

#
# STR_TO_DATE
#
SELECT STR_TO_DATE('10:00 PM', '%h:%i %p');

#
# LAST_DAY
#
SELECT LAST_DAY('2000-02-05') AS f1, LAST_DAY('2002-12-31') AS f2,
       LAST_DAY('2003-04-01') AS f4,
       LAST_DAY('2001-01-01 01:01:01') AS f5, LAST_DAY(NULL),
       LAST_DAY('2001-02-12');

SELECT LENGTH(LAST_DAY('1997-12-1'));
SELECT LAST_DAY('1997-12-1')+0;

#
# MAKEDATE
#
SELECT MAKEDATE(2024, 1);
SELECT MAKEDATE(2024, 60);

#
# MAKETIME
#
SELECT MAKETIME(10, 20, 30);
SELECT MAKETIME(0, 0, 0);

#
# TIMEDIFF
#
SELECT TIMEDIFF('2001-01-02 00:00:00', '2001-01-01 00:00:00');

#
# TO_DAYS
#
SELECT TO_DAYS('1997-01-01');
SELECT TO_DAYS('2000-01-01');

#
# DATEDIFF
#
SELECT DATEDIFF('2001-01-02', '2001-01-01');
SELECT DATEDIFF('2001-02-01', '2001-01-01');
SELECT DATEDIFF('2001-01-01', '2001-02-01');

#
# DATE_FORMAT edge cases
#
SELECT DATE_FORMAT('0000-00-11', '%W');
SELECT DATE_FORMAT('0000-00-11', '%a');
SELECT DATE_FORMAT('0000-00-11', '%w');

#
# MONTHNAME edge case
#
SELECT MONTHNAME(0), MONTHNAME(0) IS NULL;

#
# TIME_FORMAT
#
SELECT TIME_FORMAT('100:00:00', '%H %k %h %I %l');

#
# SEC_TO_TIME / TIME_TO_SEC with table
#
CREATE TABLE t1 (a int, t1 time, t2 time, d date, PRIMARY KEY (a));
INSERT INTO t1 VALUES (1, '10:00:00', NULL, NULL),
       (2, '11:00:00', '11:15:00', '1972-02-06');
SELECT t1, t2, SEC_TO_TIME( TIME_TO_SEC( t2 ) - TIME_TO_SEC( t1 ) ), QUARTER(d)
  FROM t1 ORDER BY a;
DROP TABLE t1;

#
# WEEK with STR_TO_DATE NULL
#
SELECT WEEK(STR_TO_DATE(NULL,0));

#
# DATE comparison with table
#
CREATE TABLE t1 (field DATE);
INSERT INTO t1 VALUES ('2006-11-06');
SELECT * FROM t1 WHERE field = '2006-11-06';
SELECT * FROM t1 WHERE CAST(field AS DATETIME) < '2006-11-06 04:08:36.0';
SELECT * FROM t1 WHERE CAST(field AS DATE) < '2006-11-06 04:08:36.0';
DROP TABLE t1;

#
# SEC_TO_TIME with large values
#
SELECT SEC_TO_TIME(3300000);
SELECT SEC_TO_TIME(3300000)+0;
SELECT TIME_TO_SEC('916:40:00');

#
# MAKETIME edge case
#
SELECT MAKETIME(916,0,0);

#
# MONTHNAME with STR_TO_DATE
#
SELECT MONTHNAME(STR_TO_DATE(NULL, '%m')), MONTHNAME(STR_TO_DATE(NULL, '%m')),
       MONTHNAME(STR_TO_DATE(1, '%m')), MONTHNAME(STR_TO_DATE(0, '%m'));

#
# FROM_UNIXTIME with special values
#
SELECT FROM_UNIXTIME(-1);
SELECT FROM_UNIXTIME(0);

#
# DATE_ADD / DATE_SUB
#
SELECT DATE_ADD('2020-01-01', INTERVAL 1 DAY);
SELECT DATE_ADD('2020-01-31', INTERVAL 1 MONTH);
SELECT DATE_ADD('2020-02-29', INTERVAL 1 YEAR);
SELECT DATE_ADD('2020-01-01 10:00:00', INTERVAL 3 HOUR);
SELECT DATE_ADD('2020-01-01 23:59:59', INTERVAL 1 SECOND);
SELECT DATE_ADD('2020-01-01', INTERVAL 2 WEEK);
SELECT DATE_ADD('2020-01-31', INTERVAL 1 QUARTER);
SELECT DATE_SUB('2020-01-01', INTERVAL 1 DAY);
SELECT DATE_SUB('2020-03-31', INTERVAL 1 MONTH);

#
# ADDDATE / SUBDATE aliases
#
SELECT ADDDATE('2020-06-15', INTERVAL 10 DAY);
SELECT SUBDATE('2020-06-15', INTERVAL 10 DAY);

#
# DATE_ADD with NULL
#
SELECT DATE_ADD(NULL, INTERVAL 1 DAY);
SELECT DATE_ADD('2020-01-01', INTERVAL NULL DAY);
