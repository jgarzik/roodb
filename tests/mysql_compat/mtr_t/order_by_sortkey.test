#
# ORDER BY with various sort keys
# Adapted from MySQL order_by_sortkey.test for RooDB compatibility
# Removed: TEMPORARY TABLE, SET sort_buffer_size, FLUSH STATUS, SHOW SESSION STATUS,
#          EXPLAIN, let/eval variables, BINARY/BLOB columns, charset, hex literals,
#          UNIQUE KEY, TIMESTAMP(6), DATE literal, @variables, subquery with ORDER BY
#

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

#
# Test ORDER BY with LIMIT on a table with many rows
# Use explicit f0 values to avoid auto_increment non-determinism
#
CREATE TABLE t1(
  f0 int PRIMARY KEY,
  f1 int,
  f2 varchar(200)
);

INSERT INTO t1(f0, f1, f2) VALUES
(1,0,"0"),(2,1,"1"),(3,2,"2"),(4,3,"3"),(5,4,"4"),(6,5,"5"),
(7,6,"6"),(8,7,"7"),(9,8,"8"),(10,9,"9"),(11,10,"10"),
(12,11,"11"),(13,12,"12"),(14,13,"13"),(15,14,"14"),(16,15,"15"),
(17,16,"16"),(18,17,"17"),(19,18,"18"),(20,19,"19"),(21,20,"20"),
(22,21,"21"),(23,22,"22"),(24,23,"23"),(25,24,"24"),(26,25,"25"),
(27,26,"26"),(28,27,"27"),(29,28,"28"),(30,29,"29"),(31,30,"30"),
(32,31,"31"),(33,32,"32"),(34,33,"33"),(35,34,"34"),(36,35,"35"),
(37,36,"36"),(38,37,"37"),(39,38,"38"),(40,39,"39"),(41,40,"40"),
(42,41,"41"),(43,42,"42"),(44,43,"43"),(45,44,"44"),(46,45,"45"),
(47,46,"46"),(48,47,"47"),(49,48,"48"),(50,49,"49"),(51,50,"50"),
(52,51,"51"),(53,52,"52"),(54,53,"53"),(55,54,"54"),(56,55,"55"),
(57,56,"56"),(58,57,"57"),(59,58,"58"),(60,59,"59"),(61,60,"60"),
(62,61,"61"),(63,62,"62"),(64,63,"63"),(65,64,"64"),(66,65,"65"),
(67,66,"66"),(68,67,"67"),(69,68,"68"),(70,69,"69"),(71,70,"70"),
(72,71,"71"),(73,72,"72"),(74,73,"73"),(75,74,"74"),(76,75,"75"),
(77,76,"76"),(78,77,"77"),(79,78,"78"),(80,79,"79"),(81,80,"80"),
(82,81,"81"),(83,82,"82"),(84,83,"83"),(85,84,"84"),(86,85,"85"),
(87,86,"86"),(88,87,"87"),(89,88,"88"),(90,89,"89"),(91,90,"90"),
(92,91,"91"),(93,92,"92"),(94,93,"93"),(95,94,"94"),(96,95,"95"),
(97,96,"96"),(98,97,"97"),(99,98,"98"),(100,99,"99");

# [RooDB-skip] TEMPORARY TABLE and bulk data multiplication
# [RooDB-skip] SET sort_buffer_size, FLUSH STATUS, SHOW SESSION STATUS

# Test ORDER BY on varchar column with LIMIT
SELECT * FROM t1 ORDER BY f2, f0 LIMIT 10;

# Test ORDER BY on int column
SELECT * FROM t1 ORDER BY f1, f0 LIMIT 10;

# Test ORDER BY DESC with LIMIT
SELECT * FROM t1 ORDER BY f2 DESC, f0 DESC LIMIT 10;

# Test ORDER BY with WHERE clause
SELECT * FROM t1 WHERE f1 > 90 ORDER BY f2;

# [RooDB-skip] Subquery with ORDER BY LIMIT — correlated subquery not supported
# [RooDB-skip] Bug#32038406 section — BINARY/BLOB/TIMESTAMP(6)/UNIQUE KEY/hex literals
# [RooDB-skip] latin1 charset / DATE literal / @variable sections

DROP TABLE t1;

#
# Test ORDER BY with expressions
#
CREATE TABLE t2(vc VARCHAR(20));
INSERT INTO t2 VALUES('2021-02-08'), ('21-02-08');

# String const in WHERE with ORDER BY
SELECT * FROM t2 WHERE vc = '2021-02-08' ORDER BY vc ASC;
SELECT * FROM t2 WHERE vc = '2021-02-08' ORDER BY vc DESC;

DROP TABLE t2;
