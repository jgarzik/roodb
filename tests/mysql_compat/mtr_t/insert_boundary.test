#
# Custom test for RooDB: INSERT edge cases and boundary conditions.
# Tests INSERT with default values, INSERT with expressions,
# duplicate handling, type boundaries, multi-row INSERT.
#

DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;

#
# INSERT with DEFAULT values
#

CREATE TABLE t1 (
  id INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(50) DEFAULT 'unnamed',
  score INT DEFAULT 0,
  active TINYINT DEFAULT 1
);

INSERT INTO t1 (name) VALUES ('Alice');
INSERT INTO t1 (score) VALUES (100);
INSERT INTO t1 (name, score) VALUES ('Bob', 85);
INSERT INTO t1 () VALUES ();

SELECT name, score, active FROM t1 ORDER BY name, score;

DROP TABLE t1;

#
# Multi-row INSERT
#

CREATE TABLE t1 (a INT, b VARCHAR(10));

INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three');
SELECT * FROM t1 ORDER BY a;

INSERT INTO t1 VALUES (4, 'four'), (5, 'five'), (6, 'six'), (7, 'seven'), (8, 'eight');
SELECT COUNT(*) FROM t1;
SELECT * FROM t1 ORDER BY a;

DROP TABLE t1;

#
# INSERT with type boundaries - INT
#

CREATE TABLE t1 (
  ti TINYINT,
  si SMALLINT,
  i INT,
  bi BIGINT
);

INSERT INTO t1 VALUES (127, 32767, 2147483647, 9223372036854775807);
INSERT INTO t1 VALUES (-128, -32768, -2147483648, -9223372036854775808);
INSERT INTO t1 VALUES (0, 0, 0, 0);
INSERT INTO t1 VALUES (1, 1, 1, 1);
INSERT INTO t1 VALUES (-1, -1, -1, -1);

SELECT * FROM t1 ORDER BY ti, si, i, bi;

DROP TABLE t1;

#
# INSERT with type boundaries - UNSIGNED
#

CREATE TABLE t1 (
  tu TINYINT UNSIGNED,
  su SMALLINT UNSIGNED,
  iu INT UNSIGNED,
  bu BIGINT UNSIGNED
);

INSERT INTO t1 VALUES (0, 0, 0, 0);
INSERT INTO t1 VALUES (255, 65535, 4294967295, 18446744073709551615);
INSERT INTO t1 VALUES (1, 1, 1, 1);

SELECT * FROM t1 ORDER BY tu;

DROP TABLE t1;

#
# INSERT with expressions
#

CREATE TABLE t1 (a INT, b INT, c VARCHAR(20));

INSERT INTO t1 VALUES (1+1, 2*3, CONCAT('hello', ' ', 'world'));
INSERT INTO t1 VALUES (ABS(-5), MOD(10, 3), UPPER('test'));
INSERT INTO t1 VALUES (GREATEST(1,2,3), LEAST(4,5,6), SUBSTRING('abcdef', 2, 3));

SELECT * FROM t1 ORDER BY a;

DROP TABLE t1;

#
# INSERT with NULL in NOT NULL column (should error)
#

CREATE TABLE t1 (a INT NOT NULL, b VARCHAR(10) NOT NULL);

INSERT INTO t1 VALUES (1, 'ok');
--error 1048
INSERT INTO t1 VALUES (NULL, 'bad');
--error 1048
INSERT INTO t1 VALUES (1, NULL);

SELECT * FROM t1;

DROP TABLE t1;

#
# INSERT with duplicate primary key (should error)
#

CREATE TABLE t1 (id INT PRIMARY KEY, name VARCHAR(20));

INSERT INTO t1 VALUES (1, 'first');
--error 1062
INSERT INTO t1 VALUES (1, 'duplicate');

SELECT * FROM t1;

DROP TABLE t1;

#
# [RooDB-skip] INSERT with duplicate unique key -- non-PK UNIQUE constraint
# enforcement not yet implemented.
#

#
# INSERT ... SELECT
#

CREATE TABLE t1 (a INT, b VARCHAR(10));
INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three');

CREATE TABLE t2 (x INT, y VARCHAR(10));
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY x;

INSERT INTO t2 SELECT a + 10, UPPER(b) FROM t1;
SELECT * FROM t2 ORDER BY x;

DROP TABLE t1, t2;

#
# INSERT with string/number conversions
#

CREATE TABLE t1 (a INT, b DECIMAL(10,2), c VARCHAR(20));

INSERT INTO t1 VALUES ('5', '3.14', 42);
INSERT INTO t1 VALUES ('10', '2.718', 100);

SELECT * FROM t1 ORDER BY a;
SELECT a + 1, b + 1.0, CONCAT(c, '_suffix') FROM t1 ORDER BY a;

DROP TABLE t1;

#
# INSERT empty string vs NULL
#

CREATE TABLE t1 (a VARCHAR(10), b VARCHAR(10));

INSERT INTO t1 VALUES ('', NULL);
INSERT INTO t1 VALUES (NULL, '');
INSERT INTO t1 VALUES ('', '');
INSERT INTO t1 VALUES (NULL, NULL);

SELECT a, b, a IS NULL, b IS NULL, a = '', b = '' FROM t1 ORDER BY a IS NULL, b IS NULL;

DROP TABLE t1;

--echo # End of insert_boundary tests
