#
# Custom test for RooDB: NULL handling in various expression contexts.
# Tests COALESCE, NULLIF, IFNULL, NULL arithmetic, NULL comparisons,
# NULL in aggregates, and NULL in CASE/WHEN.
#

DROP TABLE IF EXISTS t1;

#
# NULL arithmetic
#

SELECT NULL + 1;
SELECT NULL - 1;
SELECT NULL * 1;
SELECT NULL / 1;
SELECT NULL % 1;
SELECT NULL + NULL;
SELECT 1 + NULL;
SELECT 1 * NULL;

#
# NULL comparisons
#

SELECT NULL = NULL;
SELECT NULL != NULL;
SELECT NULL <> NULL;
SELECT NULL < NULL;
SELECT NULL > NULL;
SELECT NULL <= NULL;
SELECT NULL >= NULL;
SELECT NULL <=> NULL;
SELECT NULL <=> 1;
SELECT 1 <=> NULL;
SELECT NULL IS NULL;
SELECT NULL IS NOT NULL;
SELECT 1 IS NULL;
SELECT 1 IS NOT NULL;
SELECT 0 IS NULL;

#
# COALESCE with NULLs
#

SELECT COALESCE(NULL);
SELECT COALESCE(NULL, NULL);
SELECT COALESCE(NULL, 1);
SELECT COALESCE(NULL, NULL, 2);
SELECT COALESCE(3, NULL, 2);
SELECT COALESCE(NULL, NULL, NULL, 'found');

#
# IFNULL
#

SELECT IFNULL(NULL, 0);
SELECT IFNULL(1, 0);
SELECT IFNULL(NULL, 'default');
SELECT IFNULL('value', 'default');
SELECT IFNULL(NULL, NULL);

#
# NULLIF
#

SELECT NULLIF(1, 1);
SELECT NULLIF(1, 2);
SELECT NULLIF('a', 'a');
SELECT NULLIF('a', 'b');
SELECT NULLIF(NULL, 1);
SELECT NULLIF(1, NULL);

#
# NULL in CASE/WHEN
#

SELECT CASE NULL WHEN NULL THEN 'match' ELSE 'no match' END;
SELECT CASE WHEN NULL THEN 'true' ELSE 'false' END;
SELECT CASE WHEN NULL IS NULL THEN 'null is null' ELSE 'wrong' END;
SELECT CASE WHEN 1 = NULL THEN 'equal' ELSE 'not equal' END;

#
# NULL in table operations
#

CREATE TABLE t1 (a INT, b VARCHAR(20), c DECIMAL(10,2));
INSERT INTO t1 VALUES (1, 'hello', 1.50);
INSERT INTO t1 VALUES (NULL, NULL, NULL);
INSERT INTO t1 VALUES (3, 'world', 3.50);
INSERT INTO t1 VALUES (NULL, 'test', 2.00);
INSERT INTO t1 VALUES (5, NULL, NULL);

SELECT a, COALESCE(a, 0) AS a_or_0 FROM t1 ORDER BY COALESCE(a, 999);
SELECT b, IFNULL(b, 'N/A') AS b_or_na FROM t1 ORDER BY COALESCE(a, 999);
SELECT a, b, NULLIF(a, 3) AS nullif_a3 FROM t1 ORDER BY COALESCE(a, 999);

#
# NULL with aggregates
#

SELECT COUNT(*), COUNT(a), COUNT(b), COUNT(c) FROM t1;
SELECT SUM(a), AVG(a), MIN(a), MAX(a) FROM t1;
SELECT SUM(c), AVG(c), MIN(c), MAX(c) FROM t1;

#
# NULL in GROUP BY
#

SELECT a, COUNT(*) AS cnt FROM t1 GROUP BY a ORDER BY COALESCE(a, 999);

#
# NULL with DISTINCT
#

SELECT DISTINCT a FROM t1 ORDER BY COALESCE(a, 999);
SELECT DISTINCT b FROM t1 ORDER BY COALESCE(b, 'zzz');

#
# NULL with IN
#

SELECT a FROM t1 WHERE a IN (1, 3, NULL) ORDER BY a;
SELECT a FROM t1 WHERE a NOT IN (1, 3) ORDER BY COALESCE(a, 999);

#
# NULL with BETWEEN
#

SELECT a FROM t1 WHERE a BETWEEN 1 AND 5 ORDER BY a;
SELECT a FROM t1 WHERE a NOT BETWEEN 1 AND 3 ORDER BY a;

#
# NULL with LIKE
#

SELECT b FROM t1 WHERE b LIKE 'h%' ORDER BY b;
SELECT b FROM t1 WHERE b IS NULL;

#
# Nested COALESCE/IFNULL/NULLIF
#

SELECT COALESCE(NULLIF(1, 1), IFNULL(NULL, 42));
SELECT IFNULL(NULLIF(1, 2), 99);
SELECT COALESCE(NULL, NULLIF(5, 5), IFNULL(NULL, 10));

DROP TABLE t1;

--echo # End of null_expr tests
