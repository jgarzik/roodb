--echo # Real-world application patterns

--echo # --- ORM pagination ---
CREATE TABLE users (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(50), age INT);
INSERT INTO users (name, age) VALUES ('alice',30),('bob',25),('carol',35),('dave',28),('eve',22);
SELECT name, age FROM users ORDER BY name LIMIT 2 OFFSET 2;
DROP TABLE users;

--echo # --- JOIN with aggregate ---
CREATE TABLE users (id INT PRIMARY KEY, name VARCHAR(50));
CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, amount DECIMAL(10,2));
INSERT INTO users VALUES (1,'alice'),(2,'bob');
INSERT INTO orders VALUES (1,1,99.99),(2,1,49.50),(3,2,75.00);
SELECT u.name, SUM(o.amount) as total FROM users u JOIN orders o ON u.id = o.user_id GROUP BY u.name ORDER BY u.name;
DROP TABLE users, orders;

--echo # --- CTE + Window ---
CREATE TABLE t1 (id INT, val INT);
INSERT INTO t1 VALUES (1,10),(2,20),(3,30);
WITH ranked AS (SELECT id, val, ROW_NUMBER() OVER (ORDER BY val DESC) as rn FROM t1)
SELECT * FROM ranked WHERE rn <= 2 ORDER BY rn;
DROP TABLE t1;

--echo # --- JSON CRUD ---
CREATE TABLE docs (id INT PRIMARY KEY, data JSON);
INSERT INTO docs VALUES (1, '{"name":"alice","tags":["admin"]}');
SELECT JSON_EXTRACT(data, '$.name') FROM docs;
UPDATE docs SET data = JSON_SET(data, '$.age', 30) WHERE id = 1;
SELECT JSON_EXTRACT(data, '$.age') FROM docs;
DROP TABLE docs;

--echo # --- Multi-table 3-way JOIN ---
CREATE TABLE users (id INT PRIMARY KEY, name VARCHAR(50));
CREATE TABLE products (id INT PRIMARY KEY, name VARCHAR(50), price DECIMAL(10,2));
CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, product_id INT, qty INT);
INSERT INTO users VALUES (1,'alice'),(2,'bob');
INSERT INTO products VALUES (1,'Widget',9.99),(2,'Gadget',24.99);
INSERT INTO orders VALUES (1,1,1,2),(2,1,2,1),(3,2,1,3);
SELECT u.name, p.name as product, o.qty, p.price * o.qty as total
  FROM orders o JOIN users u ON o.user_id = u.id JOIN products p ON o.product_id = p.id
  ORDER BY o.id;
DROP TABLE orders, users, products;

--echo # --- Complex boolean WHERE ---
CREATE TABLE products (id INT, name VARCHAR(50), price DECIMAL(10,2), category VARCHAR(20));
INSERT INTO products VALUES (1,'Widget',9.99,'A'),(2,'Gadget',24.99,'B'),(3,'Thing',4.99,'A'),(4,'Stuff',14.99,'B');
SELECT * FROM products WHERE (category = 'A' AND price < 10) OR (category = 'B' AND price > 20) ORDER BY id;
DROP TABLE products;

--echo # --- Correlated subquery with aggregate ---
CREATE TABLE employees (id INT, dept INT, salary INT);
INSERT INTO employees VALUES (1,1,50000),(2,1,60000),(3,2,70000),(4,2,55000);
SELECT id, dept, salary FROM employees e
  WHERE salary > (SELECT AVG(salary) FROM employees WHERE dept = e.dept)
  ORDER BY id;
DROP TABLE employees;
