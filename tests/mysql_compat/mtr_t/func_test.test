CREATE TABLE t1 (a DOUBLE, b DOUBLE);
CREATE TABLE t2 (a INTEGER, b INTEGER);

INSERT INTO t1 values(1, NULL), (1, 1);
INSERT INTO t2 values(1, NULL), (1, 1);

SELECT SUM(LEAST(a, b)) FROM t1;
SELECT SUM(LEAST(a, b)) FROM t2;

DROP TABLE t1, t2;

