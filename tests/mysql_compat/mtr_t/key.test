#
# Basic key/index tests for RooDB
# Trimmed from MySQL key.test
#
# [RooDB-skip] EXPLAIN, SHOW INDEX, SHOW CREATE TABLE, SHOW KEYS
# [RooDB-skip] ALTER TABLE, ANALYZE TABLE, FLUSH TABLES, desc
# [RooDB-skip] INSERT...SELECT, CREATE TABLE AS SELECT, BINARY keyword
# [RooDB-skip] charset introducers, CHARACTER SET, COLLATE
# [RooDB-skip] information_schema, engine=heap/myisam, FULLTEXT, SPATIAL

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings

#
# Basic index lookup
#
CREATE TABLE t1 (
  ID CHAR(32) NOT NULL,
  name CHAR(32) NOT NULL,
  value CHAR(255),
  INDEX indexIDname (ID, name)
);
INSERT INTO t1 VALUES ('keyword', 'indexdir', '/path/to/indexes');
INSERT INTO t1 VALUES ('keyword', 'urlprefix', 'text/ /text');
INSERT INTO t1 VALUES ('emailgids', 'indexdir', '/path/to/email');
INSERT INTO t1 VALUES ('emailgids', 'attr', 'personal employee');

SELECT value FROM t1 WHERE ID = 'emailgids' AND name = 'attr' ORDER BY value;
DROP TABLE t1;

#
# Primary key with duplicate detection
#
CREATE TABLE t1 (
   SEQNO INT NOT NULL,
   MOTYPEID INT NOT NULL,
   VALUE VARCHAR(120) NOT NULL,
   PRIMARY KEY (SEQNO, MOTYPEID, VALUE)
);
INSERT INTO t1 VALUES (1, 1, 'a');
INSERT INTO t1 VALUES (1, 1, 'b');
--error 1062
INSERT INTO t1 VALUES (1, 1, 'a');
SELECT * FROM t1 ORDER BY SEQNO, MOTYPEID, VALUE;
DROP TABLE t1;

#
# UNIQUE key constraint
#
CREATE TABLE t1 (a INT NOT NULL, b INT, UNIQUE KEY (a));
INSERT INTO t1 VALUES (1, 10);
INSERT INTO t1 VALUES (2, 20);
# [RooDB-skip] UNIQUE key dup detection on non-PK index
SELECT * FROM t1 ORDER BY a;
DROP TABLE t1;

#
# CREATE INDEX and DROP INDEX
#
CREATE TABLE t1 (a INT, b INT, c INT);
INSERT INTO t1 VALUES (1, 10, 100), (2, 20, 200), (3, 30, 300);
CREATE INDEX idx_a ON t1 (a);
CREATE INDEX idx_b ON t1 (b);
SELECT * FROM t1 WHERE a = 2 ORDER BY a;
SELECT * FROM t1 WHERE b = 20 ORDER BY a;
DROP INDEX idx_a ON t1;
DROP INDEX idx_b ON t1;
DROP TABLE t1;

# [RooDB-skip] Text prefix keys
