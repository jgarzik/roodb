#
# Adapted from MySQL varbinary.test for RooDB.
# Tests VARBINARY/BINARY types and hex literal behavior.
# Removed: --source includes, ANALYZE TABLE, EXPLAIN, --error, SHOW CREATE TABLE,
#   stored procedures, prepared statements, views, --enable_metadata,
#   _binary prefix expressions, datetime/BIT_OR complex sections, FLOAT(m,d), zerofill,
#   hex literal arithmetic (0x41+0 — RooDB treats hex as Bytes, not integers),
#   0b binary literals (not recognized), cross-type bitwise ops,
#   bitwise ops on VARBINARY columns (~b, b<<1, etc.)
#

--disable_warnings
drop table if exists t1;
--enable_warnings

#
# varbinary as string
#
# [RooDB-skip] select 0x41,0x41+0,... — hex literal arithmetic not supported (Bytes type)
# [RooDB-skip] select 0x31+1,concat(0x31)+1,-0xf — hex literal arithmetic not supported
# [RooDB-skip] select x'31',X'ffff'+0 — hex+0 not supported

select 0x41;
select x'31';

#
# Test of hex constants in WHERE:
#
# [RooDB-skip] CREATE TABLE with zerofill/display width — not supported
# [RooDB-skip] analyze table / explain — not supported

#
# Test error conditions
#
# [RooDB-skip] --error ER_PARSE_ERROR select x'hello' — error tests
# [RooDB-skip] --error ER_BAD_FIELD_ERROR select 0xfg — error tests

#
# Test likely error conditions
#
create table t1 (x INT, xx INT);
insert into t1 values (1, 2);
select x,xx from t1;
drop table t1;

# End of 4.1 tests

# [RooDB-skip] Bug#28127 — column names starting with 0b — not standard SQL
# [RooDB-skip] show create table — not supported

#
# Bug#35658 simplified: binary/hex literals
#

# [RooDB-skip] select 0b01000001 — binary literal 0b prefix not recognized as value
select b'01000001';

select 0x41;

select x'41';

# [RooDB-skip] select x'41', 0+x'41' — cannot add Bytes and Int
# [RooDB-skip] select N'abc' — NATIONAL char not supported

select '', length('');

select b'', 0+b'';

# [RooDB-skip] select x'', 0+x'' — cannot add Int and Bytes

# [RooDB-skip] --error select 0x; — error test
# [RooDB-skip] --error select 0b; — error test


create TABLE t1(a INT, b VARBINARY(4), c VARBINARY(4));
INSERT INTO t1 VALUES
(1, 0x31393831, 0x31303037),
(2, 0x31393832, 0x31303038),
(3, 0x31393833, 0x31303039),
(3, 0x31393834, 0x31393831),
(4, 0x31393835, 0x31393832),
(5, 0x31393836, 0x31303038);

--echo #
--echo # HEX of varbinary columns
--echo #

SELECT HEX(b), HEX(c) FROM t1;

# [RooDB-skip] BIT_COUNT(b), HEX(~b), HEX(b << 1), HEX(b >> 1) — bitwise NOT/shift on VARBINARY not supported
# [RooDB-skip] HEX(BIT_AND(b)), HEX(BIT_OR(b)), HEX(BIT_XOR(b)) — aggregate bit ops on VARBINARY return 0/NULL

# [RooDB-skip] stored procedures — not supported
# [RooDB-skip] prepared statements — not supported
# [RooDB-skip] views — not supported

--echo #
--echo # integer bit operations (no VARBINARY involved)
--echo #

# [RooDB-skip] a & 0x31393838 — cross-type INT & Bytes bitwise op not supported
# [RooDB-skip] a | 0x31393838 — cross-type bitwise op not supported
# [RooDB-skip] a ^ 0x31393838 — cross-type bitwise op not supported

SELECT a, BIT_AND(a), BIT_OR(a), BIT_XOR(a) FROM t1 GROUP BY a ORDER BY a;
SELECT ~NULL, NULL << 1, NULL >> 1, 1 << NULL, 1 >> NULL;

# [RooDB-skip] ~0x31393838 — bitwise NOT on Bytes not supported
# [RooDB-skip] ~0b1011 — 0b binary literal not recognized
# [RooDB-skip] binary/varbinary vs char/varchar metadata checks
# [RooDB-skip] PREPARE ps FROM ... — prepared statements
# [RooDB-skip] Testing datetime and time — DATEDIFF/SUBTIME with _binary
# [RooDB-skip] Test conversions — FLOAT(5,2), DOUBLE(5,2), BIT_OR on varbinary

DROP TABLE t1;
