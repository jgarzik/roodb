#
# Basic subquery tests (trimmed for RooDB)
#

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
--enable_warnings

--echo # Scalar subquery in SELECT list
CREATE TABLE t1 (a INT NOT NULL, b INT NOT NULL, PRIMARY KEY (a));
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);
SELECT (SELECT MAX(a) FROM t1);
SELECT (SELECT MIN(b) FROM t1);
SELECT (SELECT COUNT(*) FROM t1);

--echo # Scalar subquery in WHERE clause
SELECT a, b FROM t1 WHERE b = (SELECT MAX(b) FROM t1);
SELECT a, b FROM t1 WHERE b > (SELECT MIN(b) FROM t1) ORDER BY a;

--echo # Scalar subquery alongside columns
SELECT a, (SELECT MAX(b) FROM t1) FROM t1 ORDER BY a;

--echo # IN subquery
CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, ref_val INT NOT NULL);
INSERT INTO t2 VALUES (1, 10), (2, 30);
SELECT a, b FROM t1 WHERE b IN (SELECT ref_val FROM t2) ORDER BY a;
SELECT a, b FROM t1 WHERE b NOT IN (SELECT ref_val FROM t2) ORDER BY a;

--echo # Scalar subquery from empty table
DROP TABLE t1;
CREATE TABLE t1 (a INT NOT NULL PRIMARY KEY);
SELECT (SELECT MAX(a) FROM t1);

DROP TABLE t1;
DROP TABLE t2;
