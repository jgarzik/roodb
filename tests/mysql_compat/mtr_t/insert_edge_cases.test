#
# INSERT edge cases.
# Tests multi-row INSERT, INSERT with expressions, INSERT with DEFAULT,
# INSERT...SELECT with transformations, boundary values, and type coercions.
#

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3, t4;
--enable_warnings

--echo # --- Multi-row INSERT ---

CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val VARCHAR(20));
INSERT INTO t1 VALUES (1,'a'), (2,'b'), (3,'c'), (4,'d'), (5,'e');
SELECT * FROM t1 ORDER BY id;

--echo # --- INSERT with expressions in VALUES ---

CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, computed INT NOT NULL, label VARCHAR(50));
INSERT INTO t2 VALUES (1, 10 + 20, CONCAT('item-', 'one'));
INSERT INTO t2 VALUES (2, 100 * 2, UPPER('hello'));
INSERT INTO t2 VALUES (3, ABS(-42), REPLACE('foo_bar', '_', '-'));
SELECT * FROM t2 ORDER BY id;

--echo # --- INSERT with NULL in non-PK columns ---

CREATE TABLE t3 (id INT NOT NULL PRIMARY KEY, a INT, b VARCHAR(20), c DECIMAL(10,2));
INSERT INTO t3 VALUES (1, NULL, NULL, NULL);
INSERT INTO t3 VALUES (2, 10, NULL, 3.14);
INSERT INTO t3 VALUES (3, NULL, 'hello', NULL);
SELECT * FROM t3 ORDER BY id;

--echo # --- INSERT with DEFAULT values ---

DROP TABLE IF EXISTS t4;
CREATE TABLE t4 (
    id INT NOT NULL PRIMARY KEY,
    status VARCHAR(20) NOT NULL DEFAULT 'active',
    priority INT NOT NULL DEFAULT 0,
    score DECIMAL(5,2) NOT NULL DEFAULT 0.00
);
INSERT INTO t4 (id) VALUES (1);
INSERT INTO t4 (id, status) VALUES (2, 'pending');
INSERT INTO t4 (id, priority) VALUES (3, 5);
INSERT INTO t4 VALUES (4, 'done', 10, 99.99);
SELECT * FROM t4 ORDER BY id;

--echo # --- INSERT...SELECT ---

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val VARCHAR(20));
INSERT INTO t1 VALUES (1,'one'), (2,'two'), (3,'three');

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, val VARCHAR(20));
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY id;

--echo # --- INSERT...SELECT with transformation ---

DROP TABLE IF EXISTS t3;
CREATE TABLE t3 (id INT NOT NULL PRIMARY KEY, upper_val VARCHAR(20));
INSERT INTO t3 SELECT id, UPPER(val) FROM t1;
SELECT * FROM t3 ORDER BY id;

--echo # --- INSERT...SELECT with WHERE ---

DROP TABLE IF EXISTS t3;
CREATE TABLE t3 (id INT NOT NULL PRIMARY KEY, val VARCHAR(20));
INSERT INTO t3 SELECT * FROM t1 WHERE id >= 2;
SELECT * FROM t3 ORDER BY id;

--echo # --- INSERT...SELECT with aggregate ---

DROP TABLE IF EXISTS t3;
CREATE TABLE t3 (cnt INT NOT NULL, total_id INT NOT NULL);
INSERT INTO t3 SELECT COUNT(*), SUM(id) FROM t1;
SELECT * FROM t3;

--echo # --- Type boundary values: INT ---

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val BIGINT);
INSERT INTO t1 VALUES (1, 0);
INSERT INTO t1 VALUES (2, -1);
INSERT INTO t1 VALUES (3, 2147483647);
INSERT INTO t1 VALUES (4, -2147483648);
SELECT * FROM t1 ORDER BY id;

--echo # --- Type boundary values: DECIMAL ---

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, val DECIMAL(10,2));
INSERT INTO t2 VALUES (1, 0.00);
INSERT INTO t2 VALUES (2, -99999999.99);
INSERT INTO t2 VALUES (3, 99999999.99);
INSERT INTO t2 VALUES (4, 0.01);
INSERT INTO t2 VALUES (5, -0.01);
SELECT * FROM t2 ORDER BY id;

--echo # --- INSERT with string-to-number coercion ---

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, '42');
INSERT INTO t1 VALUES (2, '0');
SELECT * FROM t1 ORDER BY id;

--echo # --- INSERT empty string into VARCHAR ---

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (id INT NOT NULL PRIMARY KEY, val VARCHAR(50) NOT NULL);
INSERT INTO t2 VALUES (1, '');
INSERT INTO t2 VALUES (2, 'notempty');
SELECT id, val, LENGTH(val) AS len FROM t2 ORDER BY id;

--echo # --- INSERT duplicate key should fail ---

DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (id INT NOT NULL PRIMARY KEY, val VARCHAR(20));
INSERT INTO t1 VALUES (1, 'first');
--error 1062
INSERT INTO t1 VALUES (1, 'duplicate');
SELECT * FROM t1 ORDER BY id;

--echo # --- Cleanup ---
DROP TABLE IF EXISTS t1, t2, t3, t4;
