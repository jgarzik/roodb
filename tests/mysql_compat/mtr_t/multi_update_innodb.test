#
# Adapted from MySQL multi_update_innodb.test for RooDB.
# Tests multi-table JOIN queries with aggregates and complex WHERE conditions.
# Original multi-table UPDATE syntax (UPDATE t1,t2 SET ...) is not supported
# by RooDB, so we test the JOIN/WHERE/aggregate patterns from those test
# scenarios using SELECT queries instead.
#
# Removed: ENGINE=InnoDB, VIEW, UPDATE IGNORE, EXPLAIN, ANALYZE TABLE,
#   multi-table UPDATE syntax, NATURAL JOIN, --error directives,
#   SET sql_buffer_result
#

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
--enable_warnings

--echo #
--echo # Multi-table JOIN with aggregate on empty result
--echo #

CREATE TABLE t1 (
  pk INT,
  a INT,
  b INT,
  PRIMARY KEY (pk)
);
INSERT INTO t1 VALUES (0,0,0);

CREATE TABLE t2 (
  pk INT,
  a INT,
  b INT,
  PRIMARY KEY (pk)
);
INSERT INTO t2 VALUES (1,1,1);

# Cross join: 1 row x 1 row = 1 row
SELECT COUNT(*) FROM t1, t2;

# No matching condition = empty result
SELECT t1.pk, t2.pk FROM t1 JOIN t2 ON t1.pk = t2.pk;
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.pk = t2.pk;

# Aggregates on empty JOIN result
SELECT MIN(t1.a), MAX(t2.b) FROM t1 JOIN t2 ON t1.pk = t2.pk;
SELECT SUM(t1.a + t2.b) FROM t1 JOIN t2 ON t1.pk = t2.pk;

DROP TABLE t1, t2;

--echo #
--echo # Multi-table JOIN with composite primary key
--echo #

CREATE TABLE t1 (
  col_int_key int,
  pk int,
  col_int int,
  PRIMARY KEY (pk)
);
INSERT INTO t1 VALUES (1,2,3);

CREATE TABLE t2 (
  col_int_key int,
  pk_1 int,
  pk_2 int,
  col_int int,
  PRIMARY KEY (pk_1,pk_2)
);
INSERT INTO t2 VALUES (1,2,3,4);

# JOIN on matching key
SELECT t1.pk, t1.col_int, t2.pk_1, t2.col_int
FROM t1 JOIN t2 ON t1.pk = t2.pk_1;

# Aggregate across JOIN
SELECT COUNT(*), SUM(t1.col_int + t2.col_int)
FROM t1 JOIN t2 ON t1.pk = t2.pk_1;

DROP TABLE t1, t2;

--echo #
--echo # Three-table cross join with COUNT
--echo #

CREATE TABLE t1(c1 INT);
INSERT INTO t1 VALUES (0),(0),(1);

CREATE TABLE t2(b INT);
INSERT INTO t2 VALUES(0),(0);

CREATE TABLE t3(x INT);
INSERT INTO t3 VALUES(10),(20),(30);

SELECT COUNT(*) FROM t1, t2;
SELECT COUNT(*) FROM t1, t2, t3;
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.c1 = t2.b;

# Aggregate with GROUP BY across cross join
SELECT t1.c1, COUNT(*) FROM t1, t2 GROUP BY t1.c1 ORDER BY t1.c1;

DROP TABLE t1, t2, t3;

--echo #
--echo # JOIN with large composite primary key
--echo #

CREATE TABLE t1 (c1 CHAR(255) NOT NULL);
CREATE TABLE t2 (c1 CHAR(255) NOT NULL, c2 CHAR(255) NOT NULL,
                 c3 CHAR(255) NOT NULL, PRIMARY KEY (c1, c2, c3));
INSERT INTO t1 VALUES ('x'), ('x');
INSERT INTO t2 VALUES ('x', '', '');

# JOIN on matching column
SELECT t1.c1, t2.c2, t2.c3 FROM t1 JOIN t2 ON t1.c1 = t2.c1;
SELECT COUNT(*) FROM t1 JOIN t2 ON t1.c1 = t2.c1;

# Update t2 and verify
UPDATE t2 SET c2 = 'y', c3 = 'y' WHERE c1 = 'x';
SELECT * FROM t2;

# Re-verify JOIN after update
SELECT t1.c1, t2.c2, t2.c3 FROM t1 JOIN t2 ON t1.c1 = t2.c1;

DROP TABLE t1, t2;

--echo #
--echo # Aggregate edge cases with JOINs
--echo #

CREATE TABLE t1 (id INT PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

CREATE TABLE t2 (id INT PRIMARY KEY, ref_id INT, status INT);
INSERT INTO t2 VALUES (1, 1, 0), (2, 2, 0), (3, 99, 0);

# Inner join - only matching rows
SELECT t1.id, t1.val, t2.status
FROM t1 JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id;

# Left join - all t1 rows, NULLs for non-matching
SELECT t1.id, t1.val, t2.ref_id, t2.status
FROM t1 LEFT JOIN t2 ON t1.id = t2.ref_id
ORDER BY t1.id;

# Aggregate with join condition
SELECT COUNT(*), SUM(t1.val), AVG(t1.val)
FROM t1 JOIN t2 ON t1.id = t2.ref_id;

# GROUP BY with join
SELECT t2.status, COUNT(*), SUM(t1.val)
FROM t1 JOIN t2 ON t1.id = t2.ref_id
GROUP BY t2.status;

DROP TABLE t1, t2;
