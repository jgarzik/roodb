#
# Fibonacci — recursive stored procedure with cursors
# Adapted from MySQL sp-fib.test
#

--disable_warnings
drop table if exists t3;
drop procedure if exists fib;
--enable_warnings
create table t3 ( f bigint unsigned not null );

delimiter |;
create procedure fib(n int unsigned)
begin
  if n > 1 then
    begin
      declare x, y bigint unsigned;
      declare c cursor for select f from t3 order by f desc limit 2;
      open c;
      fetch c into y;
      fetch c into x;
      insert into t3 values (x+y);
      call fib(n-1);
      close c;
    end;
  end if;
end|
delimiter ;|

insert into t3 values (0), (1);
call fib(4);
select * from t3 order by f asc;

--echo #
--echo # Deeper recursion — fib(8)
--echo #
delete from t3;
insert into t3 values (0), (1);
call fib(8);
select * from t3 order by f asc;

drop table t3;
drop procedure fib;
