#
# Test of EXPLAIN — adapted from MySQL explain.test for RooDB
#
# [RooDB-skip] EXPLAIN FORMAT=JSON, PREPARE/EXECUTE, FLUSH STATUS,
#   FULLTEXT indexes, optimizer_switch, character set tests,
#   EXPLAIN SELECT ... INTO, MyISAM specifics, key hints,
#   SHOW STATUS, hypergraph optimizer, EXPLAIN of VIEW queries,
#   EXPLAIN with subqueries, EXPLAIN of derived tables

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings

#
# Basic EXPLAIN on a table scan
#
CREATE TABLE t1 (id int NOT NULL, str char(10));
INSERT INTO t1 VALUES (1, NULL),(2, NULL),(3, 'foo'),(4, 'bar');
EXPLAIN SELECT * FROM t1;
DROP TABLE t1;

#
# EXPLAIN of constant SELECT (no tables)
#
EXPLAIN SELECT 1;

#
# EXPLAIN with count(*)
#
CREATE TABLE t1 (a int NOT NULL);
EXPLAIN SELECT count(*) FROM t1;
INSERT INTO t1 VALUES (1);
EXPLAIN SELECT count(*) FROM t1;
DROP TABLE t1;

#
# EXPLAIN with WHERE clause
#
CREATE TABLE t1 (f1 int, f2 int);
INSERT INTO t1 VALUES (1,1);
EXPLAIN SELECT * FROM t1 WHERE f1 = 1;
DROP TABLE t1;

#
# EXPLAIN with JOIN
#
CREATE TABLE t1 (a int);
CREATE TABLE t2 (a int);
INSERT INTO t1 VALUES (1),(2);
INSERT INTO t2 VALUES (1),(2);
EXPLAIN SELECT * FROM t1 JOIN t2 ON t1.a = t2.a;
DROP TABLE t1, t2;

#
# EXPLAIN SELECT with simple WHERE across tables
#
CREATE TABLE t1 (f1 int);
CREATE TABLE t2 (f2 int);
INSERT INTO t1 VALUES (1);
INSERT INTO t2 VALUES (1),(2);
EXPLAIN SELECT * FROM t1 WHERE f1 = 1;
EXPLAIN SELECT * FROM t1 JOIN t2 ON f1 = f2 WHERE f1 = 1;
DROP TABLE t1, t2;

#
# EXPLAIN with UNION
#
CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (1),(2),(3);
EXPLAIN SELECT a FROM t1 UNION SELECT a+10 FROM t1;
DROP TABLE t1;

#
# EXPLAIN with ORDER BY and LIMIT
#
CREATE TABLE t1 (a int, b varchar(20));
INSERT INTO t1 VALUES (3,'c'),(1,'a'),(2,'b');
EXPLAIN SELECT * FROM t1 ORDER BY a LIMIT 2;
DROP TABLE t1;

#
# EXPLAIN with GROUP BY
#
CREATE TABLE t1 (a int, b int);
INSERT INTO t1 VALUES (1,10),(1,20),(2,30),(2,40);
EXPLAIN SELECT a, SUM(b) FROM t1 GROUP BY a;
DROP TABLE t1;

#
# EXPLAIN with DISTINCT
#
CREATE TABLE t1 (a int, b int);
INSERT INTO t1 VALUES (1,1),(1,2),(2,3);
EXPLAIN SELECT DISTINCT a FROM t1;
DROP TABLE t1;
