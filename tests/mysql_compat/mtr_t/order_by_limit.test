# Adapted from MySQL order_by_limit.test for RooDB compatibility testing.
# Original test is almost entirely about optimizer cost-based index switching,
# EXPLAIN output, STRAIGHT_JOIN, FORCE INDEX, ANALYZE, debug sync, stored
# procedures, WITH RECURSIVE, prepared statements, optimizer_trace,
# information_schema, and connection management.
# We extract the few pure ORDER BY + LIMIT data correctness tests.

# [RooDB-skip] Most of this test requires: EXPLAIN, ANALYZE TABLE, STRAIGHT_JOIN,
# FORCE INDEX, optimizer_switch, optimizer_trace, information_schema,
# stored procedures, WITH RECURSIVE, prepared statements, DEBUG_SYNC,
# --connect/--disconnect, SECONDARY_ENGINE, SHOW SESSION STATUS.

#
# Bug#33066458: Simple ORDER BY ... LIMIT with large limit
#
CREATE TABLE t (x INTEGER PRIMARY KEY, y INTEGER);
INSERT INTO t VALUES (1, 2), (2, 3), (3, 4);
SELECT * FROM t ORDER BY x LIMIT 18446744073709551614;
DROP TABLE t;

#
# Basic ORDER BY with LIMIT
#
CREATE TABLE t1 (
  pk INT PRIMARY KEY,
  i1 INT NOT NULL,
  i2 INT NOT NULL
);
INSERT INTO t1 VALUES (1, 10, 100);
INSERT INTO t1 VALUES (2, 20, 200);
INSERT INTO t1 VALUES (3, 30, 300);
INSERT INTO t1 VALUES (4, 40, 400);
INSERT INTO t1 VALUES (5, 50, 500);
INSERT INTO t1 VALUES (6, 60, 600);
INSERT INTO t1 VALUES (7, 70, 700);
INSERT INTO t1 VALUES (8, 80, 800);
INSERT INTO t1 VALUES (9, 90, 900);
INSERT INTO t1 VALUES (10, 100, 1000);

SELECT * FROM t1 ORDER BY i1 LIMIT 3;
SELECT * FROM t1 ORDER BY i1 DESC LIMIT 3;
SELECT * FROM t1 WHERE i1 > 50 ORDER BY i1 LIMIT 3;
SELECT * FROM t1 WHERE i1 > 50 ORDER BY i1 DESC LIMIT 3;
SELECT * FROM t1 ORDER BY i1 LIMIT 5 OFFSET 3;

DROP TABLE t1;

#
# ORDER BY with LIMIT on joined tables
#
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

CREATE TABLE t2 (c INT PRIMARY KEY, d INT);
INSERT INTO t2 VALUES (1, 100), (2, 200), (3, 300), (4, 400), (5, 500);

SELECT t1.a, t1.b, t2.d FROM t1 JOIN t2 ON t1.a = t2.c ORDER BY t1.b LIMIT 3;
SELECT t1.a, t1.b, t2.d FROM t1 JOIN t2 ON t1.a = t2.c ORDER BY t2.d DESC LIMIT 2;
SELECT t1.a, t1.b, t2.d FROM t1 JOIN t2 ON t1.a = t2.c WHERE t1.b > 20 ORDER BY t1.a LIMIT 2;

DROP TABLE t1, t2;

#
# ORDER BY with LIMIT and WHERE conditions
#
CREATE TABLE t1 (id INT PRIMARY KEY, val VARCHAR(50), num INT);
INSERT INTO t1 VALUES (1, 'alpha', 50);
INSERT INTO t1 VALUES (2, 'beta', 30);
INSERT INTO t1 VALUES (3, 'gamma', 40);
INSERT INTO t1 VALUES (4, 'delta', 20);
INSERT INTO t1 VALUES (5, 'epsilon', 10);

SELECT * FROM t1 WHERE num < 40 ORDER BY num LIMIT 2;
SELECT * FROM t1 WHERE num >= 20 ORDER BY val LIMIT 3;
SELECT * FROM t1 WHERE num BETWEEN 20 AND 50 ORDER BY id DESC LIMIT 2;

DROP TABLE t1;

#
# ORDER BY with LIMIT and NULL values
#
CREATE TABLE t1 (id INT PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, NULL), (2, 10), (3, NULL), (4, 20), (5, 30);

SELECT * FROM t1 ORDER BY val LIMIT 3;
SELECT * FROM t1 ORDER BY val DESC LIMIT 3;

DROP TABLE t1;

#
# ORDER BY with LIMIT 0
#
CREATE TABLE t1 (id INT PRIMARY KEY, val INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

SELECT * FROM t1 ORDER BY val LIMIT 0;

DROP TABLE t1;

#
# Multiple ORDER BY columns with LIMIT
#
CREATE TABLE t1 (id INT PRIMARY KEY, a INT, b INT);
INSERT INTO t1 VALUES (1, 1, 3), (2, 1, 1), (3, 2, 2), (4, 2, 1), (5, 3, 3);

SELECT * FROM t1 ORDER BY a, b LIMIT 3;
SELECT * FROM t1 ORDER BY a DESC, b ASC LIMIT 3;
SELECT * FROM t1 ORDER BY a ASC, b DESC LIMIT 3;

DROP TABLE t1;
