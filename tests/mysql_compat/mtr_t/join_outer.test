#
# LEFT/RIGHT JOIN tests adapted from MySQL join_outer.test (~first 200 lines)
#
# [RooDB-skip] ENGINE=MyISAM, EXPLAIN, --sorted_result, --error directives
# [RooDB-skip] { oj ... } ODBC outer join syntax, NATURAL JOIN
# [RooDB-skip] JOIN USING (multiple columns), --skip_if_hypergraph
# [RooDB-skip] display width on INT, INDEX, AUTO_INCREMENT, ENUM
# [RooDB-skip] test.t4 qualified table name, DISTINCT with multi-table LEFT JOIN
#

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings

#
# Basic LEFT JOIN
#
CREATE TABLE t1 (
  grp INT,
  a BIGINT UNSIGNED,
  c CHAR(10) NOT NULL DEFAULT ''
);
INSERT INTO t1 VALUES (1,1,'a'),(2,2,'b'),(2,3,'c'),(3,4,'E'),(3,5,'C'),(3,6,'D'),(NULL,NULL,'');

CREATE TABLE t2 (id INT, a BIGINT UNSIGNED NOT NULL, c CHAR(10), d INT, PRIMARY KEY (a));
INSERT INTO t2 VALUES (1,1,'a',1),(3,4,'A',4),(3,5,'B',5),(3,6,'C',6),(4,7,'D',7);

# Inner join
SELECT t1.*, t2.* FROM t1 JOIN t2 WHERE t1.a = t2.a ORDER BY t1.a;

# Left join with ORDER BY
SELECT t1.*, t2.* FROM t1 LEFT JOIN t2 ON (t1.a = t2.a) ORDER BY t1.grp, t1.a, t2.c;

# Left join with ON and WHERE filtering
SELECT t1.*, t2.* FROM t1 LEFT JOIN t2 ON (t1.a = t2.a) WHERE t2.id = 3 ORDER BY t1.a;
SELECT t1.*, t2.* FROM t1 LEFT JOIN t2 ON (t1.a = t2.a) WHERE t2.id IS NULL ORDER BY t1.grp, t1.a;

# Three-table left join chain
SELECT t1.*, t2.*, t3.a FROM t1 LEFT JOIN t2 ON (t1.a = t2.a) LEFT JOIN t1 AS t3 ON (t2.a = t3.a) ORDER BY t1.grp, t1.a;

# Inner join with ON
SELECT t1.*, t2.* FROM t1 INNER JOIN t2 ON (t1.a = t2.a) ORDER BY t1.a;

DROP TABLE t1, t2;

#
# LEFT JOIN with IS NULL (find unmatched rows)
#
CREATE TABLE t1 (
  id INT NOT NULL,
  name CHAR(60) NOT NULL,
  PRIMARY KEY (id)
);
INSERT INTO t1 VALUES (1,'Antonio Paz');
INSERT INTO t1 VALUES (2,'Lilliana Angelovska');
INSERT INTO t1 VALUES (3,'Thimble Smith');

CREATE TABLE t2 (
  id INT NOT NULL,
  owner INT NOT NULL DEFAULT 0,
  name CHAR(60),
  PRIMARY KEY (id)
);
INSERT INTO t2 VALUES (1,1,'El Gato');
INSERT INTO t2 VALUES (2,1,'Perrito');
INSERT INTO t2 VALUES (3,3,'Happy');

SELECT t1.name, t2.name, t2.id FROM t1 LEFT JOIN t2 ON (t1.id = t2.owner) ORDER BY t1.name, t2.name;
SELECT t1.name, t2.name, t2.id FROM t1 LEFT JOIN t2 ON (t1.id = t2.owner) WHERE t2.id IS NULL;
SELECT COUNT(*) FROM t1 LEFT JOIN t2 ON (t1.id = t2.owner);

# RIGHT JOIN equivalence
SELECT t1.name, t2.name, t2.id FROM t2 RIGHT JOIN t1 ON (t1.id = t2.owner) ORDER BY t1.name, t2.name;
SELECT t1.name, t2.name, t2.id FROM t2 RIGHT JOIN t1 ON (t1.id = t2.owner) WHERE t2.id IS NULL;
SELECT COUNT(*) FROM t2 RIGHT JOIN t1 ON (t1.id = t2.owner);

# Three-table right+left join chain
SELECT t1.name, t2.name, t2.id, t3.id FROM t2 RIGHT JOIN t1 ON (t1.id = t2.owner) LEFT JOIN t1 AS t3 ON t3.id = t2.owner ORDER BY t1.name, t2.name;

DROP TABLE t1, t2;

#
# NULL handling with LEFT JOIN
#
CREATE TABLE t1 (id INT NOT NULL, str CHAR(10));
INSERT INTO t1 VALUES (1, NULL), (2, NULL), (3, 'foo'), (4, 'bar');
SELECT * FROM t1 WHERE str IS NOT NULL ORDER BY id;
SELECT * FROM t1 WHERE str IS NULL ORDER BY id;
DROP TABLE t1;

#
# LEFT JOIN with multiple conditions
#
CREATE TABLE t1 (n INT, m INT, o INT);
INSERT INTO t1 VALUES (1, 2, 11), (1, 2, 7), (2, 2, 8), (1, 2, 9), (1, 3, 9);

CREATE TABLE t2 (n INT NOT NULL, m INT, o INT, PRIMARY KEY (n));
INSERT INTO t2 VALUES (1, 2, 3), (2, 2, 8), (4, 3, 9), (3, 2, 10);

SELECT t1.*, t2.* FROM t1 LEFT JOIN t2 ON t1.n = t2.n AND t1.m = t2.m WHERE t1.n = 1 ORDER BY t1.o;
SELECT t1.*, t2.* FROM t1 LEFT JOIN t2 ON t1.n = t2.n AND t1.m = t2.m WHERE t1.n = 1 ORDER BY t1.o, t1.m;

DROP TABLE t1, t2;

#
# LEFT JOIN with aggregate functions
#
CREATE TABLE t1 (id INT, val INT);
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

CREATE TABLE t2 (id INT, detail VARCHAR(20));
INSERT INTO t2 VALUES (1, 'first'), (1, 'second'), (3, 'third');

SELECT t1.id, t1.val, COUNT(t2.id) AS cnt FROM t1 LEFT JOIN t2 ON t1.id = t2.id GROUP BY t1.id, t1.val ORDER BY t1.id;
SELECT t1.id, SUM(t1.val) AS total FROM t1 LEFT JOIN t2 ON t1.id = t2.id GROUP BY t1.id ORDER BY t1.id;

DROP TABLE t1, t2;

#
# Multiple LEFT JOINs
#
CREATE TABLE t1 (id INT PRIMARY KEY, name VARCHAR(20));
INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');

CREATE TABLE t2 (id INT PRIMARY KEY, t1_id INT, score INT);
INSERT INTO t2 VALUES (1, 1, 90), (2, 1, 85), (3, 3, 70);

CREATE TABLE t3 (id INT PRIMARY KEY, t2_id INT, grade CHAR(1));
INSERT INTO t3 VALUES (1, 1, 'A'), (2, 3, 'B');

SELECT t1.name, t2.score, t3.grade
FROM t1
LEFT JOIN t2 ON t1.id = t2.t1_id
LEFT JOIN t3 ON t2.id = t3.t2_id
ORDER BY t1.name, t2.score;

DROP TABLE t1, t2, t3;
