#
# Trimmed from MySQL distinct.test for RooDB compatibility testing.
# Tests: basic SELECT DISTINCT queries.
#

# [RooDB-skip] INSERT INTO ... SELECT skipped at top

CREATE TABLE t1 (id int, facility char(20));
INSERT INTO t1 VALUES (NULL,NULL);
INSERT INTO t1 VALUES (-1,'');
INSERT INTO t1 VALUES (0,'');
INSERT INTO t1 VALUES (1,'/L');
INSERT INTO t1 VALUES (2,'A01');
INSERT INTO t1 VALUES (3,'ANC');
INSERT INTO t1 VALUES (4,'F01');
INSERT INTO t1 VALUES (5,'FBX');
INSERT INTO t1 VALUES (6,'MT');
INSERT INTO t1 VALUES (7,'P');
INSERT INTO t1 VALUES (8,'RV');
INSERT INTO t1 VALUES (9,'SRV');
INSERT INTO t1 VALUES (10,'VMT');

SELECT id FROM t1 GROUP BY id ORDER BY id;
SELECT * FROM t1 ORDER BY id;
SELECT DISTINCT facility FROM t1 ORDER BY facility;
SELECT count(facility) FROM t1;
SELECT count(*) FROM t1;
SELECT count(*) FROM t1 WHERE facility IS NULL;
SELECT count(*) FROM t1 WHERE facility = NULL;
SELECT count(*) FROM t1 WHERE facility IS NOT NULL;
SELECT count(*) FROM t1 WHERE id IS NULL;
SELECT count(*) FROM t1 WHERE id IS NOT NULL;

DROP TABLE t1;

#
# Problem with distinct without results
#
CREATE TABLE t1 (UserId int DEFAULT 0 NOT NULL);
INSERT INTO t1 VALUES (20);
INSERT INTO t1 VALUES (27);

SELECT UserId FROM t1 WHERE Userid=22;
SELECT UserId FROM t1 WHERE UserId=22 GROUP BY Userid;
SELECT DISTINCT UserId FROM t1 WHERE UserId=22 GROUP BY Userid;
SELECT DISTINCT UserId FROM t1 WHERE UserId=22;
DROP TABLE t1;

#
# Test of distinct
#
CREATE TABLE t1 (a int unsigned NOT NULL PRIMARY KEY, b int unsigned);
INSERT INTO t1 VALUES (1,1),(2,1),(3,1),(4,1);
CREATE TABLE t2 (a int unsigned NOT NULL, KEY (a));
INSERT INTO t2 VALUES (1),(2);
CREATE TABLE t3 (a int unsigned, KEY(a), b text);
INSERT INTO t3 VALUES (1,'1'),(2,'2');
SELECT DISTINCT t3.b FROM t3, t2, t1 WHERE t3.a=t1.b AND t1.a=t2.a ORDER BY t3.b;

# [RooDB-skip] EXPLAIN skipped
# [RooDB-skip] TEMPORARY TABLE / INSERT...SELECT skipped
# [RooDB-skip] --skip_if_hypergraph / FLUSH STATUS / SHOW STATUS skipped
# [RooDB-skip] while/let/dec/eval loop skipped

SELECT DISTINCT t3.a FROM t3, t2, t1 WHERE t3.a=t1.b AND t1.a=t2.a;

DROP TABLE t1, t2, t3;

#
# DISTINCT with LIMIT
#
CREATE TABLE t1 (name varchar(255));
INSERT INTO t1 VALUES ('aa'),('ab'),('ac'),('ad'),('ae');
SELECT DISTINCT * FROM t1 LIMIT 2;
SELECT DISTINCT name FROM t1 LIMIT 2;
SELECT DISTINCT 1 FROM t1 LIMIT 2;
DROP TABLE t1;

#
# DISTINCT with HAVING
#
CREATE TABLE t1 (a int NOT NULL, b char(5), c text);
INSERT INTO t1 (a) VALUES (1),(2),(3),(4),(1),(2),(3),(4);
SELECT DISTINCT a FROM t1 GROUP BY b, a HAVING a > 2 ORDER BY a DESC;
DROP TABLE t1;

#
# Test cases for DISTINCT with constants
#
CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (1),(2),(3),(4),(5);
SELECT DISTINCT a, 1 FROM t1 ORDER BY a;
SELECT DISTINCT 1, a FROM t1 ORDER BY a;

CREATE TABLE t2 (a int, b int);
INSERT INTO t2 VALUES (1,1),(2,2),(2,3),(2,4),(3,5);
SELECT DISTINCT a, b, 2 FROM t2 ORDER BY a, b;
SELECT DISTINCT 2, a, b FROM t2 ORDER BY a, b;
SELECT DISTINCT a, 2, b FROM t2 ORDER BY a, b;

DROP TABLE t1, t2;

#
# DISTINCT with ORDER BY DESC
#
CREATE TABLE t1 (a char(1), KEY(a));
INSERT INTO t1 VALUES('1'),('1');
SELECT * FROM t1 WHERE a >= '1';
SELECT DISTINCT a FROM t1 ORDER BY a DESC;
SELECT DISTINCT a FROM t1 WHERE a >= '1' ORDER BY a DESC;
DROP TABLE t1;

