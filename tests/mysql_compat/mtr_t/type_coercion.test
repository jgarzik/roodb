#
# Custom test for RooDB: Implicit type coercion tests.
# Tests automatic type conversion between INT, VARCHAR, DECIMAL, DATE
# in comparisons, arithmetic, and expressions.
#

DROP TABLE IF EXISTS t1;

#
# String to number coercion in comparisons
#

SELECT 1 = '1';
SELECT 1 = '1.0';
SELECT 1 = '1abc';
SELECT 0 = 'abc';
SELECT 1 < '2';
SELECT '10' < '9';
SELECT '10' < 9;
SELECT 10 < '9';

#
# String to number in arithmetic
#

SELECT '5' + 3;
SELECT '5.5' + 3;
SELECT '5' * '3';
SELECT '10' / '3';
SELECT '10' - '3';
SELECT '10' % '3';

#
# Decimal and integer coercion
#

SELECT 1 + 1.5;
SELECT 2 * 1.5;
SELECT 5 / 2;
SELECT CAST(5 AS DECIMAL(10,2)) + 3;
SELECT 10 / 3;

#
# NULL coercion
#

SELECT NULL + 1;
SELECT NULL + 1.5;
SELECT NULL + '1';
SELECT CONCAT(NULL, 'abc');
SELECT NULL = 0;
SELECT NULL = '';

#
# Type coercion in table context
#

CREATE TABLE t1 (
  i INT,
  d DECIMAL(10,2),
  v VARCHAR(20),
  dt DATE
);

INSERT INTO t1 VALUES (1, 1.50, '100', '2025-01-15');
INSERT INTO t1 VALUES (2, 2.75, '200', '2025-06-30');
INSERT INTO t1 VALUES (3, 3.00, 'abc', '2025-12-31');
INSERT INTO t1 VALUES (100, 100.00, '100', '2025-01-15');

#
# Compare INT column to string literal
#

SELECT i FROM t1 WHERE i = '2' ORDER BY i;
SELECT i FROM t1 WHERE i > '1' ORDER BY i;

#
# Compare VARCHAR column to integer
#

SELECT v FROM t1 WHERE v = 100 ORDER BY v;
SELECT v FROM t1 WHERE v > 50 ORDER BY i;

#
# Arithmetic mixing INT and DECIMAL columns
#

SELECT i, d, i + d AS sum_id, i * d AS prod_id FROM t1 ORDER BY i;

#
# Arithmetic with VARCHAR containing numbers
#

SELECT v, v + 0 AS v_as_num, v + 10 AS v_plus_10 FROM t1 ORDER BY i;

#
# BETWEEN with mixed types
#

SELECT i FROM t1 WHERE i BETWEEN '1' AND '3' ORDER BY i;
SELECT i FROM t1 WHERE d BETWEEN 1 AND 3 ORDER BY i;

#
# IN with mixed types
#

SELECT i FROM t1 WHERE i IN ('1', '3', '100') ORDER BY i;
SELECT i FROM t1 WHERE d IN (1.50, 3.00) ORDER BY i;

#
# CASE with mixed types
#

SELECT i, CASE i WHEN '1' THEN 'one' WHEN '2' THEN 'two' ELSE 'other' END AS word FROM t1 ORDER BY i;

#
# Comparison of date string to date column
#

SELECT dt FROM t1 WHERE dt = '2025-01-15' ORDER BY dt;
SELECT dt FROM t1 WHERE dt > '2025-06-01' ORDER BY dt;
SELECT dt FROM t1 WHERE dt BETWEEN '2025-01-01' AND '2025-06-30' ORDER BY dt;

#
# CONCAT with non-string types
#

SELECT CONCAT(i, ' - ', d) FROM t1 ORDER BY i;
SELECT CONCAT(i, d, v) FROM t1 ORDER BY i;

DROP TABLE t1;

--echo # End of type_coercion tests
