#
# Basic TIMESTAMP type tests for RooDB
# Trimmed from MySQL type_timestamp.test
#
# [RooDB-skip] SET timestamp=, SET time_zone, CURRENT_TIMESTAMP ON UPDATE
# [RooDB-skip] NOW(), SHOW CREATE TABLE, SHOW COLUMNS, ALTER TABLE
# [RooDB-skip] --replace_result, --let, --skip_if_hypergraph
# [RooDB-skip] FLUSH TABLES, INSERT...SELECT, TRUNCATE, sql_mode changes
# [RooDB-skip] information_schema, timezone, NULL auto-set behavior

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings

#
# Basic TIMESTAMP column with INSERT and SELECT
#
CREATE TABLE t1 (a INT, t TIMESTAMP);
INSERT INTO t1 VALUES (1, '2002-03-03 00:00:00');
INSERT INTO t1 VALUES (2, '2004-05-15 12:30:00');
INSERT INTO t1 VALUES (3, '1999-12-31 23:59:59');
SELECT * FROM t1 ORDER BY a;
DROP TABLE t1;

#
# TIMESTAMP with various date formats
#
CREATE TABLE t1 (date_col DATE, dt_col DATETIME, ts_col TIMESTAMP);
INSERT INTO t1 VALUES ('1998-12-31', '1998-12-31 23:59:59', '1998-12-31 23:59:59');
INSERT INTO t1 VALUES ('1999-01-01', '1999-01-01 00:00:00', '1999-01-01 00:00:00');
INSERT INTO t1 VALUES ('2000-02-29', '2000-02-29 00:00:00', '2000-02-29 00:00:00');
INSERT INTO t1 VALUES ('2005-01-01', '2005-01-01 00:00:00', '2005-01-01 00:00:00');
INSERT INTO t1 VALUES ('2030-01-01', '2030-01-01 00:00:00', '2030-01-01 00:00:00');
SELECT * FROM t1 ORDER BY date_col;
DROP TABLE t1;

#
# TIMESTAMP comparison
#
CREATE TABLE t1 (a TIMESTAMP);
INSERT INTO t1 VALUES ('2010-02-01 09:31:01');
INSERT INTO t1 VALUES ('2010-02-01 09:31:02');
INSERT INTO t1 VALUES ('2010-02-01 09:31:03');
INSERT INTO t1 VALUES ('2010-02-01 09:31:04');
SELECT * FROM t1 WHERE a >= '2010-02-01 09:31:02' ORDER BY a;
SELECT * FROM t1 WHERE a <= '2010-02-01 09:31:02' ORDER BY a;
SELECT * FROM t1 WHERE a = '2010-02-01 09:31:03' ORDER BY a;
DROP TABLE t1;

#
# TIMESTAMP aggregate comparison
#
CREATE TABLE t1 (dt DATETIME, ts TIMESTAMP);
INSERT INTO t1 VALUES ('2011-01-06 12:34:30', '2011-01-06 12:34:30');
SELECT MAX(dt), MAX(ts) FROM t1;
SELECT MAX(ts) < '2010-01-01 00:00:00' FROM t1;
SELECT MAX(dt) > '2010-01-01 00:00:00' FROM t1;
SELECT MAX(ts) = '2011-01-06 12:34:30' FROM t1;
SELECT MAX(dt) = '2011-01-06 12:34:30' FROM t1;
DROP TABLE t1;
