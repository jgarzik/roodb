#
# Complex WHERE clause patterns with subqueries.
# Tests multiple subqueries in WHERE, subqueries combined with AND/OR,
# BETWEEN with subqueries, IN/NOT IN, HAVING with subqueries, and edge cases.
# Adapted from patterns in MySQL subselect_innodb.test.
#
# [RooDB-skip] EXISTS/NOT EXISTS subqueries (not yet supported)
# [RooDB-skip] Correlated subqueries (not yet supported)
# [RooDB-skip] UNION inside subqueries (not yet supported)
#

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3, employees, departments, salaries, tasks;
--enable_warnings

--echo # --- Setup ---

CREATE TABLE departments (
    id INT NOT NULL PRIMARY KEY,
    name VARCHAR(30) NOT NULL
);
INSERT INTO departments VALUES (1, 'Engineering'), (2, 'Marketing'), (3, 'Sales'), (4, 'HR');

CREATE TABLE employees (
    id INT NOT NULL PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    dept_id INT NOT NULL,
    salary DECIMAL(10,2) NOT NULL,
    manager_id INT
);
INSERT INTO employees VALUES
    (1,  'Alice',   1, 120000.00, NULL),
    (2,  'Bob',     1, 95000.00,  1),
    (3,  'Charlie', 1, 105000.00, 1),
    (4,  'Diana',   2, 80000.00,  NULL),
    (5,  'Eve',     2, 72000.00,  4),
    (6,  'Frank',   3, 90000.00,  NULL),
    (7,  'Grace',   3, 85000.00,  6),
    (8,  'Henry',   3, 65000.00,  6),
    (9,  'Irene',   4, 60000.00,  NULL),
    (10, 'Jack',    4, 55000.00,  9);

CREATE TABLE salaries (
    emp_id INT NOT NULL,
    year_val INT NOT NULL,
    amount DECIMAL(10,2) NOT NULL,
    PRIMARY KEY (emp_id, year_val)
);
INSERT INTO salaries VALUES
    (1, 2023, 115000.00), (1, 2024, 120000.00),
    (2, 2023, 90000.00),  (2, 2024, 95000.00),
    (3, 2023, 100000.00), (3, 2024, 105000.00),
    (4, 2023, 78000.00),  (4, 2024, 80000.00),
    (5, 2024, 72000.00),
    (6, 2023, 85000.00),  (6, 2024, 90000.00),
    (7, 2024, 85000.00),
    (8, 2024, 65000.00),
    (9, 2023, 58000.00),  (9, 2024, 60000.00),
    (10, 2024, 55000.00);

CREATE TABLE tasks (
    id INT NOT NULL PRIMARY KEY,
    emp_id INT NOT NULL,
    status VARCHAR(20) NOT NULL,
    priority INT NOT NULL
);
INSERT INTO tasks VALUES
    (1, 1, 'done', 1), (2, 1, 'done', 2),
    (3, 2, 'active', 1), (4, 2, 'active', 3),
    (5, 3, 'done', 2),
    (6, 4, 'active', 1),
    (7, 6, 'done', 1), (8, 6, 'active', 2),
    (9, 7, 'done', 3),
    (10, 9, 'active', 1);

--echo # --- Multiple subqueries combined with AND ---

SELECT e.name, e.salary
FROM employees e
WHERE e.salary > (SELECT AVG(salary) FROM employees)
  AND e.dept_id IN (SELECT id FROM departments WHERE name IN ('Engineering', 'Sales'))
ORDER BY e.id;

--echo # --- Multiple subqueries combined with OR ---

SELECT e.name, e.salary, e.dept_id
FROM employees e
WHERE e.salary > (SELECT AVG(salary) FROM employees)
   OR e.dept_id IN (SELECT id FROM departments WHERE name = 'HR')
ORDER BY e.id;

--echo # --- Nested IN with subquery ---

# Employees who are in departments that have at least one high earner (>100k)
SELECT e.name, e.dept_id
FROM employees e
WHERE e.dept_id IN (
    SELECT dept_id FROM employees WHERE salary > 100000.00
)
ORDER BY e.id;

--echo # --- NOT IN with subquery ---

# Employees who don't have active tasks
SELECT e.name
FROM employees e
WHERE e.id NOT IN (SELECT emp_id FROM tasks WHERE status = 'active')
ORDER BY e.id;

--echo # --- IN with subquery on priority-1 tasks ---

SELECT e.name, e.salary
FROM employees e
WHERE e.id IN (
    SELECT emp_id FROM tasks WHERE priority = 1
)
ORDER BY e.id;

--echo # --- NOT IN with subquery: employees without any tasks ---

SELECT e.name
FROM employees e
WHERE e.id NOT IN (SELECT emp_id FROM tasks)
ORDER BY e.id;

--echo # --- Subquery with aggregate in BETWEEN ---

SELECT e.name, e.salary
FROM employees e
WHERE e.salary BETWEEN
    (SELECT MIN(salary) FROM employees WHERE dept_id = 1)
    AND
    (SELECT MAX(salary) FROM employees WHERE dept_id = 3)
ORDER BY e.id;

--echo # --- Subquery in WHERE with GROUP BY in outer query ---

SELECT e.dept_id, COUNT(*) AS emp_count, SUM(e.salary) AS total_salary
FROM employees e
WHERE e.id IN (SELECT emp_id FROM tasks)
GROUP BY e.dept_id
ORDER BY e.dept_id;

--echo # --- Subquery with DISTINCT in WHERE ---

SELECT e.name
FROM employees e
WHERE e.dept_id IN (
    SELECT DISTINCT dept_id FROM employees WHERE salary >= 80000.00
)
ORDER BY e.id;

--echo # --- Subquery comparing with NULL (edge case) ---

# Employees whose manager is also a manager of someone else
SELECT e.name
FROM employees e
WHERE e.manager_id IS NOT NULL
  AND e.manager_id IN (
      SELECT DISTINCT manager_id FROM employees WHERE manager_id IS NOT NULL
  )
ORDER BY e.id;

--echo # --- Scalar subquery in complex arithmetic WHERE ---

SELECT e.name, e.salary
FROM employees e
WHERE e.salary > (SELECT AVG(salary) FROM employees) + 10000
ORDER BY e.id;

SELECT e.name, e.salary
FROM employees e
WHERE e.salary * 2 > (SELECT MAX(salary) FROM employees)
ORDER BY e.id;

--echo # --- Multiple IN subqueries combined ---

SELECT e.name
FROM employees e
WHERE e.dept_id IN (SELECT id FROM departments WHERE name = 'Engineering')
  AND e.id IN (SELECT emp_id FROM tasks WHERE status = 'done')
ORDER BY e.id;

--echo # --- IN subquery with aggregate (dept with most employees) ---

SELECT e.name, e.dept_id
FROM employees e
WHERE e.dept_id IN (
    SELECT dept_id FROM employees GROUP BY dept_id HAVING COUNT(*) = (
        SELECT MAX(cnt) FROM (SELECT COUNT(*) AS cnt FROM employees GROUP BY dept_id) sub
    )
)
ORDER BY e.id;

--echo # --- NOT IN combined with scalar subquery ---

SELECT e.name, e.salary
FROM employees e
WHERE e.id NOT IN (SELECT emp_id FROM salaries WHERE year_val = 2023)
  AND e.salary > (SELECT AVG(salary) FROM employees)
ORDER BY e.id;

--echo # --- Subquery with SUM in HAVING (from subselect_innodb) ---

CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1,2), (1,3), (2,3), (2,4), (2,5), (3,4), (4,5), (4,100);

CREATE TABLE t2 (a INT);
INSERT INTO t2 VALUES (1),(2),(3),(4);

SELECT a, SUM(b) AS b FROM t1 GROUP BY a HAVING b > (SELECT MAX(a) FROM t2) ORDER BY a;

DROP TABLE t1, t2;

--echo # --- Scalar subquery with aggregate and GROUP BY in HAVING ---

SELECT d.name, COUNT(*) AS emp_count
FROM departments d
JOIN employees e ON d.id = e.dept_id
GROUP BY d.name
HAVING COUNT(*) >= (SELECT MIN(cnt) FROM (SELECT COUNT(*) AS cnt FROM employees GROUP BY dept_id) sub)
ORDER BY d.name;

--echo # --- WHERE with IN subquery and ORDER BY + LIMIT ---

SELECT e.name, e.salary
FROM employees e
WHERE e.dept_id IN (SELECT id FROM departments WHERE name != 'HR')
ORDER BY e.salary DESC
LIMIT 5;

--echo # --- IN subquery returning empty result ---

SELECT e.name FROM employees e
WHERE e.id IN (SELECT emp_id FROM tasks WHERE priority > 100)
ORDER BY e.id;

--echo # --- NOT IN subquery returning empty result (all rows match) ---

SELECT e.name FROM employees e
WHERE e.id NOT IN (SELECT emp_id FROM tasks WHERE priority > 100)
ORDER BY e.id;

--echo # --- Multiple scalar subqueries in SELECT + WHERE ---

SELECT e.name,
    (SELECT MAX(salary) FROM employees) AS max_sal,
    (SELECT MIN(salary) FROM employees) AS min_sal,
    e.salary
FROM employees e
WHERE e.salary > (SELECT AVG(salary) FROM employees)
ORDER BY e.id;

--echo # --- Cleanup ---
DROP TABLE tasks, salaries, employees, departments;
