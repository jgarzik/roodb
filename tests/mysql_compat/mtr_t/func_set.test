# Adapted from MySQL func_set.test for RooDB compatibility testing.
# Tests SET-related functions: FIND_IN_SET(), ELT(), FIELD()

# [RooDB-skip] INTERVAL() function — not implemented in eval
# [RooDB-skip] MAKE_SET() — not implemented in eval
# [RooDB-skip] EXPORT_SET() — not implemented in eval
# [RooDB-skip] BINARY expr (deprecated)
# [RooDB-skip] INSERT IGNORE
# [RooDB-skip] CHARACTER SET / CHARSET / CONVERT ... USING
# [RooDB-skip] SET type columns with character set
# [RooDB-skip] DO statements
# [RooDB-skip] POINT() / geometry functions
# [RooDB-skip] CONNECTION_ID()
# [RooDB-skip] JSON functions (json_unquote, json_set)
# [RooDB-skip] User variables (@a, @z)
# [RooDB-skip] ENGINE= hints
# [RooDB-skip] Subqueries with MAKE_SET on same table
# [RooDB-skip] DAYOFWEEK(CURRENT_DATE()) (time-dependent)

#
# FIELD function
#
SELECT FIELD('IBM','NCA','ICL','SUN','IBM','DIGITAL'), FIELD('A','B','C'), ELT(2,'ONE','TWO','THREE'), ELT(1,1,2,3)|0;

#
# FIND_IN_SET
#
SELECT FIND_IN_SET('b','a,b,c'), FIND_IN_SET('c','a,b,c'), FIND_IN_SET('dd','a,bbb,dd'), FIND_IN_SET('bbb','a,bbb,dd');
SELECT FIND_IN_SET('d','a,b,c'), FIND_IN_SET('dd','a,bbb,d'), FIND_IN_SET('bb','a,bbb,dd');

#
# Wrong usage of functions
#
SELECT ELT(2,1), FIELD(NULL,'a','b','c');
SELECT FIELD('b','a',NULL), FIELD(1,0,NULL)+0;
SELECT FIELD(NULL,'a',NULL), FIELD(NULL,0,NULL)+0;
SELECT FIND_IN_SET('','a,b,c'), FIND_IN_SET('','a,b,c,'), FIND_IN_SET('',',a,b,c');
SELECT FIND_IN_SET('abc','abc'), FIND_IN_SET('ab','abc'), FIND_IN_SET('abcd','abc');

#
# Test for a bug with ELT()
#
CREATE TABLE t1 (id int NOT NULL UNIQUE);
CREATE TABLE t2 (id int NOT NULL PRIMARY KEY, val int NOT NULL);
INSERT INTO t1 VALUES (1),(2),(4);
INSERT INTO t2 VALUES (1,1),(2,1),(3,1),(4,2);

SELECT one.id, ELT(two.val,'one','two') FROM t1 one, t2 two WHERE two.id=one.id ORDER BY one.id;
DROP TABLE t1,t2;

#
# Bug#5513: FIND_IN_SET fails if set ends with a comma
#
SELECT FIND_IN_SET('1','3,1,');

#
# FIND_IN_SET with SET type column
#
CREATE TABLE t1 (days SET('1','2','3','4','5','6','7'));
INSERT INTO t1 VALUES('1,2,3,4,5,6,7'), (NULL), ('1,2,3,4,5,6,7');

SELECT * FROM t1 WHERE FIND_IN_SET(7, days) ORDER BY days;
SELECT * FROM t1 WHERE FIND_IN_SET(8, days) ORDER BY days;
SELECT * FROM t1 WHERE FIND_IN_SET(NULL, days) ORDER BY days;
SELECT * FROM t1 WHERE FIND_IN_SET(NULL, NULL) ORDER BY days;

DROP TABLE t1;

#
# FIELD with various types
#
SELECT FIELD('hello', 'world', 'hello', 'test');
SELECT FIELD(2, 1, 2, 3, 4);
SELECT FIELD('abc', 'def', 'ghi');
SELECT FIELD(NULL, 'a', 'b', 'c');

#
# ELT edge cases
#
SELECT ELT(1, 'a', 'b', 'c');
SELECT ELT(2, 'a', 'b', 'c');
SELECT ELT(3, 'a', 'b', 'c');
SELECT ELT(0, 'a', 'b', 'c');
SELECT ELT(4, 'a', 'b', 'c');
SELECT ELT(NULL, 'a', 'b', 'c');
SELECT ELT(1, NULL);

#
# FIND_IN_SET with table data
#
CREATE TABLE t1 (
    c varchar(40),
    z varchar(40),
    s SET('alpha','bravo','charlie','delta','echo','foxtrot','golf')
);
INSERT INTO t1 VALUES
  ('foxtrot', 'zulu', 'bravo,delta,foxtrot'),
  ('foxtrot', 'zulu', 'foxtrot'),
  ('foxtrot', 'zulu', 'alpha');

SELECT 'using string   ' AS param, FIND_IN_SET('foxtrot', s) AS f, s FROM t1
UNION
SELECT 'using column  ', FIND_IN_SET(c, s), s FROM t1;

SELECT 'invalid string   ' AS param, FIND_IN_SET('zulu', s) AS f, s FROM t1
UNION
SELECT 'invalid column  ', FIND_IN_SET(z, s), s FROM t1;

DROP TABLE t1;

# [RooDB-skip] GROUP BY on computed FIELD() expression — ordering not stable
