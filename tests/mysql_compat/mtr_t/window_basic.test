--echo # Window function tests

CREATE TABLE t1 (id INT, dept INT, name VARCHAR(10), salary INT);
INSERT INTO t1 VALUES (1, 1, 'alice', 50000);
INSERT INTO t1 VALUES (2, 1, 'bob', 60000);
INSERT INTO t1 VALUES (3, 2, 'carol', 70000);
INSERT INTO t1 VALUES (4, 2, 'dave', 55000);
INSERT INTO t1 VALUES (5, 2, 'eve', 70000);

--echo # --- ROW_NUMBER ---
SELECT name, salary, ROW_NUMBER() OVER (ORDER BY salary DESC) as rn FROM t1;

--echo # --- RANK with ties ---
SELECT name, salary, RANK() OVER (ORDER BY salary DESC) as rnk FROM t1;

--echo # --- DENSE_RANK ---
SELECT name, salary, DENSE_RANK() OVER (ORDER BY salary DESC) as drnk FROM t1;

--echo # --- SUM OVER PARTITION BY ---
SELECT dept, name, salary, SUM(salary) OVER (PARTITION BY dept) as dept_total FROM t1 ORDER BY dept, name;

--echo # --- COUNT(*) OVER PARTITION BY ---
SELECT dept, name, COUNT(*) OVER (PARTITION BY dept) as dept_size FROM t1 ORDER BY dept, name;

--echo # --- LAG and LEAD ---
SELECT id, salary, LAG(salary, 1) OVER (ORDER BY id) as prev, LEAD(salary, 1) OVER (ORDER BY id) as next FROM t1;

--echo # --- AVG OVER ---
SELECT dept, name, salary, AVG(salary) OVER (PARTITION BY dept) as dept_avg FROM t1 ORDER BY dept, name;

--echo # --- MIN/MAX OVER ---
SELECT dept, MIN(salary) OVER (PARTITION BY dept) as mn, MAX(salary) OVER (PARTITION BY dept) as mx FROM t1 ORDER BY dept, name;

DROP TABLE t1;
