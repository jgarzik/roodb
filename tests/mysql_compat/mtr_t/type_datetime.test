# Adapted from MySQL type_datetime.test for RooDB compatibility testing.
# Tests DATETIME type operations, comparisons, and functions.

# [RooDB-skip] INSERT IGNORE with invalid dates (0000-00-00, etc.)
# [RooDB-skip] SET sql_mode / SQL_MODE changes
# [RooDB-skip] OPTIMIZE TABLE / CHECK TABLE / ANALYZE TABLE / EXPLAIN
# [RooDB-skip] ALTER TABLE
# [RooDB-skip] SHOW CREATE TABLE / DESCRIBE
# [RooDB-skip] CREATE TABLE AS SELECT
# [RooDB-skip] SET timestamp / time_zone
# [RooDB-skip] prepared statements
# [RooDB-skip] stored procedures
# [RooDB-skip] SET NAMES / character_set changes
# [RooDB-skip] TRUNCATE TABLE
# [RooDB-skip] CREATE INDEX
# [RooDB-skip] CREATE VIEW / DROP VIEW
# [RooDB-skip] CURRENT_DATE / CURRENT_TIMESTAMP / NOW() (time-dependent)
# [RooDB-skip] User variables with := assignment syntax
# [RooDB-skip] 0000-00-00 dates
# [RooDB-skip] INTERVAL arithmetic (expr + INTERVAL x UNIT — binary op form)
# [RooDB-skip] EXTRACT (not implemented)
# [RooDB-skip] FORCE INDEX / IGNORE INDEX
# [RooDB-skip] SLEEP()
# [RooDB-skip] TIMESTAMP literal syntax (TIMESTAMP'...')
# [RooDB-skip] Scalar subquery in WHERE with MAX() (works but numeric datetime not supported)

#
# Basic DATETIME operations
#
CREATE TABLE t1 (id int, dt datetime);
INSERT INTO t1 VALUES (1,'2001-08-14 00:00:00'),(2,'2001-08-15 00:00:00'),(3,'2001-08-16 00:00:00'),(4,'2003-09-15 01:20:30');
SELECT * FROM t1 WHERE dt='2001-08-14 00:00:00';
SELECT * FROM t1 WHERE dt > '2002-10-20' ORDER BY dt;
DROP TABLE t1;

#
# DATETIME not null
#
CREATE TABLE t1 (a datetime NOT NULL);
INSERT INTO t1 VALUES ('2001-01-01 00:00:00');
SELECT * FROM t1;
DROP TABLE t1;

#
# CAST to DATETIME
#
SELECT CAST('2006-12-05 22:10:10' AS DATETIME) + 0;

#
# CAST DATE AS DECIMAL
#
SELECT CAST(CAST('2006-08-10' AS DATE) AS DECIMAL(20,6));
SELECT CAST(CAST('2006-08-10 10:11:12' AS DATETIME) AS DECIMAL(20,6));

#
# DATETIME comparisons
#
CREATE TABLE t1 (f1 date, f2 datetime);
INSERT INTO t1 VALUES('2001-01-01','2001-01-01 01:01:01');
INSERT INTO t1 VALUES('2001-02-05','2001-02-05 00:00:00');
INSERT INTO t1 VALUES('2001-03-10','2001-03-09 01:01:01');
INSERT INTO t1 VALUES('2001-04-15','2001-04-15 00:00:00');
INSERT INTO t1 VALUES('2001-05-20','2001-05-20 01:01:01');
SELECT f1, f2, f1 > f2, f1 = f2, f1 < f2 FROM t1 ORDER BY f1;
DROP TABLE t1;

#
# DATETIME and BETWEEN
#
CREATE TABLE t1 (f1 date, f2 datetime);
INSERT INTO t1 VALUES('2001-01-01','2001-01-01 01:01:01');
INSERT INTO t1 VALUES('2001-02-05','2001-02-05 00:00:00');
INSERT INTO t1 VALUES('2001-03-10','2001-03-09 01:01:01');
INSERT INTO t1 VALUES('2001-04-15','2001-04-15 00:00:00');
INSERT INTO t1 VALUES('2001-05-20','2001-05-20 01:01:01');
SELECT f2 FROM t1 WHERE f2 BETWEEN '2001-2-5' AND '2001-04-14' ORDER BY f2;
SELECT f1, f2 FROM t1 WHERE f1 BETWEEN f2 AND f2 ORDER BY f1;
SELECT f2 FROM t1 WHERE '2001-04-10 12:34:56' BETWEEN f2 AND '2001-05-01' ORDER BY f2;
SELECT f2 FROM t1 WHERE DATE(f2) BETWEEN '2001-4-15' AND '2001-4-15' ORDER BY f2;
DROP TABLE t1;

#
# DATETIME and IN
#
CREATE TABLE t1 (f1 date);
INSERT INTO t1 VALUES('2001-01-01'),('2001-01-02'),('2001-01-03');
SELECT * FROM t1 WHERE f1 IN ('2001-01-01','2001-01-02','2001-01-03') ORDER BY f1;
CREATE TABLE t2 (f2 datetime);
INSERT INTO t2 VALUES('2001-01-01 00:00:00'),('2001-02-03 12:34:56'),('2002-04-06 11:22:33');
SELECT * FROM t2 WHERE f2 IN ('2001-01-01','2001-02-03 12:34:56','2001-02-03') ORDER BY f2;
DROP TABLE t1,t2;

#
# LEAST/GREATEST with DATETIME
#
SELECT LEAST(CAST('2001-01-01' AS DATE), '2001-01-02');
SELECT GREATEST(CAST('2001-01-01' AS DATE), '2001-01-02');
SELECT LEAST(CAST('2001-01-01' AS DATE), '2001-01-02') + 0;
SELECT GREATEST(CAST('2001-01-01' AS DATE), '2001-01-02') + 0;
SELECT LEAST(CAST('2001-01-01' AS DATETIME), '2001-01-02') + 0;
SELECT CAST(LEAST(CAST('2001-01-01' AS DATETIME), '2001-01-02') AS SIGNED);

#
# DATETIME BETWEEN with integer
#
CREATE TABLE t1(f1 datetime);
INSERT INTO t1 VALUES('2001-01-01'),('2002-02-02');
SELECT * FROM t1 WHERE f1 BETWEEN 20020101 AND 20070101000000 ORDER BY f1;
DROP TABLE t1;

#
# COALESCE with date/datetime types
#
CREATE TABLE t1 (f1 date, f2 datetime, f3 varchar(20));
INSERT INTO t1 VALUES ('2001-01-01', '2001-01-01 12:00:00', '2001-01-01');
SELECT COALESCE(f1,f1) FROM t1;
SELECT COALESCE(f1,f2) FROM t1;
SELECT COALESCE(f2,f2) FROM t1;
SELECT COALESCE(f1,f3) FROM t1;
SELECT COALESCE(f2,f3) FROM t1;
DROP TABLE t1;

#
# Bug #31253: crash comparing datetime to double
#
CREATE TABLE t1 (f1 time);
INSERT INTO t1 VALUES ('45:44:44');
INSERT INTO t1 VALUES ('15:44:44');
SELECT * FROM t1 WHERE (CONVERT(f1,datetime)) != 1 ORDER BY f1;
DROP TABLE t1;

#
# DATETIME with NOT NULL column and IS NULL check
#
CREATE TABLE t1 (id int NOT NULL, cur_date datetime NOT NULL);
CREATE TABLE t2 (id int NOT NULL, cur_date date NOT NULL);
INSERT INTO t1 (id, cur_date) VALUES (1, '2007-04-25 18:30:22');
INSERT INTO t2 (id, cur_date) VALUES (1, '2007-04-25');

# NOT NULL columns should never have IS NULL = true
SELECT * FROM t1 WHERE cur_date IS NULL;
SELECT * FROM t2 WHERE cur_date IS NULL;

INSERT INTO t1 (id, cur_date) VALUES (2, '2007-04-26 18:30:22');
INSERT INTO t2 (id, cur_date) VALUES (2, '2007-04-26');

SELECT * FROM t1 WHERE cur_date IS NULL;
SELECT * FROM t2 WHERE cur_date IS NULL;
SELECT * FROM t1 ORDER BY id;
SELECT * FROM t2 ORDER BY id;
DROP TABLE t1,t2;

#
# NULL-safe comparison with date CASTs
#
SELECT
  CAST('NULL' AS DATE) <=> CAST('2008-01-01' AS DATE) AS n1,
  CAST('2008-01-01' AS DATE) <=> CAST('NULL' AS DATE) AS n2,
  CAST('NULL' AS DATE) <=> CAST('NULL' AS DATE) AS n3,
  CAST('NULL' AS DATE) <> CAST('2008-01-01' AS DATE) AS n4,
  CAST('2008-01-01' AS DATE) <> CAST('NULL' AS DATE) AS n5,
  CAST('NULL' AS DATE) <> CAST('NULL' AS DATE) AS n6,
  CAST('NULL' AS DATE) < CAST('2008-01-01' AS DATE) AS n7,
  CAST('2008-01-01' AS DATE) < CAST('NULL' AS DATE) AS n8,
  CAST('NULL' AS DATE) < CAST('NULL' AS DATE) AS n9;

#
# Rounding test
#
CREATE TABLE t1 (a DATETIME);
INSERT INTO t1 VALUES ('2001-01-01 10:10:10');
INSERT INTO t1 VALUES ('2001-01-01 10:10:11');
SELECT * FROM t1 ORDER BY a;
DROP TABLE t1;

#
# DATETIME and COALESCE with constant
#
CREATE TABLE t1 (b datetime);
INSERT INTO t1 VALUES ('2010-01-01 00:00:00'), ('2010-01-01 00:00:00');
SELECT * FROM t1 WHERE b <= COALESCE(NULL, '2099-12-31 23:59:59');
DROP TABLE t1;

#
# DATETIME IS NULL with NOT NULL column
#
CREATE TABLE t1 (a DATE NOT NULL, b INT);
INSERT INTO t1 VALUES ('1999-05-10',2);

CREATE TABLE t2 (a DATETIME NOT NULL, b INT);
INSERT INTO t2 VALUES ('1999-05-10 00:00:00',2);

SELECT * FROM t1 WHERE a IS NULL;
SELECT * FROM t2 WHERE a IS NULL;
DROP TABLE t1,t2;

# [RooDB-skip] Tuple IN comparison ((col1, col2) IN ((...), (...))) — not supported
#
# DATETIME IN with single-column comparison
#
CREATE TABLE t1 (
  pk int PRIMARY KEY,
  col_date date DEFAULT NULL,
  col_datetime datetime DEFAULT NULL,
  col_varchar VARCHAR(1) DEFAULT NULL
);

INSERT INTO t1 VALUES(5, '2022-02-25', '2022-02-25 11:01:14', 'I');

SELECT * FROM t1 WHERE pk = 5 AND col_datetime = '2022-02-25 11:01:14' AND col_varchar = 'I';
SELECT * FROM t1 WHERE pk = 5 AND col_date = '2022-02-25' AND col_varchar = 'I';
SELECT * FROM t1 WHERE pk = 5 AND col_varchar = 'I' AND col_date = '2022-02-25';

DROP TABLE t1;

#
# BETWEEN with NULL boundaries
#
CREATE TABLE t1 (
  pk int PRIMARY KEY,
  t0 TIME NOT NULL,
  t1 TIME NOT NULL,
  dt DATETIME
);

INSERT INTO t1 VALUES
(1, '08:00:00', '12:00:00', '2020-01-01 00:00:00'),
(2, '12:00:00', '12:00:00', '2020-01-01 00:00:00'),
(3, '16:00:00', '12:00:00', '2020-01-01 00:00:00');

SELECT pk, t0, t1, dt,
       t0 BETWEEN NULL AND t1 AS b1,
       t0 NOT BETWEEN NULL AND t1 AS b2
FROM t1 ORDER BY pk;

SELECT pk, t0, t1, dt,
       t1 BETWEEN t0 AND NULL AS b1,
       t1 NOT BETWEEN t0 AND NULL AS b2
FROM t1 ORDER BY pk;

DROP TABLE t1;

#
# Various DATETIME string formats
#
CREATE TABLE t1 (dt datetime);
INSERT INTO t1 VALUES ('2001-01-01 01:01:01');
INSERT INTO t1 VALUES ('2007-03-23 13:49:38');
INSERT INTO t1 VALUES ('2010-12-31 23:59:59');
SELECT * FROM t1 ORDER BY dt;
DROP TABLE t1;

#
# DATETIME with JOINs
#
CREATE TABLE t1 (id int PRIMARY KEY, dt datetime);
CREATE TABLE t2 (id int PRIMARY KEY, dt datetime);
INSERT INTO t1 VALUES (1, '2020-01-01 00:00:00'), (2, '2020-06-15 12:30:00');
INSERT INTO t2 VALUES (1, '2020-01-01 00:00:00'), (2, '2020-12-31 23:59:59');
SELECT t1.id, t1.dt, t2.dt FROM t1 INNER JOIN t2 ON t1.id = t2.id ORDER BY t1.id;
SELECT t1.id, t1.dt, t2.dt FROM t1 LEFT JOIN t2 ON t1.dt = t2.dt ORDER BY t1.id;
DROP TABLE t1, t2;

#
# DATETIME GROUP BY and aggregates
#
CREATE TABLE t1 (dt datetime, val int);
INSERT INTO t1 VALUES ('2020-01-01 00:00:00', 10),
                      ('2020-01-01 00:00:00', 20),
                      ('2020-06-15 12:00:00', 30),
                      ('2020-06-15 12:00:00', 40);
SELECT dt, SUM(val), COUNT(*), MIN(val), MAX(val) FROM t1 GROUP BY dt ORDER BY dt;
DROP TABLE t1;
