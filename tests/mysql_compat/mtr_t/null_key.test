#
# Adapted from MySQL null_key_innodb.inc for RooDB.
# Tests NULL key behavior in queries and joins.
#
# [RooDB-skip] SET sql_mode (not supported)
# [RooDB-skip] ANALYZE TABLE (not supported)
# [RooDB-skip] EXPLAIN (optimizer-specific)
# [RooDB-skip] --replace_column
# [RooDB-skip] SQL_CALC_FOUND_ROWS / FOUND_ROWS() (not supported)
# [RooDB-skip] FLUSH STATUS / SHOW STATUS (not supported)
# [RooDB-skip] --skip_if_hypergraph
# [RooDB-skip] INSERT ... SELECT into t3/t4 chain (INSERT ... SELECT from same table)
# [RooDB-skip] int(11) display widths (deprecated)
# [RooDB-skip] IS TRUE (mysqltest issue)

#
# NULL join behavior
#

create table t1 (id int);
insert into t1 values (null), (0);
create table t2 (id int);
insert into t2 values (null);
select * from t1, t2 where t1.id = t2.id;
drop table t1,t2;

#
# <=> NULL on indexed null field
#

create table t1 (
  id  integer,
  id2 integer not null
);
insert into t1 values(null,0),(1,1);
select * from t1;
select * from t1 where id <=> null;
select * from t1 where id <=> null or id > 0;
select * from t1 where id is null or id > 0;
select * from t1 where id2 <=> null or id2 > 0;
select * from t1 where id2 is null or id2 > 0;
delete from t1 where id <=> NULL;
select * from t1;
drop table t1;

#
# NULL keys with outer joins
#

CREATE TABLE t1 (a int);
CREATE TABLE t2 (a int, b int);
CREATE TABLE t3 (b int);
INSERT INTO t1 VALUES (1), (2), (3), (4);
INSERT INTO t2 VALUES (1, 1), (3, 1);
INSERT INTO t3 VALUES (NULL), (NULL), (NULL), (NULL), (NULL);
INSERT INTO t3 VALUES (NULL), (NULL), (NULL), (NULL), (NULL);
INSERT INTO t3 VALUES (2), (3);

SELECT COUNT(*) FROM t3;

--sorted_result
SELECT * FROM t1 LEFT JOIN t2 ON t1.a=t2.a
                 LEFT JOIN t3 ON t2.b=t3.b;

DROP TABLE t1,t2,t3;

#
# ref_or_null queries with null values
#

CREATE TABLE t1 (
  a int default NULL,
  b int default NULL
);
INSERT INTO t1 VALUES (0,10),(0,11),(0,12);

CREATE TABLE t2 (
  a int default NULL,
  b int default NULL
);
INSERT INTO t2 VALUES (3,NULL),(3,11),(3,12);

SELECT * FROM t2 inner join t1 WHERE ( t1.a = 0 OR t1.a IS NULL) AND t2.a = 3 AND t2.b = t1.b;

drop table t1, t2;

#
# IN + OR + IS NULL
#

CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1), (2), (NULL);
SELECT a FROM t1 WHERE a IN (42) OR (a=NULL);
drop table t1;

--echo # End of null_key tests
