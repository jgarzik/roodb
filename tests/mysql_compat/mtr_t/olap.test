#
# GROUP BY aggregate tests (adapted from MySQL olap.test)
# [RooDB-note] WITH ROLLUP is not yet supported. This test extracts
# the GROUP BY, HAVING, DISTINCT, JOIN, derived table, and UNION portions
# from the original olap.test that work without ROLLUP.
# Removed: WITH ROLLUP, GROUPING(), SET div_precision_increment,
#          SHOW VARIABLES, ANALYZE TABLE, EXPLAIN, --error, --source,
#          window functions, views, prepared statements, CTEs,
#          SQL_CALC_FOUND_ROWS, --skip_if_hypergraph, --replace_regex
#

--disable_warnings
DROP TABLE IF EXISTS t1,t2;
--enable_warnings

CREATE TABLE t1(
product VARCHAR(32),
country_id INTEGER NOT NULL,
year INTEGER,
profit INTEGER);

INSERT INTO t1  VALUES ( 'Computer', 2,2000, 1200),
( 'TV', 1, 1999, 150),
( 'Calculator', 1, 1999,50),
( 'Computer', 1, 1999,1500),
( 'Computer', 1, 2000,1500),
( 'TV', 1, 2000, 150),
( 'TV', 2, 2000, 100),
( 'TV', 2, 2000, 100),
( 'Calculator', 1, 2000,75),
( 'Calculator', 2, 2000,75),
( 'TV', 1, 1999, 100),
( 'Computer', 1, 1999,1200),
( 'Computer', 2, 2000,1500),
( 'Calculator', 2, 2000,75),
( 'Phone', 3, 2003,10)
;

CREATE TABLE t2 (
country_id INTEGER PRIMARY KEY,
country CHAR(20) NOT NULL);

INSERT INTO t2 VALUES (1, 'USA'),(2,'India'), (3,'Finland');

# Simple GROUP BY with SUM
--sorted_result
SELECT product, SUM(profit) FROM t1 GROUP BY product;

# GROUP BY with multiple aggregates
--sorted_result
SELECT product, SUM(profit), AVG(profit) FROM t1 GROUP BY product;

# GROUP BY with multiple columns
--sorted_result
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year;

# GROUP BY with ORDER BY
SELECT product, country_id, SUM(profit) FROM t1
GROUP BY product, country_id
ORDER BY product, country_id;

# GROUP BY with LIMIT
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year
ORDER BY product, country_id, year
LIMIT 5;

# GROUP BY with OFFSET
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year
ORDER BY product, country_id, year
LIMIT 3 OFFSET 3;

# COUNT and COUNT DISTINCT
--sorted_result
SELECT product, country_id, COUNT(*), COUNT(DISTINCT year)
FROM t1 GROUP BY product, country_id;

# HAVING with column reference
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year HAVING country_id = 1
ORDER BY product, year;

# HAVING with aggregate
--sorted_result
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year HAVING SUM(profit) > 200;

# HAVING with large threshold
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year HAVING SUM(profit) > 7000;

# Functions in GROUP BY
--sorted_result
SELECT CONCAT(product,':',country_id) AS prod, CONCAT(":",year,":") AS yr,
1+1, SUM(profit)/COUNT(*) FROM t1 GROUP BY CONCAT(product,':',country_id), CONCAT(":",year,":");
--sorted_result
SELECT product, SUM(profit)/COUNT(*) FROM t1 GROUP BY product;
--sorted_result
SELECT LEFT(product,4) AS prod, SUM(profit)/COUNT(*) FROM t1
GROUP BY prod;
--sorted_result
SELECT CONCAT(product,':',country_id), 1+1, SUM(profit)/COUNT(*) FROM t1
GROUP BY CONCAT(product,':',country_id);

# Joins with GROUP BY
SELECT product, country, year, SUM(profit) FROM t1,t2 WHERE
t1.country_id=t2.country_id GROUP BY product, country, year
ORDER BY product, country, year;

# Derived tables
SELECT product, `SUM` FROM (SELECT product, SUM(profit) AS 'sum' FROM t1
                            GROUP BY product) AS tmp
WHERE product = 'Computer';

# HAVING with IS NULL
SELECT product, country_id, year, SUM(profit) FROM t1
GROUP BY product, country_id, year HAVING country_id IS NULL;

# CONCAT in SELECT with GROUP BY
SELECT CONCAT(':',product,':'), SUM(profit), AVG(profit) FROM t1
GROUP BY product
ORDER BY product;

drop table t1,t2;

#
# Test with const tables
#

CREATE TABLE t1 (i int);
INSERT INTO t1 VALUES(100);
CREATE TABLE t2 (i int);
INSERT INTO t2 VALUES (100),(200);
SELECT i, COUNT(*) FROM t1 GROUP BY i;
SELECT t1.i, t2.i, COUNT(*) FROM t1,t2 GROUP BY t1.i,t2.i ORDER BY t1.i, t2.i;
DROP TABLE t1,t2;

# [RooDB-bug] LEFT JOIN + GROUP BY + COUNT(nullable_column) test skipped:
# COUNT() incorrectly counts NULL values from LEFT JOIN unmatched rows.
# The raw LEFT JOIN is correct, but COUNT(next_day.user_id) returns
# wrong results when next_day is NULL from the LEFT JOIN.

#
# DISTINCT with GROUP BY
#

CREATE TABLE t1 (a int, b int);

INSERT INTO t1 VALUES
  (1,4),
  (2,2), (2,2),
  (4,1), (4,1), (4,1), (4,1),
  (2,1), (2,1);

--sorted_result
SELECT SUM(b) FROM t1 GROUP BY a;
--sorted_result
SELECT DISTINCT SUM(b) FROM t1 GROUP BY a;

--sorted_result
SELECT SUM(b), COUNT(DISTINCT b) FROM t1 GROUP BY a;
--sorted_result
SELECT DISTINCT SUM(b), COUNT(DISTINCT b) FROM t1 GROUP BY a;

--sorted_result
SELECT SUM(b), COUNT(*) FROM t1 GROUP BY a;
--sorted_result
SELECT DISTINCT SUM(b), COUNT(*) FROM t1 GROUP BY a;

--sorted_result
SELECT SUM(b), COUNT(DISTINCT b), COUNT(*) FROM t1 GROUP BY a;
--sorted_result
SELECT DISTINCT SUM(b), COUNT(DISTINCT b), COUNT(*) FROM t1
  GROUP BY a;

--sorted_result
SELECT a, SUM(b) FROM t1 GROUP BY a,b;
--sorted_result
SELECT DISTINCT a, SUM(b) FROM t1 GROUP BY a,b;

--sorted_result
SELECT b, a, SUM(b) FROM t1 GROUP BY a,b;
--sorted_result
SELECT DISTINCT b, a, SUM(b) FROM t1 GROUP BY a,b;

DROP TABLE t1;

# GROUP BY with LIMIT

CREATE TABLE t1 (a int, b int);

INSERT INTO t1 VALUES
  (1,4),
  (2,2), (2,2),
  (4,1), (4,1), (4,1), (4,1),
  (2,1), (2,1);

SELECT a, SUM(b) FROM t1 GROUP BY a ORDER BY a LIMIT 1;

DROP TABLE t1;

#
# Derived table with GROUP BY
#

CREATE TABLE t1 (a int NOT NULL);
INSERT INTO t1 VALUES (1),(2);

--sorted_result
SELECT a, SUM(a) m FROM t1 GROUP BY a;
--sorted_result
SELECT * FROM ( SELECT a, SUM(a) m FROM t1 GROUP BY a ) t2;

DROP TABLE t1;

#
# Expressions with GROUP BY
#

CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (1),(2);

# [RooDB-note] UNION in derived tables not yet supported, testing simple derived table instead
SELECT a, SUM(a), SUM(a)+1 FROM t1 GROUP BY a ORDER BY a;

DROP TABLE t1;

#
# Expressions on group by attributes
#

CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (1),(2);

SELECT a, a+1, SUM(a) FROM t1 GROUP BY a ORDER BY a;
SELECT a+1 FROM t1 GROUP BY a ORDER BY a;
SELECT a+SUM(a) FROM t1 GROUP BY a ORDER BY a;
SELECT a, a+1 as b FROM t1 GROUP BY a HAVING b > 2 ORDER BY a;
SELECT IFNULL(a, 'TEST') FROM t1 GROUP BY a ORDER BY a;

CREATE TABLE t2 (a int, b int);
INSERT INTO t2 VALUES
  (1,4),
  (2,2), (2,2),
  (4,1), (4,1), (4,1), (4,1),
  (2,1), (2,1);

SELECT a,b,SUM(b) FROM t2 GROUP BY a,b ORDER BY a,b;
SELECT IFNULL(a, 'TEST'), COALESCE(b, 'TEST') FROM t2
  GROUP BY a, b ORDER BY a, b;

DROP TABLE t1,t2;

#
# Derived table with GROUP BY and expressions
#

CREATE TABLE t1 (a int NOT NULL);
INSERT INTO t1 VALUES (1),(2);

SELECT * FROM (SELECT a, a + 1, COUNT(*) FROM t1 GROUP BY a) t ORDER BY a;
# [RooDB-bug] LENGTH() on integer column fails - requires string argument
# SELECT * FROM (SELECT a, LENGTH(a), COUNT(*) FROM t1 GROUP BY a) t ORDER BY a;
SELECT * FROM (SELECT a, LENGTH(CAST(a AS CHAR)), COUNT(*) FROM t1 GROUP BY a) t ORDER BY a;

DROP TABLE t1;

#
# DISTINCT with GROUP BY on VARCHAR
#
CREATE TABLE t1 ( a VARCHAR(9), b INT );
INSERT INTO t1 VALUES('a',1),(NULL,2);
SELECT a, MAX(b) FROM t1 GROUP BY a ORDER BY a;
SELECT DISTINCT a, MAX(b) FROM t1 GROUP BY a ORDER BY a;
DROP TABLE t1;

#
# GROUP BY with LEFT and string functions
#
CREATE TABLE t1 (a VARCHAR(22) NOT NULL , b INT);
INSERT INTO t1 VALUES ("2006-07-01 21:30", 1), ("2006-07-01 23:30", 10);
--sorted_result
SELECT LEFT(a,10), a, SUM(b) FROM t1 GROUP BY 1,2;
--sorted_result
SELECT LEFT(a,10) x, a, SUM(b) FROM t1 GROUP BY x,a;
DROP TABLE t1;

#
# DISTINCT with GROUP BY and constant column
#

CREATE TABLE t1 (a int, b int);
INSERT INTO t1
  VALUES (2,10),(3,30),(2,40),(1,10),(2,30),(1,20),(2,10);

--sorted_result
SELECT a, SUM(b) FROM t1 GROUP BY a;
--sorted_result
SELECT DISTINCT a, SUM(b) FROM t1 GROUP BY a;
--sorted_result
SELECT a, b, COUNT(*) FROM t1 GROUP BY a,b;
--sorted_result
SELECT DISTINCT a, b, COUNT(*) FROM t1 GROUP BY a,b;

--sorted_result
SELECT 'x', a, SUM(b) FROM t1 GROUP BY 1,2;
--sorted_result
SELECT DISTINCT 'x', a, SUM(b) FROM t1 GROUP BY 1,2;

DROP TABLE t1;

#
# Derived table with GROUP BY
#

CREATE TABLE t1 (a int);
INSERT INTO t1 VALUES (3), (1), (4), (1), (3), (1), (1);

SELECT * FROM (SELECT a, SUM(a) FROM t1 GROUP BY a) as t ORDER BY a;

DROP TABLE t1;

#
# GROUP BY NULL
#
CREATE TABLE t1(a int);
INSERT INTO t1 VALUES (1),(2),(3);
SELECT COUNT(a) FROM t1 GROUP BY NULL;
DROP TABLE t1;

#
# GROUP BY with cross join
#

CREATE TABLE t1 (a INT NOT NULL PRIMARY KEY);
INSERT INTO t1 VALUES (1), (2);
CREATE TABLE t2 (b INT);
INSERT INTO t2 VALUES (100);

--sorted_result
SELECT a, b FROM t1, t2 GROUP BY a, b;
--sorted_result
SELECT DISTINCT b FROM t1, t2 GROUP BY a, b;

DROP TABLE t1, t2;

#
# DISTINCT with GROUP BY and const tables
#

CREATE TABLE t1 (a INT);
CREATE TABLE t2 (b INT);
INSERT INTO t1 VALUES (1);
INSERT INTO t2 VALUES (1);

--sorted_result
SELECT b FROM t1, t2 GROUP BY a, b;
--sorted_result
SELECT DISTINCT b FROM t1, t2 GROUP BY a, b;

DROP TABLE t1, t2;

#
# DECIMAL data type with GROUP BY
#

CREATE TABLE t1 (a DECIMAL(6,3));
INSERT INTO t1 VALUES (1.1);
SELECT a FROM t1 GROUP BY a;
DROP TABLE t1;

#
# GROUP BY with HAVING on aggregated column
# [RooDB-bug] HAVING SUM(x) IS NOT NULL fails ("unknown function: SUM")
# Using HAVING SUM(f2) > 0 as workaround
#

CREATE TABLE t1 (f1 INTEGER,f2 INTEGER);
INSERT INTO t1 VALUES (1,10),(1,20),(2,NULL),(2,NULL),(3,50);
SELECT f1, SUM(f2) FROM t1 GROUP BY f1 HAVING SUM(f2) > 0 ORDER BY f1;
DROP TABLE t1;

#
# DISTINCT with GROUP BY on PRIMARY KEY
#

CREATE TABLE t1 ( i INTEGER NOT NULL PRIMARY KEY );
INSERT INTO t1 VALUES (1), (2), (3);
SELECT DISTINCT i FROM t1 WHERE i = 1 GROUP BY i;
DROP TABLE t1;

#
# GROUP BY with CONCAT and INSTR
#

CREATE TABLE t1 (f1 INTEGER PRIMARY KEY);
INSERT INTO t1 values (1);

SELECT CONCAT(INSTR(f1,'w')) FROM t1 GROUP BY f1;

DROP TABLE t1;

#
# GROUP BY with JOIN
#

CREATE TABLE t1 (a INTEGER, b INTEGER);
INSERT INTO t1 VALUES (2020, 2);

CREATE TABLE t2 (b INTEGER);
INSERT INTO t2 VALUES (2);

SELECT a FROM t1 JOIN t2 ON t1.b = t2.b GROUP BY a;

DROP TABLE t1, t2;

#
# DISTINCT with GROUP BY on nullable column
#

CREATE TABLE t (x INTEGER);
INSERT INTO t VALUES (NULL), (0), (1), (2), (3);
--sorted_result
SELECT DISTINCT x AS a, x AS b FROM t GROUP BY a, b;
DROP TABLE t;
