--echo # FROM_DAYS / SUBSTRING_INDEX / MAKE_SET / TIMESTAMPDIFF / TIMESTAMPADD

--echo # --- FROM_DAYS ---
SELECT FROM_DAYS(TO_DAYS('2024-01-15'));
SELECT FROM_DAYS(TO_DAYS('1999-12-31'));
SELECT FROM_DAYS(TO_DAYS('2000-02-29'));
SELECT FROM_DAYS(0);

--echo # --- SUBSTRING_INDEX ---
SELECT SUBSTRING_INDEX('www.example.com', '.', 1);
SELECT SUBSTRING_INDEX('www.example.com', '.', 2);
SELECT SUBSTRING_INDEX('www.example.com', '.', -1);
SELECT SUBSTRING_INDEX('www.example.com', '.', -2);
SELECT SUBSTRING_INDEX('a::b::c', '::', 2);
SELECT SUBSTRING_INDEX('hello', '.', 5);
SELECT SUBSTRING_INDEX('a,b,c', ',', 0);

--echo # --- MAKE_SET ---
SELECT MAKE_SET(1, 'a', 'b', 'c');
SELECT MAKE_SET(5, 'a', 'b', 'c');
SELECT MAKE_SET(7, 'a', 'b', 'c');
SELECT MAKE_SET(0, 'a', 'b', 'c');
SELECT MAKE_SET(3, 'hello', 'world', 'test');

--echo # --- TIMESTAMPDIFF ---
SELECT TIMESTAMPDIFF(DAY, '2024-01-01', '2024-01-15');
SELECT TIMESTAMPDIFF(MONTH, '2024-01-01', '2024-06-15');
SELECT TIMESTAMPDIFF(YEAR, '2020-01-01', '2024-06-15');
SELECT TIMESTAMPDIFF(HOUR, '2024-01-01 00:00:00', '2024-01-01 12:30:00');
SELECT TIMESTAMPDIFF(MINUTE, '2024-01-01 00:00:00', '2024-01-01 02:30:00');
SELECT TIMESTAMPDIFF(SECOND, '2024-01-01 00:00:00', '2024-01-01 00:01:30');

--echo # --- TIMESTAMPADD ---
SELECT TIMESTAMPADD(DAY, 10, '2024-01-01');
SELECT TIMESTAMPADD(MONTH, 3, '2024-01-15');
SELECT TIMESTAMPADD(YEAR, 1, '2024-02-29');
SELECT TIMESTAMPADD(HOUR, 5, '2024-01-01 10:00:00');
