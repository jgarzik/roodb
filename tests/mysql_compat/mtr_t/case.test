#
# Bug #25051195: IFNULL with GROUP BY
#
CREATE TABLE t (i1 INT,
                d1 DOUBLE,
                e2 DECIMAL(5,2));

INSERT INTO t VALUES ( 6,    6.0,  10.0/3),
                     ( null, 9.0,  10.0/3),
                     ( 1,    null, 10.0/3),
                     ( 2,    2.0,  null  );

SELECT IFNULL(e2,i1) nullif_c,
       IF(e2 IS NULL,i1,e2) if_c,
       SUM(d1) FROM t
       GROUP BY e2,i1 ORDER BY nullif_c, SUM(d1);

DROP TABLE t;

# [RooDB-skip] DATETIME/TIME fractional seconds with SET TIMESTAMP

#
# Test CASE with VARCHAR
#
CREATE TABLE t1 (a VARCHAR(110));
INSERT INTO t1 VALUES (REPEAT("a",100));
SELECT CASE t1.a WHEN 'a' THEN 'c' ELSE 'd' END FROM t1;
DROP TABLE t1;

#
# Bug: aggregates inside CASE WHEN comparison expressions
# COUNT(*) inside CASE WHEN condition must be recognized as aggregate
#
CREATE TABLE t1 (id INT, max_req INT);
INSERT INTO t1 VALUES (1, 3), (2, 3), (3, 3), (4, 2), (5, 2);
--sorted_result
SELECT CASE WHEN COUNT(*) < max_req THEN 1 ELSE 0 END AS flag, max_req FROM t1 GROUP BY max_req;
--sorted_result
SELECT CASE WHEN SUM(id) > max_req THEN 'yes' ELSE 'no' END AS result, max_req FROM t1 GROUP BY max_req;
DROP TABLE t1;

