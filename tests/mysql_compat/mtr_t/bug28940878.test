# Adapted from MySQL bug28940878.test for RooDB compatibility testing.
# Tests invalid date comparisons and error handling.
#
# [RooDB-skip] SET sql_mode = 'ALLOW_INVALID_DATES' — not supported

--echo #bug28940878
CREATE TABLE t1(d DATE);
INSERT INTO t1 VALUES('2011-02-20');

# In the default sql mode invalid dates should produce errors or empty results
SELECT * FROM t1 WHERE d <= '2013-02-28';
SELECT * FROM t1 WHERE d >= '2010-01-01';
SELECT * FROM t1 WHERE d = '2011-02-20';
SELECT * FROM t1 WHERE d < '2011-02-20';
SELECT * FROM t1 WHERE d > '2011-02-20';
SELECT * FROM t1 WHERE d BETWEEN '2011-01-01' AND '2011-12-31';
SELECT * FROM t1 WHERE d NOT BETWEEN '2012-01-01' AND '2012-12-31';

# Additional date edge case tests
INSERT INTO t1 VALUES('2023-12-31');
INSERT INTO t1 VALUES('2000-01-01');
INSERT INTO t1 VALUES('1999-06-15');

SELECT * FROM t1 ORDER BY d;
SELECT * FROM t1 WHERE d >= '2000-01-01' AND d <= '2020-12-31' ORDER BY d;
SELECT MIN(d), MAX(d) FROM t1;
SELECT COUNT(*) FROM t1 WHERE d > '2010-01-01';

DROP TABLE t1;
