--echo # Window functions over aggregate expressions

CREATE TABLE t1 (dept INT, emp VARCHAR(10), sal INT);
INSERT INTO t1 VALUES (1, 'a', 100), (1, 'b', 200), (2, 'c', 300), (2, 'd', 150);

--echo # --- ROW_NUMBER ordered by SUM(sal) DESC ---
SELECT dept, SUM(sal) as total, ROW_NUMBER() OVER (ORDER BY SUM(sal) DESC) as rnk FROM t1 GROUP BY dept ORDER BY dept;

--echo # --- Window ORDER BY group-by column ---
SELECT dept, SUM(sal) as total, ROW_NUMBER() OVER (ORDER BY dept) as rnk FROM t1 GROUP BY dept ORDER BY dept;

DROP TABLE t1;
