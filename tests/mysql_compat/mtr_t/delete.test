--echo #
--echo # Bug#27455809: DELETE FROM ...WHERE NOT EXISTS WITH TABLE ALIAS
--echo #

CREATE TABLE t1 (c1 INT);
INSERT INTO t1 VALUES (1), (2);
SELECT * FROM t1;

DELETE FROM t1 WHERE c1 = 2;
SELECT * FROM t1;

DROP TABLE t1;

--echo #
--echo # Bug#20460208: DELETE with error column
--echo #

CREATE TABLE t1(a INTEGER);
CREATE TABLE t2(a INT);
--error ER_BAD_FIELD_ERROR
INSERT INTO t1 SET z=1;
INSERT INTO t2 VALUES('a');
DELETE FROM t2 WHERE 1 = a;
DROP TABLE t1, t2;

--echo # Basic DELETE with multiple rows and conditions

CREATE TABLE t1 (a INT PRIMARY KEY, b VARCHAR(10));
INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three'), (4, 'four'), (5, 'five');

DELETE FROM t1 WHERE a > 3;
SELECT * FROM t1;

DELETE FROM t1 WHERE b = 'two';
SELECT * FROM t1;

DELETE FROM t1 ORDER BY a DESC LIMIT 1;
SELECT * FROM t1;

DELETE FROM t1;
SELECT * FROM t1;

DROP TABLE t1;
