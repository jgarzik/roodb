--echo # WEEKOFYEAR and TO_SECONDS tests

--echo # --- WEEKOFYEAR ---
SELECT WEEKOFYEAR('2024-01-01');
SELECT WEEKOFYEAR('2024-01-07');
SELECT WEEKOFYEAR('2024-06-15');
SELECT WEEKOFYEAR('2024-12-31');

--echo # --- WEEKOFYEAR NULL ---
SELECT WEEKOFYEAR(NULL);

--echo # --- TO_SECONDS ---
SELECT TO_SECONDS('2024-01-15');
SELECT TO_SECONDS('2024-01-15 12:00:00');

--echo # --- TO_SECONDS = TO_DAYS * 86400 for date-only ---
SELECT TO_SECONDS('2024-01-15') = TO_DAYS('2024-01-15') * 86400;
SELECT TO_SECONDS('1999-12-31') = TO_DAYS('1999-12-31') * 86400;

--echo # --- TO_SECONDS with time adds hours/min/sec ---
SELECT TO_SECONDS('2024-01-15 12:00:00') - TO_SECONDS('2024-01-15') = 43200;
SELECT TO_SECONDS('2024-01-15 01:01:01') - TO_SECONDS('2024-01-15') = 3661;

--echo # --- TO_SECONDS NULL ---
SELECT TO_SECONDS(NULL);
