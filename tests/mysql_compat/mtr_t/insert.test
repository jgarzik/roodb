# Trimmed from MySQL insert.test for RooDB compatibility testing.
# Tests basic INSERT INTO, INSERT SET, multi-row INSERT, INSERT with expressions.

#
# Basic INSERT values
#
CREATE TABLE t1 (a int NOT NULL);
INSERT INTO t1 VALUES (1);
INSERT INTO t1 VALUES (2),(3),(4);
SELECT * FROM t1;
DROP TABLE t1;

#
# INSERT with default values and INSERT SET
#
CREATE TABLE t1 (a int NOT NULL, c char(10) DEFAULT 'hello', i int);
INSERT INTO t1 VALUES (1, 'test', 10), (2, 'foo', 20), (3, DEFAULT, 30), (4, DEFAULT, DEFAULT);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t1 (a int NOT NULL, b int DEFAULT 0, c varchar(20) DEFAULT 'none');
INSERT INTO t1 SET a=1, b=10, c='first';
INSERT INTO t1 SET a=2, b=20, c='second';
# [RooDB-skip] INSERT SET ... DEFAULT keyword
INSERT INTO t1 SET a=4;
SELECT * FROM t1;
DROP TABLE t1;

#
# INSERT NULL into NOT NULL column
#
CREATE TABLE t1 (id int NOT NULL DEFAULT 8);
-- error 1048
INSERT INTO t1 VALUES(NULL);
SELECT * FROM t1;
DROP TABLE t1;

#
# Wrong number of fields
#
CREATE TABLE t1 (a INTEGER, b INTEGER);
INSERT INTO t1 VALUES(1, 1);
--error ER_WRONG_VALUE_COUNT_ON_ROW
INSERT INTO t1 VALUES(1);
--error ER_WRONG_VALUE_COUNT_ON_ROW
INSERT INTO t1 VALUES(1, 1, 1);
--error ER_WRONG_VALUE_COUNT_ON_ROW
INSERT INTO t1 VALUES(1, 1), (2);
--error ER_WRONG_VALUE_COUNT_ON_ROW
INSERT INTO t1 VALUES(1, 1), (3, 3, 3);
DROP TABLE t1;

#
# Multi-row INSERT
#
CREATE TABLE t1 (a int, b varchar(20));
INSERT INTO t1 VALUES (1, 'one'), (2, 'two'), (3, 'three');
SELECT * FROM t1;
DROP TABLE t1;

#
# INSERT with expressions
#
CREATE TABLE t1 (a int, b int, c int);
INSERT INTO t1 VALUES (1, 2, 1+2);
INSERT INTO t1 VALUES (10, 20, 10*2+5);
INSERT INTO t1 VALUES (100, 200, 100-50);
SELECT * FROM t1;
DROP TABLE t1;

#
# INSERT into specific columns
#
CREATE TABLE t1 (a int, b int DEFAULT 99, c varchar(20) DEFAULT 'hi');
INSERT INTO t1 (a) VALUES (1);
INSERT INTO t1 (a, c) VALUES (2, 'world');
INSERT INTO t1 (b, a) VALUES (77, 3);
SELECT * FROM t1;
DROP TABLE t1;

#
# INSERT with numeric string conversions
#
CREATE TABLE t1 (c1 INT NOT NULL);
INSERT INTO t1 VALUES(4188), (0), (-100), (999999);
SELECT * FROM t1;
DROP TABLE t1;
