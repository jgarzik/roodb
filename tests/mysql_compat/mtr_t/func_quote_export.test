--echo # QUOTE and EXPORT_SET

--echo # --- QUOTE ---
SELECT QUOTE('hello');
SELECT QUOTE('');
SELECT QUOTE(NULL);
SELECT QUOTE('it''s');

--echo # --- EXPORT_SET ---
SELECT EXPORT_SET(5, 'Y', 'N', ',', 4);
SELECT EXPORT_SET(6, '1', '0', ',', 10);
SELECT EXPORT_SET(0, 'Y', 'N', ',', 4);
SELECT EXPORT_SET(15, 'Y', 'N', ',', 4);
SELECT EXPORT_SET(1, 'on', 'off', '-', 3);

--echo # --- EXPORT_SET defaults ---
SELECT EXPORT_SET(5, 'Y', 'N', ',', 8);
